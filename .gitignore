# ── Dependências ────────────────────────────────────────────
node_modules/

# ── Builds e outputs ────────────────────────────────────────
dist/
build/
out/
.next/

# ── Cache TypeScript ─────────────────────────────────────────
*.tsbuildinfo

# ── Output acidental de tsc dentro de src/ (Vite usa noEmit) ─
**/src/**/*.js
**/src/**/*.js.map
**/src/**/*.d.ts
**/src/**/*.d.ts.map

# ── Scratch / preview / fragments temporários ────────────────
_*/
_preview_*.html

# ── Prisma engines gerados (plataforma-específicos) ──────────
**/generated/libquery_engine-*
**/generated/query_engine-*

# ── Variáveis de ambiente (NUNCA commitar segredos!) ─────────
.env
.env.local
.env.*.local

# ── Prisma ───────────────────────────────────────────────────
prisma/dev.db
prisma/dev.db-journal
*.tmp*
configurador/generated/*.tmp*

# ── Logs ─────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Testes (outputs gerados) ─────────────────────────────────
playwright-report/
test-results/
testes/**/resultados/

# ── Turborepo (proibido na Fase 1, mas previne lixo residual) ─
.turbo/

# ── Vite ─────────────────────────────────────────────────────
*.timestamp-*.mjs

# ── Sistema operacional ──────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor ───────────────────────────────────────────────────
.vscode/settings.json
.idea/

*storybook.log
storybook-static

servicos-global/organizacao/pedido/server/backups/

# ── Arquivos temporarios de trabalho (planilhas, scratch) ─
.claude/planilha-tmp.xlsx
.claude/*.tmp.*
