# ============================================================
# Configurador — .env.example
# Copie para .env e preencha com os valores reais.
# NUNCA commite o arquivo .env com valores reais.
# Versões: T26000001 (Staging) / P26000001 (Produção)
# ============================================================

# --- Banco de Dados (Configurador DB) ---
# Staging (T26000001): obter em Railway > configurador-db-staging > Connect
# Produção (P26000001): obter em Railway > configurador-db-prod > Connect
CONFIGURADOR_DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/configurador_db?sslmode=require

# --- Autenticação (Clerk) ---
# Obter em: https://dashboard.clerk.com > API Keys
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# --- Billing (Stripe) ---
# Staging: usar chave de teste (sk_test_...)
# Produção: usar chave live (sk_live_...)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Comunicação entre Serviços (S2S) ---
# Mesmo valor em todos os serviços — rotacionar trimestralmente
# Railway internal: configurador.railway.internal:3000
INTERNAL_SERVICE_KEY=gravity_internal_...

# --- Ambiente ---
# Valores: development | staging | production
NODE_ENV=development
PORT=3000

# --- Observabilidade ---
SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project_id>
LOG_LEVEL=info
