// configurador/prisma/schema.prisma
// GERADO PELO AGENTE 0B — BANCO DE DADOS
// Este arquivo é gerenciado diretamente pelo Configurador.
// NÃO usar como base para fragments de tenant.

generator client {
  provider      = "prisma-client-js"
  output        = "../generated"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("CONFIGURADOR_DATABASE_URL")
}

// ---------------------------------------------------------------------------
// ENUMS
// ---------------------------------------------------------------------------

enum OrganizacaoStatus {
  ATIVO
  SUSPENSO
  CANCELADO
  CONFIGURACAO_PENDENTE
}

enum StatusAssinaturaProdutoGravity {
  ATIVA
  EM_TESTE
  SUSPENSA
  CANCELADA
}

// Roles canônicos do sistema — alinhados com skill antigravity-permissoes
enum UsuarioTipo {
  SUPER_ADMIN // Equipe Gravity — acesso total irrestrito
  ADMIN // Equipe Gravity — acesso com permissões explícitas
  MASTER // Cliente — acesso total na organização
  PADRAO // Cliente — acesso conforme permissões do Master
  FORNECEDOR // Fornecedor — permissões explícitas obrigatórias (cross-tenant)
}

enum WorkspaceStatus {
  ATIVO
  INATIVO
}

enum TipoUsuarioWorkspace {
  MASTER // Acesso implícito a todos os workspaces da organização
  PADRAO // Acesso apenas aos workspaces onde foi habilitado
  FORNECEDOR // Acesso externo — permissões granulares obrigatórias
}

enum APITokenServico {
  SERVICO
  WEBHOOK
  CRON
}

// ---------------------------------------------------------------------------
// TENANT
// Cada empresa que assina a plataforma Gravity é um Organizacao.
// id_organizacao = id do próprio registro (self-referencing por convenção).
// ---------------------------------------------------------------------------

model Organizacao {
  id_organizacao           String            @id @default(cuid())
  nome_organizacao         String
  subdominio_organizacao   String            @unique
  status_organizacao       OrganizacaoStatus @default(CONFIGURACAO_PENDENTE)
  clerk_organizacao_id     String?           @unique(map: "organizacao_clerk_organizacao_id_key")
  suid_empresa_organizacao String?           @unique(map: "organizacao_suid_empresa_organizacao_key")

  // Dados cadastrais da organização
  cnpj_organizacao     String?
  estado_organizacao   String?
  cidade_organizacao   String?
  segmento_organizacao String?
  tipo_organizacao     String?

  // Metadata
  data_criacao_organizacao     DateTime @default(now())
  data_atualizacao_organizacao DateTime @updatedAt

  // Relações
  users_organizacao             Usuario[]
  subscriptions_organizacao     ProdutoGravityAssinatura[]
  user_permissions_organizacao  UsuarioPermissao[]
  companies_organizacao         Workspace[]
  product_configs_organizacao   ProdutoGravityConfiguracao[]
  ProdutoGravityWorkspace       ProdutoGravityWorkspace[]
  faturas_organizacao           ProdutoGravityFatura[]
  fatura_itens_organizacao      ProdutoGravityFaturaItem[]
  fatura_documentos_organizacao ProdutoGravityFaturaDocumento[]

  @@index([status_organizacao], map: "status_organizacao_idx")
  @@index([subdominio_organizacao], map: "subdominio_organizacao_idx")
  @@map("organizacao")
}

// ---------------------------------------------------------------------------
// USER
// Usuário vinculado a um tenant. Autenticado via Clerk.
// id_organizacao é obrigatório — nunca nullable.
// ---------------------------------------------------------------------------

model Usuario {
  id_usuario       String      @id @default(cuid())
  id_organizacao   String
  id_clerk_usuario String      @unique(map: "usuario_id_clerk_usuario_key")
  email_usuario    String
  nome_usuario     String
  tipo_usuario     UsuarioTipo @default(PADRAO)

  // Workspace preferido — skip pós-login para Master/Standard
  // Supplier ignora este campo (fornecedor cross-tenant sempre vê tela de seleção)
  id_workspace_preferido_usuario String?

  // Timestamps
  data_criacao_usuario     DateTime @default(now())
  data_atualizacao_usuario DateTime @updatedAt

  // Relações
  tenant            Organizacao        @relation(fields: [id_organizacao], references: [id_organizacao], onDelete: Cascade, map: "usuario_id_organizacao_fkey")
  preferred_company Workspace?         @relation("UserPreferredCompany", fields: [id_workspace_preferido_usuario], references: [id_workspace], onDelete: SetNull, map: "usuario_id_workspace_preferido_usuario_fkey")
  user_permissions  UsuarioPermissao[]
  memberships       UsuarioWorkspace[]

  // Email único por organização
  @@unique([id_organizacao, email_usuario], map: "usuario_id_organizacao_email_usuario_key")
  // Índices obrigatórios
  @@index([id_organizacao], map: "usuario_id_organizacao_idx")
  @@index([id_organizacao, data_criacao_usuario], map: "usuario_id_organizacao_data_criacao_idx")
  @@index([id_organizacao, tipo_usuario], map: "usuario_id_organizacao_tipo_usuario_idx")
  @@index([id_workspace_preferido_usuario], map: "usuario_id_workspace_preferido_usuario_idx")
  @@map("usuario")
}

// ---------------------------------------------------------------------------
// SUBSCRIPTION
// Uma assinatura por tenant — vincula a Organizacao a um produto Gravity.
// id_organizacao é obrigatório — nunca nullable.
// ---------------------------------------------------------------------------

model ProdutoGravityAssinatura {
  id_assinatura_produto_gravity     String                         @id @default(cuid())
  id_organizacao                    String
  id_produto_gravity                String
  status_assinatura_produto_gravity StatusAssinaturaProdutoGravity @default(ATIVA)

  data_fim_teste_assinatura_produto_gravity      DateTime?
  data_inicio_periodo_assinatura_produto_gravity DateTime?
  data_fim_periodo_assinatura_produto_gravity    DateTime?
  data_cancelamento_assinatura_produto_gravity   DateTime?

  // Timestamps
  data_criacao_assinatura_produto_gravity     DateTime @default(now())
  data_atualizacao_assinatura_produto_gravity DateTime @updatedAt

  // Relações
  tenant  Organizacao    @relation(fields: [id_organizacao], references: [id_organizacao], onDelete: Cascade)
  produto ProdutoGravity @relation(fields: [id_produto_gravity], references: [id_produto_gravity], onDelete: Restrict, map: "apg_produto_fkey")

  // Apenas uma assinatura por (organizacao, produto)
  @@unique([id_organizacao, id_produto_gravity], map: "apg_org_produto_unq")
  // Índices obrigatórios — `map` explícito porque os nomes longos colidem após truncamento PG (63 chars)
  @@index([id_organizacao], map: "apg_org_idx")
  @@index([id_organizacao, data_criacao_assinatura_produto_gravity], map: "apg_org_criacao_idx")
  @@index([id_organizacao, status_assinatura_produto_gravity], map: "apg_org_status_idx")
  @@index([id_organizacao, id_produto_gravity], map: "apg_org_produto_idx")
  @@map("assinatura_produto_gravity")
}

// ---------------------------------------------------------------------------
// USER PERMISSION (Cadeia 2 — Permissões Granulares por Produto)
// Permissão granular de um usuário em um produto/workspace específico.
// Ex: permission = 'email:write', 'simulacusto:read'
// Alinhado com skill antigravity-permissoes.
// ---------------------------------------------------------------------------

model UsuarioPermissao {
  id_usuario_permissao            String @id @default(cuid())
  id_organizacao                  String
  id_workspace                    String // workspace onde se aplica (obrigatório)
  id_usuario                      String
  id_produto_gravity              String // produto ao qual a permissão pertence
  permissao_usuario               String // ex: 'email:write', 'simulacusto:read', 'atividades:read'
  permissao_usuario_concedido_por String // clerk_id do Master que concedeu a permissão

  // Timestamps
  data_criacao_permissao_usuario     DateTime @default(now())
  data_atualizacao_permissao_usuario DateTime @updatedAt

  // Relações
  tenant Organizacao @relation(fields: [id_organizacao], references: [id_organizacao], onDelete: Cascade, map: "usuario_permissao_id_organizacao_fkey")
  user   Usuario     @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade, map: "usuario_permissao_id_usuario_fkey")

  // Um usuário não pode ter permissão duplicada no mesmo produto/workspace
  @@unique([id_organizacao, id_workspace, id_usuario, id_produto_gravity, permissao_usuario], map: "usuario_permissao_org_ws_usu_prod_perm_unq")
  @@index([id_organizacao], map: "usuario_permissao_id_organizacao_idx")
  @@index([id_organizacao, id_usuario], map: "usuario_permissao_id_organizacao_usuario_idx")
  @@index([id_organizacao, id_workspace, id_usuario], map: "usuario_permissao_id_organizacao_workspace_usuario_idx")
  @@map("usuario_permissao")
}

// ---------------------------------------------------------------------------
// GRAVITY ADMIN PERMISSION (Cadeia 1 — Permissões de Edição para Admin Gravity)
// Controla o que um Admin interno da Gravity pode editar.
// Super Admin não usa esta tabela — tem acesso irrestrito.
// ---------------------------------------------------------------------------

model AdminGravityPermissao {
  id_permissao_usuario_admin            String @id @default(cuid())
  id_clerk_usuario                      String // clerk_id do Admin Gravity
  permissao_usuario_admin               String // ex: 'editar_tenants', 'visualizar_billing', 'gerenciar_deploy'
  concedido_por_permissao_usuario_admin String // clerk_id do Super Admin que concedeu

  // Timestamps
  data_criacao_permissao_usuario_admin     DateTime @default(now())
  data_atualizacao_permissao_usuario_admin DateTime @updatedAt

  // Admin não pode ter a mesma permissão duplicada
  @@unique([id_clerk_usuario, permissao_usuario_admin], map: "permissao_usuario_admin_gravity_admin_permissao_unq")
  @@index([id_clerk_usuario], map: "permissao_usuario_admin_gravity_admin_idx")
  @@map("permissao_usuario_admin_gravity")
}

// ---------------------------------------------------------------------------
// COMPANY
// Empresa filha (unidade de negócio) dentro de um tenant.
// Um tenant pode ter até 50 empresas filhas.
// ---------------------------------------------------------------------------

model Workspace {
  id_workspace         String          @id @default(cuid())
  id_organizacao       String
  nome_workspace       String
  subdominio_workspace String?         @unique(map: "workspace_subdominio_key")
  cnpj_workspace       String?
  status_workspace     WorkspaceStatus @default(ATIVO)

  // Endereço/contato (opcionais)
  cidade_workspace           String?
  estado_workspace           String?
  endereco_workspace         String?
  email_contato_workspace    String?
  telefone_contato_workspace String?

  // Timestamps
  data_criacao_workspace     DateTime @default(now())
  data_atualizacao_workspace DateTime @updatedAt

  // Relações
  tenant             Organizacao               @relation(fields: [id_organizacao], references: [id_organizacao], onDelete: Cascade, map: "workspace_id_organizacao_fkey")
  memberships        UsuarioWorkspace[]
  company_products   ProdutoGravityWorkspace[]
  preferred_by_users Usuario[]                 @relation("UserPreferredCompany")

  @@index([id_organizacao], map: "workspace_id_organizacao_idx")
  @@index([id_organizacao, status_workspace], map: "workspace_id_organizacao_status_idx")
  @@index([id_organizacao, data_criacao_workspace], map: "workspace_id_organizacao_data_criacao_idx")
  @@map("workspace")
}

// ---------------------------------------------------------------------------
// USER MEMBERSHIP
// Habilitação de um usuário do tenant em uma empresa filha.
// Define o papel (Master/Standard/Supplier) e o acesso a produtos.
// ---------------------------------------------------------------------------

model UsuarioWorkspace {
  id_usuario_workspace    String               @id @default(cuid())
  id_organizacao          String
  id_usuario              String
  id_workspace            String
  tipo_usuario_workspace  TipoUsuarioWorkspace @default(PADRAO)
  ativo_usuario_workspace Boolean              @default(true)

  // Timestamps
  data_criacao_usuario_workspace     DateTime @default(now())
  data_atualizacao_usuario_workspace DateTime @updatedAt

  // Relações
  user    Usuario   @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade, map: "usuario_workspace_id_usuario_fkey")
  company Workspace @relation(fields: [id_workspace], references: [id_workspace], onDelete: Cascade, map: "usuario_workspace_id_workspace_fkey")

  // Usuário não pode ter duplicata de habilitação na mesma empresa
  @@unique([id_organizacao, id_usuario, id_workspace], map: "usuario_workspace_id_organizacao_id_usuario_id_workspace_key")
  @@index([id_organizacao], map: "usuario_workspace_id_organizacao_idx")
  @@index([id_organizacao, id_usuario], map: "usuario_workspace_id_organizacao_id_usuario_idx")
  @@index([id_organizacao, id_workspace], map: "usuario_workspace_id_organizacao_id_workspace_idx")
  @@map("usuario_workspace")
}

// ---------------------------------------------------------------------------
// PRODUCT CONFIG
// Configurações de produto por tenant. Persistência do PRODUCT_CONFIG.
// product_key identifica o produto (ex: "simulacusto", "nf-importacao")
// ---------------------------------------------------------------------------

model ProdutoGravityConfiguracao {
  id_configuracao_produto_gravity             String  @id @default(cuid())
  id_organizacao_configuracao_produto_gravity String
  chave_produto_configuracao_produto_gravity  String
  configuracao_config_produto_gravity         Json    @default("{}")
  ativo_configuracao_produto_gravity          Boolean @default(true)

  // Timestamps
  data_criacao_configuracao_produto_gravity     DateTime @default(now())
  data_atualizacao_configuracao_produto_gravity DateTime @updatedAt

  // Relações — `map` explícito para nome curto (auto seria > 63 chars)
  tenant Organizacao @relation(fields: [id_organizacao_configuracao_produto_gravity], references: [id_organizacao], onDelete: Cascade, map: "cpg_org_fkey")

  // Apenas uma config por produto por tenant — `map` explícito para evitar colisão pós truncamento PG (63 chars)
  @@unique([id_organizacao_configuracao_produto_gravity, chave_produto_configuracao_produto_gravity], map: "cpg_org_chave_unq")
  // Índices obrigatórios — `map` explícito pelo mesmo motivo
  @@index([id_organizacao_configuracao_produto_gravity], map: "cpg_org_idx")
  @@index([id_organizacao_configuracao_produto_gravity, chave_produto_configuracao_produto_gravity], map: "cpg_org_chave_idx")
  @@index([id_organizacao_configuracao_produto_gravity, ativo_configuracao_produto_gravity], map: "cpg_org_ativo_idx")
  @@map("configuracao_produto_gravity")
}

// ---------------------------------------------------------------------------
// COMPANY PRODUCT (Cadeia 1.5 — Ativação por Workspace)
// Habilita um produto que o Organizacao já possui para um Workspace específico.
// ---------------------------------------------------------------------------

model ProdutoGravityWorkspace {
  id_produto_gravity_workspace    String  @id @default(cuid())
  id_organizacao                  String
  id_workspace                    String
  id_produto_gravity              String
  ativo_produto_gravity_workspace Boolean @default(true)

  // Timestamps
  data_contratacao_produto_gravity_workspace DateTime @default(now())
  data_atualizacao_produto_gravity_workspace DateTime @updatedAt

  // Relações
  tenant  Organizacao    @relation(fields: [id_organizacao], references: [id_organizacao], onDelete: Cascade, map: "pgw_org_fkey")
  company Workspace      @relation(fields: [id_workspace], references: [id_workspace], onDelete: Cascade, map: "pgw_ws_fkey")
  produto ProdutoGravity @relation(fields: [id_produto_gravity], references: [id_produto_gravity], onDelete: Cascade, map: "pgw_produto_fkey")

  // Apenas uma ativação por produto por workspace
  @@unique([id_workspace, id_produto_gravity], map: "pgw_ws_produto_unq")
  @@index([id_organizacao], map: "pgw_org_idx")
  @@index([id_workspace], map: "pgw_ws_idx")
  @@index([id_workspace, ativo_produto_gravity_workspace], map: "pgw_ws_ativo_idx")
  @@map("produto_gravity_workspace")
}

// ---------------------------------------------------------------------------
// PRODUCT (Catálogo Master da Plataforma)
// Representa cada produto disponível no portfólio Gravity.
// Gerenciado exclusivamente por gravity_admin via /api/admin/products.
// NÃO confundir com ProductConfig (que é a ativação por tenant).
// ---------------------------------------------------------------------------

enum StatusProdutoGravity {
  ATIVO
  SUSPENSO
  EM_BREVE
  LEGADO
  INATIVO
}

enum TipoCobrancaGravity {
  MENSAL
  POR_PROCESSO
  POR_DOCUMENTO
  POR_ESTIMATIVA
  POR_DI_DUIMP
  POR_DUE
  POR_PRODUTO
  POR_FLUXO
  POR_LPCO
}

enum ProdutoGravityLimiteUsuario {
  ILIMITADO
  LIMITADO
}

model ProdutoGravity {
  id_produto_gravity              String               @id @default(cuid())
  nome_produto_gravity            String
  slug_produto_gravity            String               @unique(map: "pg_slug_unq")
  descricao_produto_gravity       String
  status_produto_gravity          StatusProdutoGravity @default(ATIVO)
  data_lancamento_produto_gravity DateTime?

  // Setup
  possui_setup_produto_gravity Boolean  @default(false)
  preco_setup_produto_gravity  Decimal? @db.Decimal(15, 2)
  moeda_setup_produto_gravity  String   @default("BRL")

  // Billing
  tipo_cobranca_produto_gravity  TipoCobrancaGravity @default(MENSAL)
  preco_unitario_produto_gravity Decimal             @db.Decimal(15, 2)
  moeda_unitario_produto_gravity String              @default("BRL")
  preco_minimo_produto_gravity   Decimal             @default(0) @db.Decimal(15, 2)
  moeda_minimo_produto_gravity   String              @default("BRL")
  preco_total_produto_gravity    Decimal?            @db.Decimal(15, 2)
  moeda_total_produto_gravity    String              @default("BRL")

  // Users
  tipo_limite_usuario_produto_gravity ProdutoGravityLimiteUsuario @default(ILIMITADO)
  qtd_usuarios_base_produto_gravity   Int?
  preco_usuario_extra_produto_gravity Decimal?                    @db.Decimal(15, 2)
  moeda_usuario_extra_produto_gravity String                      @default("BRL")

  // Support
  horas_helpdesk_produto_gravity   Int      @default(0)
  preco_hora_extra_produto_gravity Decimal? @db.Decimal(15, 2)
  moeda_hora_extra_produto_gravity String   @default("BRL")

  // GABI On-Demand — quota padrão de tokens por tenant/mês
  quota_gabi_mensal_produto_gravity Int @default(0)

  // Metadata
  modulo_backend_produto_gravity String? // ex: "simula-custo", "bid-frete"
  publico_alvo_produto_gravity   String?

  // Timestamps
  data_criacao_produto_gravity     DateTime  @default(now())
  data_atualizacao_produto_gravity DateTime  @updatedAt
  data_remocao_produto_gravity     DateTime? // soft-delete — preserva negociações especiais

  // Relations
  faixas_preco_produto_gravity ProdutoGravityFaixaPreco[]
  negociacoes_produto_gravity  ProdutoGravityNegociacaoEspecial[]
  ativacoes_produto_gravity    ProdutoGravityWorkspace[]
  assinaturas_produto_gravity  ProdutoGravityAssinatura[]
  itens_fatura_produto_gravity ProdutoGravityFaturaItem[]

  @@index([status_produto_gravity], map: "pg_status_idx")
  @@index([slug_produto_gravity], map: "pg_slug_idx")
  @@index([data_remocao_produto_gravity], map: "pg_remocao_idx")
  @@map("produto_gravity")
}

// ---------------------------------------------------------------------------
// PRICE TIER (Faixas de Preço por Volume)
// Precificação escalonada — preço varia conforme quantidade.
// ---------------------------------------------------------------------------

model ProdutoGravityFaixaPreco {
  id_faixa_preco_produto_gravity        String  @id @default(cuid())
  id_produto_gravity_faixa_preco        String
  faixa_de_faixa_preco_produto_gravity  Int
  faixa_ate_faixa_preco_produto_gravity Int?
  preco_faixa_preco_produto_gravity     Decimal @db.Decimal(15, 2)
  moeda_faixa_preco_produto_gravity     String  @default("BRL")

  // Timestamps
  data_criacao_faixa_preco_produto_gravity DateTime @default(now())

  // Relations
  produto ProdutoGravity @relation(fields: [id_produto_gravity_faixa_preco], references: [id_produto_gravity], onDelete: Cascade, map: "faixa_preco_produto_gravity_produto_id_fkey")

  @@index([id_produto_gravity_faixa_preco], map: "faixa_preco_produto_gravity_produto_id_idx")
  @@index([id_produto_gravity_faixa_preco, faixa_de_faixa_preco_produto_gravity], map: "faixa_preco_produto_gravity_produto_id_faixa_de_idx")
  @@map("faixa_preco_produto_gravity")
}

// ---------------------------------------------------------------------------
// SPECIAL NEGOTIATION (Negociação Especial por Organizacao)
// Condições comerciais personalizadas para tenants específicos.
// ---------------------------------------------------------------------------

model ProdutoGravityNegociacaoEspecial {
  id_negociacao_especial_preco_produto_gravity               String    @id @default(cuid())
  id_produto_gravity                                         String
  id_organizacao                                             String
  nome_organizacao_negociacao_especial_preco_produto_gravity String
  acordo_negociacao_especial_preco_produto_gravity           String // Descrição: "Desconto 20%", "Preço fixo R$ 5/proc"
  data_inicio_negociacao_especial_preco_produto_gravity      DateTime?
  data_fim_negociacao_especial_preco_produto_gravity         DateTime?
  ilimitado_negociacao_especial_preco_produto_gravity        Boolean   @default(false)

  // Timestamps
  data_criacao_negociacao_especial_preco_produto_gravity     DateTime @default(now())
  data_atualizacao_negociacao_especial_preco_produto_gravity DateTime @updatedAt

  // Relations
  produto ProdutoGravity @relation(fields: [id_produto_gravity], references: [id_produto_gravity], onDelete: Cascade, map: "negociacao_especial_preco_produto_gravity_fkey")

  @@index([id_produto_gravity], map: "negociacao_especial_preco_produto_gravity_idx")
  @@index([id_organizacao], map: "negociacao_especial_preco_produto_gravity_organizacao_idx")
  @@map("negociacao_especial_preco_produto_gravity")
}

// ---------------------------------------------------------------------------
// DEPLOY LOG (Histórico de Deploys da Plataforma Gravity)
// Registro manual de cada deploy feito pelo time (hotfix, migration, release).
// Global — não é tenant-scoped. Apenas gravity_admin grava/lê.
// ---------------------------------------------------------------------------

enum DeployAmbiente {
  DESENVOLVIMENTO
  HOMOLOGACAO
  PRODUCAO
  TODOS
}

enum DeployStatus {
  SUCESSO
  FALHOU
  REVERTIDO
  EM_ANDAMENTO
}

model Deploy {
  id_deploy            String         @id @default(cuid())
  numero_deploy        Int            @default(autoincrement())
  area_deploy          String // ex: 'configurador', 'pedido', 'bid-frete', 'nucleo-global', 'devops'
  versao_deploy        String // semver (v1.2.3) ou git sha (8f3a1c2)
  descricao_deploy     String // resumo das alterações (changelog curto)
  ambiente_deploy      DeployAmbiente @default(PRODUCAO)
  status_deploy        DeployStatus   @default(SUCESSO)
  quem_deploy          String // nome legível do responsável (snapshot no momento do deploy)
  id_usuario_deploy    String? // FK opcional para Usuario (pode ser null se deploy veio de CI)
  data_execucao_deploy DateTime       @default(now())

  data_criacao_deploy DateTime @default(now())

  @@index([data_execucao_deploy])
  @@index([area_deploy])
  @@index([ambiente_deploy])
  @@index([status_deploy])
  @@index([area_deploy, data_execucao_deploy])
  @@map("deploy")
}

// ---------------------------------------------------------------------------
// SUPPLIER TENANT ACCESS
// Fornecedor cross-tenant — pode prestar serviços para múltiplos tenants.
// clerk_user_id único no Clerk, múltiplos vínculos aqui.
// ---------------------------------------------------------------------------

model OrganizacaoFornecedor {
  id_fornecedor_organizacao             String @id @default(cuid())
  id_clerk_usuario                      String
  id_organizacao_fornecedor_organizacao String
  status_fornecedor_organizacao         String @default("active")

  // Timestamps
  data_criacao_fornecedor_organizacao     DateTime @default(now())
  data_atualizacao_fornecedor_organizacao DateTime @updatedAt

  // Unique: um clerk_user_id não pode ter dois acessos ao mesmo tenant
  @@unique([id_clerk_usuario, id_organizacao_fornecedor_organizacao], map: "fornecedor_organizacao_clerk_usuario_id_organizacao_id_key")
  // Índices
  @@index([id_organizacao_fornecedor_organizacao], map: "fornecedor_organizacao_id_idx")
  @@index([id_clerk_usuario], map: "fornecedor_organizacao_clerk_usuario_id_idx")
  @@index([id_organizacao_fornecedor_organizacao, id_clerk_usuario], map: "fornecedor_organizacao_id_clerk_usuario_id_idx")
  @@map("fornecedor_organizacao")
}

// ---------------------------------------------------------------------------
// SECURITY EVENT
// Eventos de segurança registrados pelo securityAuditLogger.
// Alimenta o painel /admin/seguranca em tempo real.
// ---------------------------------------------------------------------------

model Seguranca {
  id_seguranca              String    @id @default(cuid())
  id_organizacao            String
  id_ator_seguranca         String
  tipo_ator_seguranca       String // USER | SYSTEM | GABI_IA | ADMIN
  acao_seguranca            String // AUTH_FAILURE, CROSS_TENANT_ATTEMPT, ROLE_CHANGED, etc.
  severidade_seguranca      String // CRITICAL | WARNING | INFO
  status_seguranca          String    @default("DETECTED") // BLOCKED | ALLOWED | DETECTED
  descricao_seguranca       String?
  ip_seguranca              String?
  endpoint_seguranca        String?
  id_usuario                String?
  id_workspace              String?
  id_produto_gravity        String?
  id_correlacao_seguranca   String?
  id_clerk_sessao           String?
  usuario_agente_seguranca  String?
  geo_pais_seguranca        String? // ISO-2
  payload_request_seguranca Json?
  acoes_tomadas_seguranca   Json?
  resolvido_por_seguranca   String? // clerk_user_id de quem fechou o incidente
  data_resolucao_seguranca  DateTime?
  metadata_seguranca        Json?     @default("{}")
  data_criacao_seguranca    DateTime  @default(now())

  @@index([data_criacao_seguranca], map: "seguranca_data_criacao_idx")
  @@index([severidade_seguranca], map: "seguranca_severidade_idx")
  @@index([acao_seguranca], map: "seguranca_acao_idx")
  @@index([id_organizacao, data_criacao_seguranca], map: "seguranca_id_organizacao_data_criacao_idx")
  @@index([severidade_seguranca, data_criacao_seguranca], map: "seguranca_severidade_data_criacao_idx")
  @@index([id_workspace], map: "seguranca_id_workspace_idx")
  @@index([id_usuario], map: "seguranca_id_usuario_idx")
  @@index([data_resolucao_seguranca], map: "seguranca_data_resolucao_idx")
  @@map("seguranca")
}

// ---------------------------------------------------------------------------
// RATE LIMIT METRIC
// Metricas agregadas do rate limiter para monitoramento no painel.
// ---------------------------------------------------------------------------

model Requisicoes {
  id_requisicoes                String   @id @default(cuid())
  chave_requisicoes             String // organizacao:ip combo
  id_organizacao                String?
  ip_requisicoes                String?
  endpoint_requisicoes          String
  metodo_requisicoes            String // GET | POST | PUT | DELETE | PATCH
  status_code_requisicoes       Int // 200 | 429 | 500 ...
  contagem_requisicoes          Int
  limite_maximo_requisicoes     Int
  bloqueado_requisicoes         Boolean  @default(false)
  razao_bloqueio_requisicoes    String? // ex: "rate limit exceeded", "ip blacklisted"
  user_agent_requisicoes        String?
  id_usuario                    String? // quando autenticado
  tempo_resposta_ms_requisicoes Int? // latência em milissegundos
  inicio_janela_requisicoes     DateTime
  data_criacao_requisicoes      DateTime @default(now())

  @@index([id_organizacao], map: "requisicoes_id_organizacao_idx")
  @@index([data_criacao_requisicoes], map: "requisicoes_data_criacao_idx")
  @@index([bloqueado_requisicoes, data_criacao_requisicoes], map: "requisicoes_bloqueado_data_criacao_idx")
  @@index([endpoint_requisicoes, data_criacao_requisicoes], map: "requisicoes_endpoint_data_criacao_idx")
  @@index([id_usuario], map: "requisicoes_id_usuario_idx")
  @@map("requisicoes")
}

// ---------------------------------------------------------------------------
// SERVICE HEALTH
// Snapshot do ultimo health check de cada servico.
// ---------------------------------------------------------------------------

model ServicoGravity {
  id_servico_gravity               String   @id @default(cuid())
  nome_servico_gravity             String   @unique(map: "servico_gravity_service_key") // ex: "configurador", "bid-frete"
  url_servico_gravity              String // health check URL
  status_servico_gravity           String   @default("UNKNOWN") // OK | DEGRADED | DOWN | UNKNOWN
  latencia_ms_servico_gravity      Int?
  ultimo_erro_servico_gravity      String?
  data_verificacao_servico_gravity DateTime @default(now())

  // Auditoria estendida + workflow de incidente
  versao_atual_servico_gravity        String?
  ambiente_servico_gravity            String? // dev | staging | prod
  tipo_servico_gravity                String? // api | worker | cron | db | external
  falhas_consecutivas_servico_gravity Int       @default(0)
  data_ultima_falha_servico_gravity   DateTime?
  data_recuperacao_servico_gravity    DateTime?
  tempo_uptime_pct_servico_gravity    Decimal?  @db.Decimal(5, 2)
  regiao_servico_gravity              String?
  responsavel_servico_gravity         String? // squad/time

  // Timestamps
  data_criacao_servico_gravity     DateTime @default(now())
  data_atualizacao_servico_gravity DateTime @updatedAt

  @@index([status_servico_gravity], map: "servico_gravity_status_idx")
  @@index([data_verificacao_servico_gravity], map: "servico_gravity_verificado_em_idx")
  @@index([ambiente_servico_gravity, status_servico_gravity], map: "servico_gravity_ambiente_status_idx")
  @@index([falhas_consecutivas_servico_gravity], map: "servico_gravity_falhas_idx")
  @@index([responsavel_servico_gravity], map: "servico_gravity_responsavel_idx")
  @@index([tipo_servico_gravity], map: "servico_gravity_tipo_idx")
  @@map("servico_gravity")
}

// ---------------------------------------------------------------------------
// TAXA CAMBIO
// Cotações PTAX oficiais do BCB armazenadas para consulta centralizada.
// Tabela global — sem id_organizacao (rates são públicas, iguais para todos).
// Alimentada via POST /api/v1/taxa-cambio/sync (busca do bid-cambio/BCB).
// ---------------------------------------------------------------------------

model Cambio {
  id_cambio           String   @id @default(cuid())
  moeda_cambio        String // USD, EUR, GBP, CHF, CNY, JPY
  compra_cambio       Decimal  @db.Decimal(15, 6)
  venda_cambio        Decimal  @db.Decimal(15, 6)
  data_cotacao_cambio DateTime // data da cotação (dia, meia-noite UTC)
  hora_cotacao_cambio String? // ex: "13:02"
  boletim_cambio      String   @default("Fechamento") // "1º Boletim" | "2º Boletim" | "3º Boletim" | "Fechamento"
  fonte_cambio        String   @default("BCB/PTAX")
  data_criacao_cambio DateTime @default(now())

  // Garante 1 registro por moeda × dia × boletim (upsert idempotente)
  @@unique([moeda_cambio, data_cotacao_cambio, boletim_cambio], map: "cmb_moeda_data_boletim_unq")
  @@index([moeda_cambio], map: "cmb_moeda_idx")
  @@index([moeda_cambio, data_cotacao_cambio], map: "cmb_moeda_data_idx")
  @@index([data_cotacao_cambio], map: "cmb_data_idx")
  @@index([data_criacao_cambio], map: "cmb_criacao_idx")
  @@map("cambio")
}

// ---------------------------------------------------------------------------
// SISTEMA DE TESTES — Testes, TestSchedule, TestPlan
// ---------------------------------------------------------------------------
// Tabelas que suportam o sistema de testes automatizado do Admin/Testes.
// Documentação completa em documentos-tecnicos/testes/tecnico/.
// Convenção de IDs: TST-{TIPO}-{ESCOPO}-{NNNNNN}

model Teste {
  id_teste               String   @id @default(cuid())
  id_organizacao         String   @default("platform") // sempre "platform" — logs globais
  tipo_teste             String // UNI | CON | FUN | CRO | E2E | PEN
  escopo_teste           String // LOGIN | CONFIG | ADMIN | HUB | CORE | MARKET | TENANT | DBASE | PEDIDO | NFIMP | LPCO | BIDFRT | BIDCAM | SIMCUS | FINCOM | PROCSO
  sublocal_teste         String?
  modulo_teste           String
  nome_teste             String
  id_plano_teste         String? // TST-E2E-CONFIG-000001 (quando vinculado a um plano)
  id_agendamento_teste   String? // FK opcional para agendamento_teste
  resultado_teste        String // APROVADO | REPROVADO | ERRO
  duracao_teste          String
  log_erro_teste         String?  @db.Text
  analise_ia_teste       Json? // AiAnalysis schema do gemini-test-analyzer
  screenshot_teste       String? // path do PNG capturado pela fixture
  ambiente_teste         String   @default("Local") // Local | Staging | Producao
  id_execucao_teste      String? // agrupa logs do mesmo run
  disparado_por_teste    String? // userId que disparou (manual) ou "cron" (automático)
  gatilho_teste          String? // tipo de gatilho: manual | cron | ci | post_deploy
  data_criacao_teste     DateTime @default(now())
  data_atualizacao_teste DateTime @updatedAt

  // Relação opcional para agendamento (set null se agendamento for excluído)
  agendamento TesteAgendamento? @relation(fields: [id_agendamento_teste], references: [id_agendamento_teste], onDelete: SetNull, map: "teste_agendamento_fkey")

  @@index([id_organizacao], map: "tst_org_idx")
  @@index([data_criacao_teste], map: "tst_criacao_idx")
  @@index([tipo_teste, escopo_teste], map: "tst_tipo_escopo_idx")
  @@index([resultado_teste], map: "tst_resultado_idx")
  @@index([id_execucao_teste], map: "tst_execucao_idx")
  @@index([id_plano_teste], map: "tst_plano_idx")
  @@index([id_agendamento_teste], map: "tst_agendamento_idx")
  @@map("teste")
}

model TesteAgendamento {
  id_agendamento_teste               String    @id @default(cuid())
  id_organizacao_agendamento_teste   String    @default("platform")
  ativo_agendamento_teste            Boolean   @default(false)
  frequencia_agendamento_teste       String    @default("Manual") // Manual | Diario | Semanal
  hora_agendamento_teste             Int       @default(0) // 0-23
  minuto_agendamento_teste           Int       @default(0) // 0-59
  tipos_agendamento_teste            Json // { uni: bool, con: bool, fun: bool, cro: bool, e2e: bool, pen: bool }
  escopos_agendamento_teste          String[] // ['CONFIG','PEDIDO','ADMIN',...]
  ambiente_agendamento_teste         String    @default("Local") // Local | Staging | Producao
  alertas_agendamento_teste          Json      @default("[]") // [{ nome, contato, condicao, canal }]
  ultima_execucao_agendamento_teste  DateTime?
  proxima_execucao_agendamento_teste DateTime?
  data_criacao_agendamento_teste     DateTime  @default(now())
  data_atualizacao_agendamento_teste DateTime  @updatedAt

  // Relações
  testes Teste[]

  @@index([id_organizacao_agendamento_teste], map: "agt_org_idx")
  @@index([ativo_agendamento_teste], map: "agt_ativo_idx")
  @@index([proxima_execucao_agendamento_teste], map: "agt_proxima_idx")
  @@map("agendamento_teste")
}

model TestePlano {
  id_plano_teste                 String    @id // TST-E2E-CONFIG-000001
  id_organizacao_plano_teste     String    @default("platform")
  nome_plano_teste               String
  versao_plano_teste             String    @default("1.0")
  tipo_plano_teste               String // UNI | CON | FUN | CRO | E2E | PEN
  escopo_plano_teste             String // LOGIN | CONFIG | ...
  sublocal_plano_teste           String
  tela_plano_teste               String
  rota_plano_teste               String
  criticidade_plano_teste        String    @default("media") // baixa | media | alta | critica
  ambientes_plano_teste          String[]
  caminho_componente_plano_teste String
  caminho_spec_plano_teste       String?
  caminho_mapeamento_plano_teste String
  cobertura_pct_plano_teste      Int       @default(0)
  passos_total_plano_teste       Int       @default(0)
  resumo_executivo_plano_teste   String    @db.Text
  plano_completo_plano_teste     Json // o JSON inteiro do plano (formato do agente-plano-teste)
  status_plano_teste             String    @default("pendente_validacao") // pendente_validacao | aprovado | obsoleto
  ultima_execucao_plano_teste    DateTime?
  ultimo_resultado_plano_teste   String? // APROVADO | REPROVADO | ERRO | NAO_EXECUTADO
  data_criacao_plano_teste       DateTime  @default(now())
  data_atualizacao_plano_teste   DateTime  @updatedAt

  @@index([id_organizacao_plano_teste], map: "plt_org_idx")
  @@index([tipo_plano_teste, escopo_plano_teste], map: "plt_tipo_escopo_idx")
  @@index([status_plano_teste], map: "plt_status_idx")
  @@index([sublocal_plano_teste], map: "plt_sublocal_idx")
  @@map("plano_teste")
}

// ---------------------------------------------------------------------------
// FATURA PRODUTO GRAVITY (fatura de serviços internos Gravity)
// ---------------------------------------------------------------------------

enum StatusFaturaProdutoGravity {
  RASCUNHO
  EMITIDA
  ENVIADA
  PAGA
  EM_ATRASO
  ANULADA
  INCOBRAVEL
}

model ProdutoGravityFatura {
  id_fatura_produto_gravity                String                     @id @default(cuid())
  id_organizacao                           String
  numero_fatura_produto_gravity            String
  status_fatura_produto_gravity            StatusFaturaProdutoGravity @default(RASCUNHO)
  nome_organizacao_fatura_produto_gravity  String
  email_organizacao_fatura_produto_gravity String?
  valor_total_fatura_produto_gravity       Decimal                    @db.Decimal(18, 2)
  moeda_fatura_produto_gravity             String                     @default("brl")
  competencia_fatura_produto_gravity       String?
  data_fatura_produto_gravity              DateTime                   @default(now())
  data_criacao_fatura_produto_gravity      DateTime                   @default(now())
  data_atualizacao_fatura_produto_gravity  DateTime                   @updatedAt

  // Relações
  itens_fatura_produto_gravity      ProdutoGravityFaturaItem[]
  documentos_fatura_produto_gravity ProdutoGravityFaturaDocumento[]
  organizacao                       Organizacao                     @relation(fields: [id_organizacao], references: [id_organizacao], onDelete: Cascade)

  @@index([id_organizacao], map: "fpg_org_idx")
  @@index([id_organizacao, status_fatura_produto_gravity], map: "fpg_org_status_idx")
  @@index([id_organizacao, data_fatura_produto_gravity], map: "fpg_org_data_idx")
  @@map("fatura_produto_gravity")
}

// ---------------------------------------------------------------------------
// FATURA PRODUTO GRAVITY ITEM (composição de uma fatura — line items)
// ---------------------------------------------------------------------------

model ProdutoGravityFaturaItem {
  id_fatura_item_produto_gravity             String  @id @default(cuid())
  id_organizacao                             String
  id_fatura_produto_gravity                  String
  id_produto_gravity                         String?
  descricao_fatura_item_produto_gravity      String
  quantidade_fatura_item_produto_gravity     Decimal @default(1) @db.Decimal(18, 4)
  valor_unitario_fatura_item_produto_gravity Decimal @db.Decimal(18, 2)
  valor_total_fatura_item_produto_gravity    Decimal @db.Decimal(18, 2)
  moeda_fatura_item_produto_gravity          String  @default("brl")

  data_criacao_fatura_item_produto_gravity     DateTime @default(now())
  data_atualizacao_fatura_item_produto_gravity DateTime @updatedAt

  // Relações
  fatura      ProdutoGravityFatura @relation(fields: [id_fatura_produto_gravity], references: [id_fatura_produto_gravity], onDelete: Cascade)
  produto     ProdutoGravity?      @relation(fields: [id_produto_gravity], references: [id_produto_gravity], onDelete: SetNull)
  organizacao Organizacao          @relation(fields: [id_organizacao], references: [id_organizacao], onDelete: Cascade)

  @@index([id_organizacao], map: "fipg_org_idx")
  @@index([id_organizacao, id_fatura_produto_gravity], map: "fipg_org_fatura_idx")
  @@index([id_organizacao, id_produto_gravity], map: "fipg_org_produto_idx")
  @@map("fatura_item_produto_gravity")
}

// ---------------------------------------------------------------------------
// FATURA PRODUTO GRAVITY DOCUMENTO (anexos: boleto, NF-e, recibo, PDF, outro)
// Soft-delete via data_exclusao_*. Storage abstraído: url_documento_* guarda
// chave (S3-key ou caminho relativo no volume Railway).
// ---------------------------------------------------------------------------

enum TipoDocumentoFaturaProdutoGravity {
  BOLETO
  NFE
  RECIBO
  PDF_GENERICO
  OUTRO
}

model ProdutoGravityFaturaDocumento {
  id_documento_fatura_produto_gravity                String                            @id @default(cuid())
  id_organizacao                                     String
  id_fatura_produto_gravity                          String
  tipo_documento_fatura_produto_gravity              TipoDocumentoFaturaProdutoGravity
  nome_documento_fatura_produto_gravity              String
  url_documento_fatura_produto_gravity               String
  tamanho_documento_fatura_produto_gravity           Int?
  mime_documento_fatura_produto_gravity              String?
  id_usuario_anexou_documento_fatura_produto_gravity String?

  data_criacao_documento_fatura_produto_gravity     DateTime  @default(now())
  data_atualizacao_documento_fatura_produto_gravity DateTime  @updatedAt
  data_exclusao_documento_fatura_produto_gravity    DateTime?

  // Relações
  fatura      ProdutoGravityFatura @relation(fields: [id_fatura_produto_gravity], references: [id_fatura_produto_gravity], onDelete: Cascade)
  organizacao Organizacao          @relation(fields: [id_organizacao], references: [id_organizacao], onDelete: Cascade)

  @@index([id_organizacao], map: "fdpg_org_idx")
  @@index([id_organizacao, id_fatura_produto_gravity], map: "fdpg_org_fatura_idx")
  @@index([id_organizacao, id_usuario_anexou_documento_fatura_produto_gravity], map: "fdpg_org_usuario_idx")
  @@map("fatura_documento_produto_gravity")
}

// ---------------------------------------------------------------------------
// METRICAS LLM (dados agregados de uso de LLM — qualquer provedor)
// ---------------------------------------------------------------------------

model LLMMetricas {
  id_metricas_llm                         String   @id @default(cuid())
  nome_metricas_llm                       String[]
  data_analise_metricas_llm               DateTime
  total_analise_metricas_llm              Int      @default(0)
  total_token_metricas_llm                Int      @default(0)
  custo_metricas_llm                      Decimal  @db.Decimal(10, 4)
  latencia_metricas_llm                   Int      @default(0)
  confianca_alta_metricas_llm             Int      @default(0)
  confianca_media_metricas_llm            Int      @default(0)
  confianca_baixa_metricas_llm            Int      @default(0)
  quantidade_codigo_validado_metricas_llm Int      @default(0)
  data_criacao_metricas_llm               DateTime @default(now())

  @@index([data_analise_metricas_llm], map: "metricas_llm_data_analise_idx")
  @@map("metricas_llm")
}
