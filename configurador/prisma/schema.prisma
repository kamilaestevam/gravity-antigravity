// configurador/prisma/schema.prisma
// GERADO PELO AGENTE 0B — BANCO DE DADOS
// Este arquivo é gerenciado diretamente pelo Configurador.
// NÃO usar como base para fragments de tenant.

generator client {
  provider      = "prisma-client-js"
  output        = "../generated"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("CONFIGURADOR_DATABASE_URL")
}

// ---------------------------------------------------------------------------
// ENUMS
// ---------------------------------------------------------------------------

enum OrganizacaoStatus {
  ATIVO
  SUSPENSO
  CANCELADO
  CONFIGURACAO_PENDENTE
}

enum StatusAssinaturaProdutoGravity {
  ATIVA
  VENCIDA
  CANCELADA
  EM_TESTE
  INCOMPLETA
}

// Roles canônicos do sistema — alinhados com skill antigravity-permissoes
enum UsuarioTipo {
  SUPER_ADMIN // Equipe Gravity — acesso total irrestrito
  ADMIN // Equipe Gravity — acesso com permissões explícitas
  MASTER // Cliente — acesso total na organização
  PADRAO // Cliente — acesso conforme permissões do Master
  FORNECEDOR // Fornecedor — permissões explícitas obrigatórias (cross-tenant)
}

enum EmpresaStatus {
  ATIVO
  INATIVO
}

enum TipoUsuarioEmpresa {
  MASTER // Acesso implícito a todos os workspaces da organização
  PADRAO // Acesso apenas aos workspaces onde foi habilitado
  FORNECEDOR // Acesso externo — permissões granulares obrigatórias
}

enum APITokenServico {
  SERVICO
  WEBHOOK
  CRON
}

// ---------------------------------------------------------------------------
// TENANT
// Cada empresa que assina a plataforma Gravity é um Organizacao.
// tenant_id = id do próprio registro (self-referencing por convenção).
// ---------------------------------------------------------------------------

model Organizacao {
  id_organizacao     String       @id @default(cuid())
  nome_organizacao         String
  subdominio_organizacao   String       @unique
  status_organizacao       OrganizacaoStatus @default(CONFIGURACAO_PENDENTE)
  clerk_org_id       String?      @unique
  stripe_customer_id String?      @unique
  suid_empresa_organizacao String?      @unique

  // Dados cadastrais da organização
  cnpj_organizacao         String?
  estado_organizacao       String?
  cidade_organizacao       String?
  segmento_organizacao     String?
  tipo_empresa_organizacao String?

  // Metadata
  data_criacao_organizacao     DateTime @default(now())
  data_atualizacao_organizacao DateTime @updatedAt

  // Relações
  users_organizacao            Usuario[]
  subscriptions_organizacao    AssinaturaProdutoGravity[]
  user_permissions_organizacao UsuarioPermissao[]
  companies_organizacao        Empresa[]
  product_configs_organizacao  ConfiguracaoProduto[]
  ProdutoGravityWorkspace      ProdutoGravityWorkspace[]

  @@index([status_organizacao])
  @@index([subdominio_organizacao])
  @@map("organizacao")
}

// ---------------------------------------------------------------------------
// USER
// Usuário vinculado a um tenant. Autenticado via Clerk.
// tenant_id é obrigatório — nunca nullable.
// ---------------------------------------------------------------------------

model Usuario {
  id_usuario             String   @id @default(cuid())
  id_organizacao_usuario String
  clerk_user_id          String   @unique
  email_usuario          String
  nome_usuario           String
  tipo_usuario           UsuarioTipo @default(PADRAO)

  // Workspace preferido — skip pós-login para Master/Standard
  // Supplier ignora este campo (fornecedor cross-tenant sempre vê tela de seleção)
  preferred_company_id String?

  // Timestamps
  data_criacao_usuario DateTime @default(now())
  updated_at           DateTime @updatedAt

  // Relações
  tenant            Organizacao        @relation(fields: [id_organizacao_usuario], references: [id_organizacao], onDelete: Cascade)
  preferred_company Empresa?           @relation("UserPreferredCompany", fields: [preferred_company_id], references: [id_workspace], onDelete: SetNull)
  user_permissions  UsuarioPermissao[]
  memberships       UsuarioWorkspace[]

  // Email único por organização
  @@unique([id_organizacao_usuario, email_usuario])
  // Índices obrigatórios (id_organizacao_usuario base + compostos)
  @@index([id_organizacao_usuario])
  @@index([id_organizacao_usuario, data_criacao_usuario])
  @@index([id_organizacao_usuario, tipo_usuario])
  @@index([preferred_company_id])
  @@map("usuario")
}

// ---------------------------------------------------------------------------
// SUBSCRIPTION
// Uma assinatura por tenant. Gerenciada via Stripe.
// tenant_id é obrigatório — nunca nullable.
// ---------------------------------------------------------------------------

model AssinaturaProdutoGravity {
  id_assinatura_produto_gravity             String                         @id @default(cuid())
  id_organizacao_assinatura_produto_gravity String
  status_assinatura_produto_gravity         StatusAssinaturaProdutoGravity @default(EM_TESTE)

  stripe_subscription_id String? @unique
  stripe_price_id        String?

  data_fim_teste_assinatura_produto_gravity     DateTime?
  data_inicio_periodo_assinatura_produto_gravity DateTime?
  data_fim_periodo_assinatura_produto_gravity   DateTime?
  data_cancelamento_assinatura_produto_gravity  DateTime?

  // Timestamps
  data_criacao_assinatura_produto_gravity     DateTime @default(now())
  data_atualizacao_assinatura_produto_gravity DateTime @updatedAt

  // Relações
  tenant Organizacao @relation(fields: [id_organizacao_assinatura_produto_gravity], references: [id_organizacao], onDelete: Cascade)

  // Índices obrigatórios — `map` explícito porque os nomes longos colidem após truncamento PG (63 chars)
  @@index([id_organizacao_assinatura_produto_gravity], map: "apg_org_idx")
  @@index([id_organizacao_assinatura_produto_gravity, data_criacao_assinatura_produto_gravity], map: "apg_org_criacao_idx")
  @@index([id_organizacao_assinatura_produto_gravity, status_assinatura_produto_gravity], map: "apg_org_status_idx")
  @@map("assinatura_produto_gravity")
}

// ---------------------------------------------------------------------------
// USER PERMISSION (Cadeia 2 — Permissões Granulares por Produto)
// Permissão granular de um usuário em um produto/workspace específico.
// Ex: permission = 'email:write', 'simulacusto:read'
// Alinhado com skill antigravity-permissoes.
// ---------------------------------------------------------------------------

model UsuarioPermissao {
  id_usuario_permissao             String @id @default(cuid())
  id_organizacao_usuario_permissao String
  id_workspace_usuario_permissao   String // workspace onde se aplica (obrigatório)
  id_usuario_usuario_permissao     String
  id_produto_usuario_permissao     String // produto ao qual a permissão pertence
  permissao_usuario_permissao      String // ex: 'email:write', 'simulacusto:read', 'atividades:read'
  concedido_por_usuario_permissao  String // clerk_id do Master que concedeu a permissão

  // Timestamps
  data_criacao_usuario_permissao     DateTime @default(now())
  data_atualizacao_usuario_permissao DateTime @updatedAt

  // Relações
  tenant Organizacao @relation(fields: [id_organizacao_usuario_permissao], references: [id_organizacao], onDelete: Cascade)
  user   Usuario     @relation(fields: [id_usuario_usuario_permissao], references: [id_usuario], onDelete: Cascade)

  // Um usuário não pode ter permissão duplicada no mesmo produto/workspace
  @@unique([id_organizacao_usuario_permissao, id_workspace_usuario_permissao, id_usuario_usuario_permissao, id_produto_usuario_permissao, permissao_usuario_permissao])
  // Índices obrigatórios
  @@index([id_organizacao_usuario_permissao])
  @@index([id_organizacao_usuario_permissao, id_usuario_usuario_permissao])
  @@index([id_organizacao_usuario_permissao, id_workspace_usuario_permissao, id_usuario_usuario_permissao])
  @@map("usuario_permissao")
}

// ---------------------------------------------------------------------------
// GRAVITY ADMIN PERMISSION (Cadeia 1 — Permissões de Edição para Admin Gravity)
// Controla o que um Admin interno da Gravity pode editar.
// Super Admin não usa esta tabela — tem acesso irrestrito.
// ---------------------------------------------------------------------------

model PermissaoAdminGravity {
  id_permissao_admin_gravity        String @id @default(cuid())
  id_admin_permissao_admin_gravity  String // clerk_id do Admin Gravity
  recurso_permissao_admin_gravity   String // ex: 'tenants', 'billing', 'deploy', 'usuarios'
  acao_permissao_admin_gravity      String // 'READ' | 'WRITE' | 'DELETE' | 'MANAGE'
  concedido_por_permissao_admin_gravity String // clerk_id do Super Admin que concedeu

  // Timestamps
  data_criacao_permissao_admin_gravity     DateTime @default(now())
  data_atualizacao_permissao_admin_gravity DateTime @updatedAt

  // Admin não pode ter permissão duplicada no mesmo recurso+ação
  @@unique([id_admin_permissao_admin_gravity, recurso_permissao_admin_gravity, acao_permissao_admin_gravity], map: "pag_admin_recurso_acao_unq")
  // Índices obrigatórios
  @@index([id_admin_permissao_admin_gravity], map: "pag_admin_idx")
  @@index([id_admin_permissao_admin_gravity, recurso_permissao_admin_gravity], map: "pag_admin_recurso_idx")
  @@map("permissao_admin_gravity")
}

// ---------------------------------------------------------------------------
// COMPANY
// Empresa filha (unidade de negócio) dentro de um tenant.
// Um tenant pode ter até 50 empresas filhas.
// ---------------------------------------------------------------------------

model Empresa {
  id_workspace             String        @id @default(cuid())
  id_organizacao_workspace String
  nome_workspace           String
  subdominio_workspace     String?       @unique
  cnpj_workspace           String?
  status_workspace         EmpresaStatus @default(ATIVO)

  // Timestamps
  data_criacao_workspace DateTime @default(now())
  updated_at             DateTime @updatedAt

  // Relações
  tenant             Organizacao               @relation(fields: [id_organizacao_workspace], references: [id_organizacao], onDelete: Cascade)
  memberships        UsuarioWorkspace[]
  company_products   ProdutoGravityWorkspace[]
  preferred_by_users Usuario[]                 @relation("UserPreferredCompany")

  // Índices obrigatórios
  @@index([id_organizacao_workspace])
  @@index([id_organizacao_workspace, status_workspace])
  @@index([id_organizacao_workspace, data_criacao_workspace])
  @@map("workspace")
}

// ---------------------------------------------------------------------------
// USER MEMBERSHIP
// Habilitação de um usuário do tenant em uma empresa filha.
// Define o papel (Master/Standard/Supplier) e o acesso a produtos.
// ---------------------------------------------------------------------------

model UsuarioWorkspace {
  id         String             @id @default(cuid())
  tenant_id  String
  user_id    String
  company_id String
  role       TipoUsuarioEmpresa @default(PADRAO)
  is_active  Boolean            @default(true)

  // Timestamps
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relações
  user    Usuario   @relation(fields: [user_id], references: [id_usuario], onDelete: Cascade)
  company Empresa @relation(fields: [company_id], references: [id_workspace], onDelete: Cascade)

  // Usuário não pode ter duplicata de habilitação na mesma empresa
  @@unique([tenant_id, user_id, company_id])
  // Índices obrigatórios
  @@index([tenant_id])
  @@index([tenant_id, user_id])
  @@index([tenant_id, company_id])
  @@map("usuario_workspace")
}

// ---------------------------------------------------------------------------
// PRODUCT CONFIG
// Configurações de produto por tenant. Persistência do PRODUCT_CONFIG.
// product_key identifica o produto (ex: "simulacusto", "nf-importacao")
// ---------------------------------------------------------------------------

model ConfiguracaoProduto {
  id          String  @id @default(cuid())
  tenant_id   String
  product_key String
  config      Json    @default("{}")
  is_active   Boolean @default(true)

  // Timestamps
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relações
  tenant Organizacao @relation(fields: [tenant_id], references: [id_organizacao], onDelete: Cascade)

  // Apenas uma config por produto por tenant
  @@unique([tenant_id, product_key])
  // Índices obrigatórios
  @@index([tenant_id])
  @@index([tenant_id, product_key])
  @@index([tenant_id, is_active])
  @@map("config_produto_gravity")
}

// ---------------------------------------------------------------------------
// COMPANY PRODUCT (Cadeia 1.5 — Ativação por Workspace)
// Habilita um produto que o Organizacao já possui para um Workspace específico.
// ---------------------------------------------------------------------------

model ProdutoGravityWorkspace {
  id          String  @id @default(cuid())
  tenant_id   String
  company_id  String
  product_key String // ex: "simulacusto", "gestao-atividades"
  is_active   Boolean @default(true)

  // Timestamps
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relações
  tenant  Organizacao @relation(fields: [tenant_id], references: [id_organizacao], onDelete: Cascade)
  company Empresa     @relation(fields: [company_id], references: [id_workspace], onDelete: Cascade)

  // Apenas uma ativação por produto por workspace
  @@unique([company_id, product_key])
  // Índices obrigatórios
  @@index([tenant_id])
  @@index([company_id])
  @@index([company_id, is_active])
  @@map("produto_gravity_workspace")
}

// ---------------------------------------------------------------------------
// PRODUCT (Catálogo Master da Plataforma)
// Representa cada produto disponível no portfólio Gravity.
// Gerenciado exclusivamente por gravity_admin via /api/admin/products.
// NÃO confundir com ProductConfig (que é a ativação por tenant).
// ---------------------------------------------------------------------------

enum StatusProdutoGravity {
  ATIVO
  SUSPENSO
  EM_BREVE
  LEGADO
  INATIVO
}

enum TipoCobrancaGravity {
  MENSAL
  POR_PROCESSO
  POR_DOCUMENTO
  POR_ESTIMATIVA
  POR_DI_DUIMP
  POR_DUE
  POR_PRODUTO
  POR_FLUXO
  POR_LPCO
}

enum ProdutoGravityLimiteUsuario {
  ILIMITADO
  LIMITADO
}

model ProdutoGravity {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String
  status      StatusProdutoGravity @default(ATIVO)
  launch_date DateTime?

  // Setup
  has_setup      Boolean  @default(false)
  setup_price    Decimal? @db.Decimal(15, 2)
  setup_currency String   @default("BRL")

  // Billing
  billing_type     TipoCobrancaGravity @default(MENSAL)
  unit_price       Decimal     @db.Decimal(15, 2)
  unit_currency    String      @default("BRL")
  minimum_price    Decimal     @default(0) @db.Decimal(15, 2)
  minimum_currency String      @default("BRL")
  total_price      Decimal?    @db.Decimal(15, 2)
  total_currency   String      @default("BRL")

  // Users
  user_limit_type     ProdutoGravityLimiteUsuario @default(ILIMITADO)
  base_users_qty      Int?
  extra_user_price    Decimal?      @db.Decimal(15, 2)
  extra_user_currency String        @default("BRL")

  // Support
  helpdesk_hours      Int      @default(0)
  extra_hour_price    Decimal? @db.Decimal(15, 2)
  extra_hour_currency String   @default("BRL")

  // GABI On-Demand — quota padrão de tokens por tenant/mês
  gabi_quota_mensal Int @default(0)

  // Metadata
  backend_module  String? // ex: "simula-custo", "bid-frete"
  target_audience String?

  // Timestamps
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime? // soft-delete — preserva negociações especiais

  // Relations
  price_tiers  FaixaPreco[]
  negotiations NegociacaoEspecial[]

  @@index([status])
  @@index([slug])
  @@index([deleted_at])
  @@map("produtos_gravity")
}

// ---------------------------------------------------------------------------
// PRICE TIER (Faixas de Preço por Volume)
// Precificação escalonada — preço varia conforme quantidade.
// ---------------------------------------------------------------------------

model FaixaPreco {
  id         String  @id @default(cuid())
  product_id String
  range_from Int
  range_to   Int?
  price      Decimal @db.Decimal(15, 2)
  currency   String  @default("BRL")

  // Timestamps
  created_at DateTime @default(now())

  // Relations
  product ProdutoGravity @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([product_id])
  @@index([product_id, range_from])
  @@map("faixa_preco_produto_gravity")
}

// ---------------------------------------------------------------------------
// SPECIAL NEGOTIATION (Negociação Especial por Organizacao)
// Condições comerciais personalizadas para tenants específicos.
// ---------------------------------------------------------------------------

model NegociacaoEspecial {
  id           String    @id @default(cuid())
  product_id   String
  tenant_id    String
  tenant_name  String
  agreement    String // Descrição: "Desconto 20%", "Preço fixo R$ 5/proc"
  starts_at    DateTime?
  ends_at      DateTime?
  is_unlimited Boolean   @default(false)

  // Timestamps
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relations
  product ProdutoGravity @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([product_id])
  @@index([tenant_id])
  @@index([product_id, tenant_id])
  @@map("negociacao_especial_produto_gravity")
}

// ---------------------------------------------------------------------------
// DEPLOY LOG (Histórico de Deploys da Plataforma Gravity)
// Registro manual de cada deploy feito pelo time (hotfix, migration, release).
// Global — não é tenant-scoped. Apenas gravity_admin grava/lê.
// ---------------------------------------------------------------------------

enum DeployAmbiente {
  DESENVOLVIMENTO
  HOMOLOGACAO
  PRODUCAO
  TODOS
}

enum DeployStatus {
  SUCESSO
  FALHOU
  REVERTIDO
  EM_ANDAMENTO
}

model Deploy {
  id                  String            @id @default(cuid()) @map("id_deploy")
  deploy_number       Int               @default(autoincrement())
  area                String            @map("area_deploy") // ex: 'configurador', 'pedido', 'bid-frete', 'nucleo-global', 'devops'
  version             String            @map("versao_deploy") // semver (v1.2.3) ou git sha (8f3a1c2)
  description         String            @map("descricao_deploy") // resumo das alterações (changelog curto)
  environment         DeployAmbiente @default(PRODUCAO) @map("ambiente_deploy")
  status              DeployStatus      @default(SUCESSO) @map("status_deploy")
  deployed_by         String            @map("quem_deploy") // nome legível do responsável (snapshot no momento do deploy)
  deployed_by_user_id String?           @map("id_usuario_deploy") // FK opcional para Usuario (pode ser null se deploy veio de CI)
  deployed_at         DateTime          @default(now()) @map("data_execucao_deploy")

  created_at DateTime @default(now()) @map("data_criacao_deploy")

  @@index([deployed_at])
  @@index([area])
  @@index([environment])
  @@index([status])
  @@index([area, deployed_at])
  @@map("deploy")
}

// ---------------------------------------------------------------------------
// SUPPLIER TENANT ACCESS
// Fornecedor cross-tenant — pode prestar serviços para múltiplos tenants.
// clerk_user_id único no Clerk, múltiplos vínculos aqui.
// ---------------------------------------------------------------------------

model FornecedorOrganizacao {
  id            String @id @default(cuid())
  clerk_user_id String
  tenant_id     String
  status        String @default("active")

  // Timestamps
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Unique: um clerk_user_id não pode ter dois acessos ao mesmo tenant
  @@unique([clerk_user_id, tenant_id])
  // Índices obrigatórios
  @@index([tenant_id])
  @@index([clerk_user_id])
  @@index([tenant_id, clerk_user_id])
  @@map("fornecedor_organizacao")
}

// ---------------------------------------------------------------------------
// SECURITY EVENT
// Eventos de segurança registrados pelo securityAuditLogger.
// Alimenta o painel /admin/seguranca em tempo real.
// ---------------------------------------------------------------------------

model Seguranca {
  id             String   @id @default(cuid())
  tenant_id      String
  actor_id       String
  actor_type     String // USER | SYSTEM | GABI_IA | ADMIN
  action         String // AUTH_FAILURE, CROSS_TENANT_ATTEMPT, ROLE_CHANGED, etc.
  severity       String // CRITICAL | WARNING | INFO
  status         String   @default("DETECTED") // BLOCKED | ALLOWED | DETECTED
  description    String?
  ip             String?
  endpoint       String?
  user_id        String?
  product_id     String?
  correlation_id String?
  metadata       Json?    @default("{}")
  created_at     DateTime @default(now())

  @@index([created_at])
  @@index([severity])
  @@index([action])
  @@index([tenant_id, created_at])
  @@index([severity, created_at])
  @@map("seguranca")
}

// ---------------------------------------------------------------------------
// RATE LIMIT METRIC
// Metricas agregadas do rate limiter para monitoramento no painel.
// ---------------------------------------------------------------------------

model Requisicoes {
  id           String   @id @default(cuid())
  key          String // tenant:ip combo
  tenant_id    String?
  ip           String?
  endpoint     String
  count        Int
  limit_max    Int
  blocked      Boolean  @default(false)
  window_start DateTime
  created_at   DateTime @default(now())

  @@index([created_at])
  @@index([blocked, created_at])
  @@index([tenant_id])
  @@map("requisicoes")
}

// ---------------------------------------------------------------------------
// SERVICE HEALTH
// Snapshot do ultimo health check de cada servico.
// ---------------------------------------------------------------------------

model Servicos {
  id         String   @id @default(cuid())
  service    String   @unique // ex: "configurador", "bid-frete"
  url        String // health check URL
  status     String   @default("UNKNOWN") // OK | DEGRADED | DOWN | UNKNOWN
  latency_ms Int?
  last_error String?
  checked_at DateTime @default(now())
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([status])
  @@index([checked_at])
  @@map("servicos")
}

// ---------------------------------------------------------------------------
// TAXA CAMBIO
// Cotações PTAX oficiais do BCB armazenadas para consulta centralizada.
// Tabela global — sem tenant_id (rates são públicas, iguais para todos).
// Alimentada via POST /api/v1/taxa-cambio/sync (busca do bid-cambio/BCB).
// ---------------------------------------------------------------------------

model Cambio {
  id           String   @id @default(cuid())
  moeda        String // USD, EUR, GBP, CHF, CNY, JPY
  compra       Decimal  @db.Decimal(15, 6)
  venda        Decimal  @db.Decimal(15, 6)
  data_cotacao DateTime // data da cotação (dia, meia-noite UTC)
  hora_cotacao String? // ex: "13:02"
  boletim      String   @default("Fechamento") // "1º Boletim" | "2º Boletim" | "3º Boletim" | "Fechamento"
  fonte        String   @default("BCB/PTAX")
  criado_em    DateTime @default(now())

  // Garante 1 registro por moeda × dia × boletim (upsert idempotente)
  @@unique([moeda, data_cotacao, boletim])
  @@index([moeda])
  @@index([moeda, data_cotacao])
  @@index([data_cotacao])
  @@index([criado_em])
  @@map("cambio")
}

// ---------------------------------------------------------------------------
// SISTEMA DE TESTES — Testes, TestSchedule, TestPlan
// ---------------------------------------------------------------------------
// Tabelas que suportam o sistema de testes automatizado do Admin/Testes.
// Documentação completa em documentos-tecnicos/testes/tecnico/.
// Convenção de IDs: TST-{TIPO}-{ESCOPO}-{NNNNNN}

model Testes {
  id           String   @id @default(cuid())
  tenant_id    String   @default("platform") // sempre "platform" — logs globais
  type         String // UNI | CON | FUN | CRO | E2E | PEN
  escopo       String // LOGIN | CONFIG | ADMIN | HUB | CORE | MARKET | TENANT | DBASE | PEDIDO | NFIMP | LPCO | BIDFRT | BIDCAM | SIMCUS | FINCOM | PROCSO
  sublocal     String?
  module       String
  test_name    String
  test_id      String? // TST-E2E-CONFIG-000001 (quando vinculado a um plano)
  result       String // APROVADO | REPROVADO | ERRO
  duration     String
  error_log    String?  @db.Text
  ai_analysis  Json? // AiAnalysis schema do gemini-test-analyzer
  screenshot   String? // path do PNG capturado pela fixture
  ambiente     String   @default("Local") // Local | Staging | Producao
  run_id       String? // agrupa logs do mesmo run
  triggered_by String? // userId que disparou (manual) ou "cron" (automático)
  created_at   DateTime @default(now())

  @@index([tenant_id])
  @@index([created_at])
  @@index([type, escopo])
  @@index([result])
  @@index([run_id])
  @@index([test_id])
  @@map("testes")
}

model AgendamentoTeste {
  id           String    @id @default(cuid())
  tenant_id    String    @default("platform")
  ativo        Boolean   @default(false)
  frequencia   String    @default("Manual") // Manual | Diario | Semanal
  hora         Int       @default(0) // 0-23
  minuto       Int       @default(0) // 0-59
  tipos        Json // { uni: bool, con: bool, fun: bool, cro: bool, e2e: bool, pen: bool }
  escopos      String[] // ['CONFIG','PEDIDO','ADMIN',...]
  ambiente     String    @default("Local") // Local | Staging | Producao
  alertas      Json      @default("[]") // [{ nome, contato, condicao, canal }]
  ultima_exec  DateTime?
  proxima_exec DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  @@index([tenant_id])
  @@index([ativo])
  @@index([proxima_exec])
  @@map("agendamento_teste")
}

model PlanoTeste {
  id               String    @id // TST-E2E-CONFIG-000001
  tenant_id        String    @default("platform")
  versao           String    @default("1.0")
  tipo             String // UNI | CON | FUN | CRO | E2E | PEN
  escopo           String // LOGIN | CONFIG | ...
  sublocal         String
  tela             String
  rota             String
  criticidade      String    @default("media") // baixa | media | alta | critica
  ambientes        String[]
  componente_path  String
  spec_path        String?
  mapeamento_path  String
  cobertura_pct    Int       @default(0)
  passos_total     Int       @default(0)
  resumo_executivo String    @db.Text
  plano_completo   Json // o JSON inteiro do plano (formato do agente-plano-teste)
  status           String    @default("pendente_validacao") // pendente_validacao | aprovado | obsoleto
  ultima_execucao  DateTime?
  ultimo_resultado String? // APROVADO | REPROVADO | ERRO | NAO_EXECUTADO
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  @@index([tenant_id])
  @@index([tipo, escopo])
  @@index([status])
  @@index([sublocal])
  @@map("plano_teste")
}

// ---------------------------------------------------------------------------
// FATURA PRODUTOS GRAVITY (nova — fatura de serviços internos Gravity)
// ---------------------------------------------------------------------------

enum FaturaStatusGravity {
  DRAFT
  OPEN
  PAID
  VOID
  OVERDUE
  UNCOLLECTIBLE
}

model FaturaProdutosGravity {
  id                                        String       @id @default(cuid())
  tenant_id                                 String
  numero_fatura_servicos_gravity            String
  status_fatura_servicos_gravity            FaturaStatusGravity @default(DRAFT)
  organizacao_fatura_servicos_gravity       String
  email_organizacao_fatura_servicos_gravity String?
  valor_total_fatura_servicos_gravity       Decimal      @db.Decimal(18, 2)
  moeda_fatura_servicos_gravity             String       @default("brl")
  competencia_fatura_servicos_gravity       String?
  data_fatura_servicos_gravity              DateTime     @default(now())
  created_at                                DateTime     @default(now())
  updated_at                                DateTime     @updatedAt

  @@index([tenant_id])
  @@index([status_fatura_servicos_gravity])
  @@map("fatura_produtos_gravity")
}

// ---------------------------------------------------------------------------
// METRICAS GEMINI (nova — dados de LLM/teste AI)
// ---------------------------------------------------------------------------

model MetricasGemini {
  id                             String   @id @default(cuid())
  nome_llm                       String[]
  data_analise_llm               DateTime
  total_analise_llm              Int      @default(0)
  total_token_llm                Int      @default(0)
  custo_llm                      Decimal  @db.Decimal(10, 4)
  latencia_llm                   Int      @default(0)
  confianca_alta_llm             Int      @default(0)
  confianca_media_llm            Int      @default(0)
  confianca_baixa_llm            Int      @default(0)
  quantidade_codigo_validado_llm Int      @default(0)
  created_at                     DateTime @default(now())

  @@index([data_analise_llm])
  @@map("metricas_gemini")
}
