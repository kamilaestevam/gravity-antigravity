{
  "name": "@gravity/monorepo",
  "private": true,
  "workspaces": [
    "packages/resolver-organizacao",
    "nucleo-global",
    "scripts",
    "servicos-global/shell",
    "servicos-global/servicos-plataforma",
    "servicos-global/configurador",
    "servicos-global/marketplace",
    "servicos-global/servicos-plataforma/helpdesk",
    "servicos-global/servicos-plataforma/agendamento",
    "servicos-global/servicos-plataforma/api-cockpit",
    "servicos-global/servicos-plataforma/atividades",
    "servicos-global/servicos-plataforma/conector-erp",
    "servicos-global/servicos-plataforma/cronometro",
    "servicos-global/servicos-plataforma/dashboard",
    "servicos-global/servicos-plataforma/dashboard/client",
    "servicos-global/servicos-plataforma/email",
    "servicos-global/servicos-plataforma/gabi",
    "servicos-global/servicos-plataforma/historico-global",
    "servicos-global/servicos-plataforma/notificacoes",
    "servicos-global/servicos-plataforma/preferencias-usuario",
    "servicos-global/servicos-plataforma/relatorios",
    "servicos-global/servicos-plataforma/whatsapp",
    "servicos-global/produto/bid-cambio",
    "servicos-global/produto/bid-cambio/client",
    "servicos-global/produto/bid-cambio/server",
    "servicos-global/produto/bid-frete",
    "servicos-global/produto/bid-frete/client",
    "servicos-global/produto/bid-frete/server",
    "servicos-global/produto/financeiro-comex/client",
    "servicos-global/produto/financeiro-comex/server",
    "servicos-global/produto/lpco",
    "servicos-global/produto/lpco/client",
    "servicos-global/produto/lpco/server",
    "servicos-global/produto/nf-importacao",
    "servicos-global/produto/nf-importacao/client",
    "servicos-global/produto/nf-importacao/server",
    "servicos-global/produto/pedido",
    "servicos-global/produto/pedido/client",
    "servicos-global/produto/pedido/server",
    "servicos-global/produto/processo/client",
    "servicos-global/produto/processo/server",
    "servicos-global/produto/simula-custo",
    "servicos-global/produto/simula-custo/client",
    "servicos-global/produto/simula-custo/server",
    "servicos-global/servicos-plataforma/taxas-cambio",
    "servicos-global/servicos-plataforma/taxas-cambio/server"
  ],
  "scripts": {
    "dev": "concurrently -k -n CFG-BACK,CFG-FRONT,ORG,SC-BACK,PROC-BACK -c blue,green,cyan,yellow,magenta \"cd servicos-global/configurador && npm run dev\" \"cd servicos-global/configurador && npx vite\" \"cd servicos-global/servicos-plataforma && npm run dev\" \"cd servicos-global/produto/simula-custo/server && npx tsx watch src/index.ts\" \"cd servicos-global/produto/processo/server && npx tsx watch src/index.ts\"",
    "db:compose": "npx ts-node scripts/ativamente/compose-plataforma-schema.ts",
    "db:migrate:dev": "npm run db:compose && npx prisma migrate dev --schema=configurador/prisma/schema.prisma && npx prisma migrate dev --schema=servicos-global/servicos-plataforma/prisma/schema.prisma",
    "db:migrate:deploy": "npx prisma migrate deploy --schema=configurador/prisma/schema.prisma && npx prisma migrate deploy --schema=servicos-global/servicos-plataforma/prisma/schema.prisma",
    "db:seed:staging": "npx ts-node scripts/ativamente/seed-staging.ts",
    "db:apply-rls": "railway run psql $ORGANIZACAO_DATABASE_URL -f scripts/ativamente/apply-rls.sql",
    "translate": "npx tsx scripts/ativamente/translate.ts",
    "translate:check": "npx tsx scripts/ativamente/translate.ts --dry-run",
    "test": "vitest run --config testes/testes-unitarios/i18n/vitest.config.ts",
    "test:e2e": "playwright test --project=i18n",
    "test:all": "vitest run --config testes/testes-unitarios/i18n/vitest.config.ts && playwright test --project=i18n",
    "validate:test-ids": "npx tsx scripts/ativamente/validate-test-ids.ts",
    "validate:cobertura": "npx tsx scripts/ativamente/validate-cobertura.ts",
    "validate:testes": "npx tsx scripts/ativamente/validate-testes.ts",
    "check:deps": "npx tsx scripts/ativamente/check-deps.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "package.json": "npx tsx scripts/ativamente/check-deps.ts",
    "*.{ts,tsx}": "npx tsx scripts/ativamente/check-deps.ts"
  },
  "dependencies": {
    "@clerk/localizations": "^4.2.3",
    "@playwright/test": "^1.58.2",
    "@prisma/client": "^5.22.0",
    "@tanstack/react-virtual": "^3.13.23",
    "helmet": "^8.1.0",
    "i18next": "^26.0.1",
    "react-i18next": "^17.0.1",
    "react-resizable": "^3.1.3"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^4.17.21",
    "@types/react-grid-layout": "^1.3.5",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^2.1.9",
    "@vitest/ui": "^2.1.9",
    "concurrently": "^9.2.1",
    "express": "^4.19.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "playwright": "^1.58.2",
    "prisma": "^5.22.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-grid-layout": "^1.5.3",
    "recharts": "^2.15.4",
    "supertest": "^7.2.2",
    "svix": "^1.89.0",
    "vite": "^5.4.21",
    "vitest": "^2.1.9",
    "zod": "^3.25.76"
  },
  "overrides": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "i18next": "^26.0.1",
    "react-i18next": "^17.0.1",
    "zustand": "^5.0.12",
    "@prisma/client": "^5.22.0",
    "express": "^4.19.0",
    "zod": "^3.25.76",
    "vite": "^5.4.21",
    "typescript": "^5.4.0"
  }
}
