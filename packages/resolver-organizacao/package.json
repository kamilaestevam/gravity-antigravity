{
  "name": "@gravity/resolver-organizacao",
  "version": "0.2.0",
  "description": "SDK obrigatório de isolamento Schema-per-Organização para a plataforma Gravity. Única porta de entrada permitida ao banco de produtos. Implementa ADR-001 e ADR-002.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:all": "vitest run --config vitest.config.ts && vitest run --config vitest.e2e.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "dependencies": {
    "@clerk/backend": "^1.0.0",
    "@prisma/client": "^5.0.0",
    "zod": "^3.22.0"
  },
  "peerDependencies": {
    "bullmq": "^5.0.0",
    "express": "^4.18.0",
    "ioredis": "^5.0.0",
    "pino": "^9.0.0"
  },
  "peerDependenciesMeta": {
    "bullmq": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "pino": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^2.1.9",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.9"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
