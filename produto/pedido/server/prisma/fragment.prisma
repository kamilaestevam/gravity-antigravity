  valor_total_pedido                Int @default(2)
  valor_unitario_item               Int @default(2)
  quantidade_total_inicial_pedido   Int @default(2)
  quantidade_pronta_pedido_total    Int @default(2)
  saldo_itens_do_pedido             Int @default(2)
  quantidade_transferida_total      Int @default(2)
  quantidade_cancelada_total_pedido Int @default(2)
  peso_liquido_total_pedido         Int @default(3)
  peso_bruto_total_pedido           Int @default(3)
  cubagem_total_pedido              Int @default(3)

  formato_data String @default("DD/MM/AAAA")

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

