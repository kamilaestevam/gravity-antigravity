// ============================================
// Pedido — Anexos
// Produto: produto/pedido
// ============================================

model PedidoAnexo {
  id            String   @id @default(cuid())
  tenant_id     String
  product_id    String?
  vinculo       String              // 'pedido' | 'item'
  vinculo_id    String
  nome_arquivo  String
  tipo_arquivo  String
  tamanho_bytes Int
  descricao     String?
  categoria     String?
  storage_key   String
  uploaded_by   String
  created_at    DateTime @default(now())

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, vinculo_id])
  @@map("pedido_anexos")
}

// ============================================
// Pedido — Templates PDF
// Produto: produto/pedido
// ============================================

model PedidoTemplatePdf {
  id            String   @id @default(cuid())
  tenant_id     String
  product_id    String?
  nome          String
  descricao     String?
  conteudo_html String   @db.Text
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@map("pedido_templates_pdf")
}

// ============================================
// Pedido — Transferência de Pedidos
// Produto: produto/pedido
// ============================================

model TransferHistorico {
  id               String    @id @default(cuid())
  tenant_id        String
  product_id       String?

  // Referências de origem
  pedido_origem_id String
  item_origem_id   String

  // Dados da transferência
  cenario          String
  quantidade       Float
  destinos_json    String    // JSON serializado de TransferDestino[]

  // Reversão
  revertido        Boolean   @default(false)
  revertido_em     DateTime?
  revertido_por    String?

  // Auditoria
  created_at       DateTime  @default(now())
  created_by       String

  // Relação com Pedido (pedidos_comerciais)
  pedido_origem    Pedido @relation(fields: [pedido_origem_id], references: [id])

  // Índices obrigatórios (agent-policy)
  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, pedido_origem_id])
  @@map("transfer_historico")
}

