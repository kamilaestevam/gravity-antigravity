// ============================================================================
// fragment.prisma — produto/pedido
// Fonte da verdade dos models do produto Pedido (Mandamento 02).
// O Coordenador combina este arquivo com schema.base.prisma via
// `npx tsx scripts/ativamente/compose-pedido-schema.ts`.
//
// Nomenclatura: por enquanto preservamos `tenant_id`/`company_id` em modelos
// existentes para manter consistência interna do produto (renomeação massiva
// para `id_organizacao`/`id_workspace` será feita em sub-fase própria,
// depois que a planilha DDD geral estiver finalizada — PASSO 06).
// Modelos NOVOS criados neste arquivo (PedidoSnapshotEmpresa,
// PedidoSnapshotOpe, PedidoConfigAtualizacaoCadastros) já adotam DDD.
// ============================================================================

model Pedido {
  id_pedido                                                   String                      @id
  id_organizacao                                              String
  id_workspace                                                String
  tipo_operacao_pedido                                        String
  numero_pedido                                               String
  status_pedido                                               String                      @default("draft")
  id_status_pedido                                            String?
  id_importacao_exportador_pedido                             String?
  id_exportacao_importador_pedido                             String?
  id_fabricante_pedido                                        String?
  incoterm_pedido                                             String?
  moeda_pedido                                                String                      @default("USD")
  valor_total_pedido                                          Decimal?                    @db.Decimal(18, 6)
  casas_decimais_valor_pedido                                 Int                         @default(2)
  quantidade_total_pedido                                     Decimal?                    @db.Decimal(18, 6)
  casas_decimais_quantidade_pedido                            Int                         @default(2)
  unidade_comercializada_pedido                               String?
  condicao_pagamento_pedido                                   String?
  numero_proforma_pedido                                      String?
  numero_invoice_pedido                                       String?
  referencia_importador_pedido                                String?
  referencia_exportador_pedido                                String?
  referencia_fabricante_pedido                                String?
  valor_total_cambio_pedido                                   Decimal?                    @db.Decimal(18, 6)
  moeda_cambio_pedido                                         String?
  taxa_cambio_estimada_pedido                                 Decimal?                    @db.Decimal(18, 6)
  contrato_cambio_id_pedido                                   String?
  data_emissao_pedido                                         DateTime                    @default(now())
  detalhes_operacionais_pedido                                Json?
  dados_extras_importacao_pedido                              Json?
  ids_origem_consolidacao_pedido                              Json?
  cnpj_importador_pedido                                      String?
  data_consolidacao_pedido                                    DateTime?
  data_exclusao_pedido                                        DateTime?
  peso_liquido_total_pedido                                   Decimal?                    @db.Decimal(18, 6)
  peso_bruto_total_pedido                                     Decimal?                    @db.Decimal(18, 6)
  cubagem_total_pedido                                        Decimal?                    @db.Decimal(18, 6)
  casas_decimais_peso_pedido                                  Int                         @default(3)
  casas_decimais_cubagem_pedido                               Int                         @default(3)
  data_criacao_pedido                                         DateTime                    @default(now())
  data_atualizacao_pedido                                     DateTime                    @updatedAt

  // ============================================================
  // FASE 06B — Campos novos (cobertura cambial agregada + volumes)
  // ============================================================
  cobertura_cambial_pedido                                    String?
  quantidade_volumes_pedido                                   Int?

  // ============================================================
  // FASE 06B — Datas dos documentos (Pedido / Proforma / Invoice)
  // ============================================================
  data_documento_pedido                                       DateTime?
  data_documento_proforma_pedido                              DateTime?
  data_documento_invoice_pedido                               DateTime?

  // ============================================================
  // FASE 06B — Datas de etapa do Pedido (prev / conf / meta)
  // ============================================================
  data_prevista_pedido_pronto                                 DateTime?
  data_confirmada_pedido_pronto                               DateTime?
  data_meta_pedido_pronto                                     DateTime?
  data_prevista_inspecao_pedido                               DateTime?
  data_confirmada_inspecao_pedido                             DateTime?
  data_meta_inspecao_pedido                                   DateTime?
  data_prevista_coleta_pedido                                 DateTime?
  data_confirmada_coleta_pedido                               DateTime?
  data_meta_coleta_pedido                                     DateTime?

  // ============================================================
  // FASE 06B — Datas Draft Pedido (recebimento / aprovação)
  // ============================================================
  data_previsao_recebimento_draft_pedido                      DateTime?
  data_confirmacao_recebimento_draft_pedido                   DateTime?
  data_meta_recebimento_draft_pedido                          DateTime?
  data_previsao_aprovacao_draft_pedido                        DateTime?
  data_confirmacao_aprovacao_draft_pedido                     DateTime?
  data_meta_aprovacao_draft_pedido                            DateTime?

  // ============================================================
  // FASE 06B — Datas Proforma (Draft + Original)
  // ============================================================
  data_previsao_recebimento_draft_proforma_pedido             DateTime?
  data_confirmacao_recebimento_draft_proforma_pedido          DateTime?
  data_meta_recebimento_draft_proforma_pedido                 DateTime?
  data_previsao_aprovacao_draft_proforma_pedido               DateTime?
  data_confirmacao_aprovacao_draft_proforma_pedido            DateTime?
  data_meta_aprovacao_draft_proforma_pedido                   DateTime?
  data_previsao_envio_original_proforma_pedido                DateTime?
  data_confirmacao_envio_original_proforma_pedido             DateTime?
  data_meta_envio_original_proforma_pedido                    DateTime?
  data_previsao_recebimento_original_proforma_pedido          DateTime?
  data_confirmacao_recebimento_original_proforma_pedido       DateTime?
  data_meta_recebimento_original_proforma_pedido              DateTime?

  // ============================================================
  // FASE 06B — Datas Invoice (Draft + Original)
  // ============================================================
  data_previsao_recebimento_draft_invoice_pedido              DateTime?
  data_confirmacao_recebimento_draft_invoice_pedido           DateTime?
  data_meta_recebimento_draft_invoice_pedido                  DateTime?
  data_previsao_aprovacao_draft_invoice_pedido                DateTime?
  data_confirmacao_aprovacao_draft_invoice_pedido             DateTime?
  data_meta_aprovacao_draft_invoice_pedido                    DateTime?
  data_previsao_envio_original_invoice_pedido                 DateTime?
  data_confirmacao_envio_original_invoice_pedido              DateTime?
  data_meta_envio_original_invoice_pedido                     DateTime?
  data_previsao_recebimento_original_invoice_pedido           DateTime?
  data_confirmacao_recebimento_original_invoice_pedido        DateTime?
  data_meta_recebimento_original_invoice_pedido               DateTime?

  itens_pedido                                                PedidoItem[]
  transferencias_pedido                                       TrackingItemsTransferidos[]
  snapshots_empresa_pedido                                    PedidoSnapshotEmpresa[]
  snapshots_ope_pedido                                        PedidoSnapshotOpe[]

  @@unique([id_organizacao, numero_pedido])
  @@index([id_organizacao])
  @@index([id_organizacao, id_workspace])
  @@index([id_organizacao, status_pedido])
  @@index([id_organizacao, id_status_pedido])
  @@index([id_organizacao, tipo_operacao_pedido])
  @@index([id_organizacao, data_emissao_pedido])
  @@index([id_organizacao, data_exclusao_pedido])
  @@map("pedido_produto_gravity")
}

model PedidoItem {
  id_item                          String         @id
  id_organizacao                   String
  id_workspace                     String
  id_pedido                        String
  sequencia_item_pedido            Int?
  part_number_item                 String
  ncm_item                         String
  descricao_item                   String
  unidade_comercializada_item      String?
  quantidade_inicial_item          Decimal        @db.Decimal(18, 6)
  quantidade_atual_item            Decimal        @db.Decimal(18, 6)
  quantidade_pronta_item           Decimal        @default(0) @db.Decimal(18, 6)
  quantidade_transferida_item      Decimal        @default(0) @db.Decimal(18, 6)
  quantidade_cancelada_item        Decimal        @default(0) @db.Decimal(18, 6)
  casas_decimais_quantidade_item   Int            @default(2)
  moeda_item                       String         @default("USD")
  valor_total_item                 Decimal?       @db.Decimal(18, 6)
  valor_por_unidade_item           Decimal?       @db.Decimal(18, 6)
  casas_decimais_valor_item        Int            @default(2)
  cobertura_cambial_item           String         @default("com_cobertura")
  nome_exportador_item             String?
  nome_importador_item             String?
  nome_fabricante_item             String?
  referencia_importador_item       String?
  referencia_exportador_item       String?
  referencia_fabricante_item       String?
  incoterm_item                    String?
  condicao_pagamento_item          String?
  data_emissao_item                DateTime?
  peso_liquido_unitario_item       Decimal?       @db.Decimal(18, 6)
  peso_bruto_unitario_item         Decimal?       @db.Decimal(18, 6)
  cubagem_unitaria_item            Decimal?       @db.Decimal(18, 6)
  casas_decimais_peso_item         Int            @default(3)
  casas_decimais_cubagem_item      Int            @default(3)
  dados_extras_importacao_item     Json?
  data_criacao_item                DateTime       @default(now())
  data_atualizacao_item            DateTime       @updatedAt
  pedido_item                      Pedido         @relation(fields: [id_pedido], references: [id_pedido], onDelete: Cascade)
  embarques_efetivos_pedido_item   ProcessoItem[]

  @@index([id_organizacao])
  @@index([id_organizacao, id_workspace])
  @@index([id_pedido])
  @@map("pedido_itens")
}

