  id_organizacao                    String
  id_usuario                        String
  preferencias_kanban_preferencias  Json
  data_criacao_kanban_preferencias  DateTime @default(now())
  data_atualizacao_kanban_preferencias DateTime @updatedAt

  @@unique([id_organizacao, id_usuario])
  @@index([id_organizacao])
  @@index([id_organizacao, id_usuario])
