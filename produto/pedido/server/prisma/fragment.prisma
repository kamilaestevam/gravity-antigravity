model ProcessoFatura {
  id               String    @id
  tenant_id        String
  company_id       String
  processo_id      String
  tipo_fatura      String
  numero_fatura    String
  moeda_fatura     String    @default("USD")
  valor_total      Decimal   @db.Decimal(18, 6)
  valor_pago       Decimal   @default(0) @db.Decimal(18, 6)
  data_vencimento  DateTime?
  status_pagamento String    @default("pendente")
  processo         Processo  @relation(fields: [processo_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, company_id])
  @@index([tenant_id, processo_id])
  @@map("fatura_processo")
}

model ProcessoItem {
  id                          String      @id
  tenant_id                   String
  company_id                  String
  processo_id                 String
  pedido_item_id              String?
  sequencia_item              Int?
  part_number                 String
  ncm                         String
  descricao_po                String
  descricao_en                String?
  quantidade                  Decimal     @db.Decimal(18, 6)
  unidade_comercializada_item String?
  valor_unitario              Decimal     @db.Decimal(18, 6)
  valor_total                 Decimal     @db.Decimal(18, 6)
  peso_liquido_unitario       Decimal?    @db.Decimal(18, 6)
  peso_bruto_unitario         Decimal?    @db.Decimal(18, 6)
  detalhes_do_produto         Json?
  pedido_item                 PedidoItem? @relation(fields: [pedido_item_id], references: [id_item])
  processo                    Processo    @relation(fields: [processo_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, company_id])
  @@index([processo_id])
  @@index([pedido_item_id])
  @@map("logistica_processo")
}

model ProcessoContainer {
  id                        String    @id
  tenant_id                 String
  company_id                String
  processo_id               String
  container_numero          String
  container_lacre           String?
  container_tipo            String
  container_tara            Decimal?  @db.Decimal(18, 6)
  container_peso_bruto      Decimal?  @db.Decimal(18, 6)
  container_peso_liquido    Decimal?  @db.Decimal(18, 6)
  container_metragem_cubica Decimal?  @db.Decimal(18, 6)
  data_devolucao_prevista   DateTime?
  data_devolucao_real       DateTime?
  local_devolucao           String?
  processo                  Processo  @relation(fields: [processo_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, company_id])
  @@index([processo_id])
  @@map("container_processo")
}

model PedidoStatus {
  id         String   @id @default(cuid())
  tenant_id  String
  company_id String?
  nome       String
  rotulo     String
  cor        String
  icone      String?
  ordem      Int      @default(0)
  is_padrao  Boolean  @default(false)
  is_sistema Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([tenant_id, nome])
  @@index([tenant_id])
  @@index([tenant_id, company_id])
  @@map("status_pedido")
}

model PedidoColuna {
  id             String   @id @default(cuid())
  tenant_id      String
  company_id     String?
  nome           String
  rotulo         String
  tipo           String
  casas_decimais Int      @default(2)
  opcoes         Json?
  ordem          Int      @default(0)
  filtravel      Boolean  @default(true)
  exibida_padrao Boolean  @default(false)
  index_criado   Boolean  @default(false)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@unique([tenant_id, nome])
  @@index([tenant_id])
  @@index([tenant_id, company_id])
  @@map("pedido_colunas")
}

model PedidoPreferenciaUsuario {
  id_pedido_colunas_preferencia_usuario       String   @id @default(cuid())
  id_organizacao                              String
  id_workspace                                String?
  id_usuario                                  String
  colunas_visiveis_pedido_preferencia_usuario String[]
  colunas_largura_pedido_preferencia_usuario  Json?
  data_atualizacao_pedido_preferencia_usuario DateTime @updatedAt

  @@unique([id_organizacao, id_usuario])
  @@index([id_organizacao])
  @@index([id_organizacao, id_usuario])
  @@map("preferencia_coluna_pedido")
}

model PedidoPreferenciaPadrao {
  id_pedido_preferencia_padrao                String   @id @default(cuid())
  id_organizacao                              String   @unique
  id_workspace                                String?
  colunas_visiveis_pedido_preferencia_padrao  String[]
  colunas_largura_pedido_preferencia_padrao   Json?
  data_atualizacao_pedido_preferencia_padrao  DateTime @updatedAt

  @@index([id_organizacao])
  @@map("preferencia_padrao_pedido")
}

model AprendizadoImportacaoDados {
  id           String   @id @default(cuid())
  tenant_id    String
  product_id   String?
  user_id      String?
  hash_colunas String
  mapeamento   String
  uso_count    Int      @default(1)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@unique([tenant_id, hash_colunas])
  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
  @@map("aprendizado_importacao_dados")
}

model PedidoAnexo {
  id_anexo_pedido            String   @id @default(cuid())
  id_organizacao             String
  id_produto_gravity         String?
  vinculo_anexo_pedido       String
  id_vinculo_anexo_pedido    String
  nome_arquivo_anexo_pedido  String
  tipo_arquivo_anexo_pedido  String
  tamanho_bytes_anexo_pedido Int
  descricao_anexo_pedido     String?
  categoria_anexo_pedido     String?
  chave_storage_anexo_pedido String
  enviado_por_anexo_pedido   String
  data_criacao_anexo_pedido  DateTime @default(now())

  tipo_documento_anexo_pedido String?

  @@index([id_organizacao])
  @@index([id_organizacao, id_produto_gravity])
  @@index([id_organizacao, id_vinculo_anexo_pedido])
  @@index([id_organizacao, tipo_documento_anexo_pedido])
  @@map("anexo_pedido")
}

model PedidoTemplate {
  id_template_pedido               String   @id @default(cuid())
  id_organizacao                   String
  id_produto_gravity               String?
  nome_template_pedido             String
  descricao_template_pedido        String?
  conteudo_html_template_pedido    String
  data_criacao_template_pedido     DateTime @default(now())
  data_atualizacao_template_pedido DateTime @updatedAt

  @@index([id_organizacao])
  @@index([id_organizacao, id_produto_gravity])
  @@map("template_pedido_pdf")
}

model TrackingItemsTransferidos {
  id                          String    @id @default(cuid())
  tenant_id                   String
  product_id                  String?
  pedido_origem_id            String
  item_origem_id              String
  cenario                     String
  quantidade_item_transferida Float
  destinos_json               String
  revertido                   Boolean   @default(false)
  revertido_em                DateTime?
  revertido_por               String?
  created_at                  DateTime  @default(now())
  created_by                  String
  pedido_origem               Pedido    @relation(fields: [pedido_origem_id], references: [id_pedido])

  // FASE 06B — Dt Transferência Qtd. do Pedido (timestamp da efetivação da transferência da quantidade)
  data_transferencia_qtd      DateTime?

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, pedido_origem_id])
  @@map("tracking_items_transferidos")
}

model ColunaUsuarioPedido {
  id               String                     @id @default(cuid())
  tenant_id        String
  product_id       String?
  nome             String
  chave            String
  tipo             String
  escopo           String
  visibilidade     String
  roles_permitidas String[]                   @default([])
  obrigatorio      Boolean                    @default(false)
  opcoes           String[]                   @default([])
  descricao        String?
  valor_padrao     String?
  ordem            Int                        @default(0)
  ativo            Boolean                    @default(true)
  created_by       String
  created_at       DateTime                   @default(now())
  updated_at       DateTime                   @updatedAt
  valores          PedidoValorColunaUsuario[]

  @@unique([tenant_id, chave])
  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, ativo])
  @@map("coluna_usuario_pedido")
}

model PedidoValorColunaUsuario {
  id_valor_coluna_usuario_pedido            String              @id @default(cuid())
  id_organizacao                            String
  id_produto_gravity                        String?
  id_coluna_usuario_pedido                  String
  vinculo_valor_coluna_usuario_pedido       String
  id_vinculo_valor_coluna_usuario_pedido    String
  valor_coluna_usuario_pedido               String
  coluna_valor_coluna_usuario_pedido        ColunaUsuarioPedido @relation(fields: [id_coluna_usuario_pedido], references: [id])

  @@unique([id_organizacao, id_coluna_usuario_pedido, id_vinculo_valor_coluna_usuario_pedido])
  @@index([id_organizacao])
  @@index([id_organizacao, id_produto_gravity])
  @@index([id_organizacao, id_vinculo_valor_coluna_usuario_pedido])
  @@map("valor_coluna_usuario_pedido")
}

model KanbanPreferencias {
