// ============================================
// Pedido — Colunas do Usuário
// Produto: produto/pedido
// ============================================

model ColunaUsuarioPedido {
  id               String   @id @default(cuid())
  tenant_id        String
  product_id       String?
  nome             String
  chave            String
  tipo             String
  escopo           String   // 'pedido' | 'item' | 'ambos'
  visibilidade     String   // 'todos' | 'roles' | 'privado'
  roles_permitidas String[] @default([])
  obrigatorio      Boolean  @default(false)
  opcoes           String[] @default([])
  descricao        String?
  valor_padrao     String?
  ordem            Int      @default(0)
  ativo            Boolean  @default(true)
  created_by       String
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  valores ValorColunaUsuarioPedido[]

  @@unique([tenant_id, chave])
  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, ativo])
  @@map("colunas_usuario_pedido")
}

model ValorColunaUsuarioPedido {
  id         String   @id @default(cuid())
  tenant_id  String
  product_id String?
  coluna_id  String
  vinculo    String   // 'pedido' | 'item'
  vinculo_id String
  valor      String

  coluna ColunaUsuarioPedido @relation(fields: [coluna_id], references: [id])

  @@unique([tenant_id, coluna_id, vinculo_id])
  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, vinculo_id])
  @@map("valores_colunas_usuario_pedido")
}

// ============================================
// Pedido — Mapeamento de Importacao (Smart Import)
// Produto: produto/pedido
// ============================================

model MapeamentoImport {
  id           String   @id @default(cuid())
  tenant_id    String
  product_id   String?

  // Hash SHA256/CRC dos cabecalhos ordenados do arquivo
  hash_colunas String

  // JSON serializado de ColunaMapeada[]
  mapeamento   String

  // Quantas vezes este mapeamento foi utilizado/confirmado
  uso_count    Int      @default(1)

  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  // Unicidade por tenant + estrutura de arquivo
  @@unique([tenant_id, hash_colunas])

  // Indices obrigatorios (agent-policy)
  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, hash_colunas])

  @@map("mapeamento_import")
}

// ============================================
// Pedido — Rastreamento de Comportamento (Gabi Insights Fase 2)
// Produto: produto/pedido
// ============================================

model UserBehaviorEvent {
  id         String   @id @default(cuid())
  tenant_id  String
  product_id String?
  user_id    String

  /// Tipo: route_visited | filter_applied | widget_clicked | column_viewed | insight_clicked
  event      String

  /// JSON com dados do evento (rota, campo filtrado, widget_id, insight_id, etc.)
  payload    Json

  created_at DateTime @default(now())

  @@index([tenant_id])
  @@index([tenant_id, user_id])
  @@index([tenant_id, user_id, event])
  @@index([tenant_id, user_id, created_at])
  @@map("user_behavior_events")
}

// ============================================
// Pedido — Casas Decimais Config (por tenant)
// Produto: produto/pedido
// Armazena os defaults do workspace — aplicados em novos pedidos/itens
// e usados na migração em massa quando o admin altera a configuração.
// ============================================

model PedidoCasasDecimaisConfig {
  id         String   @id @default(cuid())
  tenant_id  String   @unique
  product_id String?

  // Grupo PEDIDO — 10 campos conforme spec mapas_pedido.pdf
  valor_total_pedido            Int @default(2)
  valor_unitario_item           Int @default(2)
  quantidade_total_inicial_pedido Int @default(2)
  quantidade_pronta_pedido_total  Int @default(2)
  saldo_itens_do_pedido           Int @default(2)
  quantidade_transferida_total    Int @default(2)
  quantidade_cancelada_total_pedido Int @default(2)
  peso_liquido_total_pedido       Int @default(3)
  peso_bruto_total_pedido         Int @default(3)
  cubagem_total_pedido            Int @default(3)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@map("pedido_casas_decimais_config")
}

// ============================================
// Pedido — Kanban Preferências
// Produto: produto/pedido
// ============================================

model KanbanPreferencias {
  id           String   @id @default(uuid())
  tenant_id    String
  user_id      String
  preferencias Json
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@unique([tenant_id, user_id])
  @@index([tenant_id])
  @@index([tenant_id, user_id])
}

// ============================================
// Pedido — Dashboard Painéis (por usuário)
// Produto: produto/pedido
// ============================================

model DashboardPainel {
  id           String   @id @default(cuid())
  tenant_id    String
  user_id      String
  nome         String
  ordem        Int      @default(0)
  is_visivel   Boolean  @default(true)
  widgets_json String   @default("[]")
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@index([tenant_id])
  @@index([tenant_id, user_id])
  @@map("dashboard_paineis")
}
