// ============================================================================
// fragment.prisma — produto/pedido
// Fonte da verdade dos models do produto Pedido (Mandamento 02).
// O Coordenador combina este arquivo com schema.base.prisma via
// `npx tsx scripts/ativamente/compose-pedido-schema.ts`.
//
// Nomenclatura: por enquanto preservamos `tenant_id`/`company_id` em modelos
// existentes para manter consistência interna do produto (renomeação massiva
// para `id_organizacao`/`id_workspace` será feita em sub-fase própria,
// depois que a planilha DDD geral estiver finalizada — PASSO 06).
// Modelos NOVOS criados neste arquivo (PedidoSnapshotEmpresa,
// PedidoSnapshotOpe, PedidoConfigAtualizacaoCadastros) já adotam DDD.
// ============================================================================

model Pedido {
  id                               String                      @id
  tenant_id                        String
  company_id                       String
  tipo_operacao                    String
  numero_pedido                    String
  status                           String                      @default("draft")
  status_id                        String?
  importacao_exportador_id         String?
  exportacao_importador_id         String?
  fabricante_id                    String?
  incoterm                         String?
  moeda_pedido                     String                      @default("USD")
  valor_total_pedido               Decimal?                    @db.Decimal(18, 6)
  casas_decimais_valor_pedido      Int                         @default(2)
  quantidade_total_pedido          Decimal?                    @db.Decimal(18, 6)
  casas_decimais_quantidade_pedido Int                         @default(2)
  unidade_comercializada_pedido    String?
  condicao_pagamento               String?
  numero_proforma                  String?
  numero_invoice                   String?
  referencia_importador            String?
  referencia_exportador            String?
  referencia_fabricante            String?
  valor_total_cambio_pedido        Decimal?                    @db.Decimal(18, 6)
  moeda_cambio_pedido              String?
  taxa_cambio_estimada             Decimal?                    @db.Decimal(18, 6)
  contrato_cambio_id_pedido        String?
  data_emissao_pedido              DateTime                    @default(now())
  detalhes_operacionais            Json?
  campos_custom                    Json?
  pedidos_origem_id                Json?
  cnpj_importador                  String?
  data_consolidacao_pedido         DateTime?
  deleted_at                       DateTime?
  peso_liquido_total_pedido        Decimal?                    @db.Decimal(18, 6)
  peso_bruto_total_pedido          Decimal?                    @db.Decimal(18, 6)
  cubagem_total_pedido             Decimal?                    @db.Decimal(18, 6)
  casas_decimais_peso_pedido       Int                         @default(3)
  casas_decimais_cubagem_pedido    Int                         @default(3)
  created_at                       DateTime                    @default(now())
  updated_at                       DateTime                    @updatedAt

  // ============================================================
  // FASE 06B — Campos novos (cobertura cambial agregada + volumes)
  // ============================================================
  cobertura_cambial_pedido         String?
  quantidade_volumes_pedido        Int?

  // ============================================================
  // FASE 06B — Datas dos documentos (Pedido / Proforma / Invoice)
  // ============================================================
  data_documento_pedido            DateTime?
  data_documento_proforma          DateTime?
  data_documento_invoice           DateTime?

  // ============================================================
  // FASE 06B — Datas de etapa do Pedido (prev / conf / meta)
  // ============================================================
  data_prevista_pedido_pronto      DateTime?
  data_confirmada_pedido_pronto    DateTime?
  data_meta_pedido_pronto          DateTime?
  data_prevista_inspecao_pedido    DateTime?
  data_confirmada_inspecao_pedido  DateTime?
  data_meta_inspecao_pedido        DateTime?
  data_prevista_coleta_pedido      DateTime?
  data_confirmada_coleta_pedido    DateTime?
  data_meta_coleta_pedido          DateTime?

  // ============================================================
  // FASE 06B — Datas Draft Pedido (recebimento / aprovação)
  // ============================================================
  data_prev_recebimento_draft_pedido     DateTime?
  data_conf_recebimento_draft_pedido     DateTime?
  data_meta_recebimento_draft_pedido     DateTime?
  data_prev_aprovacao_draft_pedido       DateTime?
  data_conf_aprovacao_draft_pedido       DateTime?
  data_meta_aprovacao_draft_pedido       DateTime?

  // ============================================================
  // FASE 06B — Datas Proforma (Draft + Original)
  // ============================================================
  data_prev_recebimento_draft_proforma     DateTime?
  data_conf_recebimento_draft_proforma     DateTime?
  data_meta_recebimento_draft_proforma     DateTime?
  data_prev_aprovacao_draft_proforma       DateTime?
  data_conf_aprovacao_draft_proforma       DateTime?
  data_meta_aprovacao_draft_proforma       DateTime?
  data_prev_envio_original_proforma        DateTime?
  data_conf_envio_original_proforma        DateTime?
  data_meta_envio_original_proforma        DateTime?
  data_prev_recebimento_original_proforma  DateTime?
  data_conf_recebimento_original_proforma  DateTime?
  data_meta_recebimento_original_proforma  DateTime?

  // ============================================================
  // FASE 06B — Datas Invoice (Draft + Original)
  // ============================================================
  data_prev_recebimento_draft_invoice     DateTime?
  data_conf_recebimento_draft_invoice     DateTime?
  data_meta_recebimento_draft_invoice     DateTime?
  data_prev_aprovacao_draft_invoice       DateTime?
  data_conf_aprovacao_draft_invoice       DateTime?
  data_meta_aprovacao_draft_invoice       DateTime?
  data_prev_envio_original_invoice        DateTime?
  data_conf_envio_original_invoice        DateTime?
  data_meta_envio_original_invoice        DateTime?
  data_prev_recebimento_original_invoice  DateTime?
  data_conf_recebimento_original_invoice  DateTime?
  data_meta_recebimento_original_invoice  DateTime?

  itens                            PedidoItem[]
  transferencias                   TrackingItemsTransferidos[]
  snapshots_empresa                PedidoSnapshotEmpresa[]
  snapshots_ope                    PedidoSnapshotOpe[]

  @@unique([tenant_id, numero_pedido])
  @@index([tenant_id])
  @@index([tenant_id, company_id])
  @@index([tenant_id, status])
  @@index([tenant_id, status_id])
  @@index([tenant_id, tipo_operacao])
  @@index([tenant_id, data_emissao_pedido])
  @@index([tenant_id, deleted_at])
  @@map("pedido_produto_gravity")
}

model PedidoItem {
  id                             String         @id
  tenant_id                      String
  company_id                     String
  pedido_id                      String
  sequencia_item                 Int?
  part_number                    String
  ncm                            String
  descricao_item                 String
  unidade_comercializada_item    String?
  quantidade_inicial_pedido      Decimal        @db.Decimal(18, 6)
  quantidade_atual_pedido        Decimal        @db.Decimal(18, 6)
  quantidade_pronta_pedido       Decimal        @default(0) @db.Decimal(18, 6)
  quantidade_transferida_pedido  Decimal        @default(0) @db.Decimal(18, 6)
  quantidade_cancelada_pedido    Decimal        @default(0) @db.Decimal(18, 6)
  casas_decimais_quantidade_item Int            @default(2)
  moeda_item                     String         @default("USD")
  valor_total_item               Decimal?       @db.Decimal(18, 6)
  valor_por_unidade_item         Decimal?       @db.Decimal(18, 6)
  casas_decimais_valor_item      Int            @default(2)
  cobertura_cambial              String         @default("com_cobertura")
  nome_exportador                String?
  nome_importador                String?
  nome_fabricante                String?
  referencia_importador          String?
  referencia_exportador          String?
  referencia_fabricante          String?
  incoterm                       String?
  condicao_pagamento_pedido      String?
  data_emissao_pedido            DateTime?
  peso_liquido_unitario          Decimal?       @db.Decimal(18, 6)
  peso_bruto_unitario            Decimal?       @db.Decimal(18, 6)
  cubagem_unitaria               Decimal?       @db.Decimal(18, 6)
  casas_decimais_peso_item       Int            @default(3)
  casas_decimais_cubagem_item    Int            @default(3)
  campos_custom                  Json?
  created_at                     DateTime       @default(now())
  updated_at                     DateTime       @updatedAt
  pedido                         Pedido         @relation(fields: [pedido_id], references: [id], onDelete: Cascade)
  embarques_efetivos             ProcessoItem[]

  @@index([tenant_id])
  @@index([tenant_id, company_id])
  @@index([pedido_id])
  @@map("pedido_itens")
}

