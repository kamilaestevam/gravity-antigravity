model ProcessoFatura {
  id               String    @id
  tenant_id        String
  company_id       String
  processo_id      String
  tipo_fatura      String
  numero_fatura    String
  moeda_fatura     String    @default("USD")
  valor_total      Decimal   @db.Decimal(18, 6)
  valor_pago       Decimal   @default(0) @db.Decimal(18, 6)
  data_vencimento  DateTime?
  status_pagamento String    @default("pendente")
  processo         Processo  @relation(fields: [processo_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, company_id])
  @@index([tenant_id, processo_id])
  @@map("fatura_processo")
}

model ProcessoItem {
  id                          String      @id
  tenant_id                   String
  company_id                  String
  processo_id                 String
  pedido_item_id              String?
  sequencia_item              Int?
  part_number                 String
  ncm                         String
  descricao_po                String
  descricao_en                String?
  quantidade                  Decimal     @db.Decimal(18, 6)
  unidade_comercializada_item String?
  valor_unitario              Decimal     @db.Decimal(18, 6)
  valor_total                 Decimal     @db.Decimal(18, 6)
  peso_liquido_unitario       Decimal?    @db.Decimal(18, 6)
  peso_bruto_unitario         Decimal?    @db.Decimal(18, 6)
  detalhes_do_produto         Json?
  pedido_item                 PedidoItem? @relation(fields: [pedido_item_id], references: [id])
  processo                    Processo    @relation(fields: [processo_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, company_id])
  @@index([processo_id])
  @@index([pedido_item_id])
  @@map("logistica_processo")
}

model ProcessoContainer {
  id                        String    @id
  tenant_id                 String
  company_id                String
  processo_id               String
  container_numero          String
  container_lacre           String?
  container_tipo            String
  container_tara            Decimal?  @db.Decimal(18, 6)
  container_peso_bruto      Decimal?  @db.Decimal(18, 6)
  container_peso_liquido    Decimal?  @db.Decimal(18, 6)
  container_metragem_cubica Decimal?  @db.Decimal(18, 6)
  data_devolucao_prevista   DateTime?
  data_devolucao_real       DateTime?
  local_devolucao           String?
  processo                  Processo  @relation(fields: [processo_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, company_id])
  @@index([processo_id])
  @@map("container_processo")
}

model PedidoStatus {
  id         String   @id @default(cuid())
  tenant_id  String
  company_id String?
  nome       String
  rotulo     String
  cor        String
  icone      String?
  ordem      Int      @default(0)
  is_padrao  Boolean  @default(false)
  is_sistema Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([tenant_id, nome])
  @@index([tenant_id])
  @@index([tenant_id, company_id])
  @@map("status_pedido")
}

model PedidoColuna {
  id             String   @id @default(cuid())
  tenant_id      String
  company_id     String?
  nome           String
  rotulo         String
  tipo           String
  casas_decimais Int      @default(2)
  opcoes         Json?
  ordem          Int      @default(0)
  filtravel      Boolean  @default(true)
  exibida_padrao Boolean  @default(false)
  index_criado   Boolean  @default(false)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@unique([tenant_id, nome])
  @@index([tenant_id])
  @@index([tenant_id, company_id])
  @@map("pedido_colunas")
}

model PedidoPreferenciaUsuario {
  id_pedido_preferencia_usuario               String   @id @default(cuid())
  id_organizacao                              String
  id_workspace                                String?
  id_usuario                                  String
  colunas_visiveis_pedido_preferencia_usuario String[]
  colunas_largura_pedido_preferencia_usuario  Json?
  data_atualizacao_pedido_preferencia_usuario DateTime @updatedAt

  @@unique([id_organizacao, id_usuario])
  @@index([id_organizacao])
  @@index([id_organizacao, id_usuario])
  @@map("preferencia_coluna_pedido")
}

model PedidoPreferenciaPadrao {
  id               String   @id @default(cuid())
  tenant_id        String   @unique
  company_id       String?
  colunas_visiveis String[]
  colunas_largura  Json?
  updated_at       DateTime @updatedAt

  @@index([tenant_id])
  @@map("preferencia_padrao_pedido")
}

model AprendizadoImportacaoDados {
  id           String   @id @default(cuid())
  tenant_id    String
  product_id   String?
  user_id      String?
  hash_colunas String
  mapeamento   String
  uso_count    Int      @default(1)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@unique([tenant_id, hash_colunas])
  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
  @@map("aprendizado_importacao_dados")
}

model AnexoPedido {
  id_anexo_pedido            String   @id @default(cuid())
  id_organizacao             String
  id_produto                 String?
  vinculo_anexo_pedido       String
  id_vinculo                 String
  nome_arquivo_anexo_pedido  String
  tipo_arquivo_anexo_pedido  String
  tamanho_bytes_anexo_pedido Int
  descricao_anexo_pedido     String?
  categoria_anexo_pedido     String?
  storage_key_anexo_pedido   String
  uploaded_by_anexo_pedido   String
  data_criacao_anexo_pedido  DateTime @default(now())

  // FASE 06B — categoria do documento (pedido | proforma | invoice | certificado_origem | apolice | etc.)
  // Versão (draft/original) NÃO é atributo do anexo — vive em colunas de data no model Pedido.
  tipo_documento_anexo_pedido String?

  @@index([id_organizacao])
  @@index([id_organizacao, id_produto])
  @@index([id_organizacao, id_vinculo])
  @@index([id_organizacao, tipo_documento_anexo_pedido])
  @@map("anexo_pedido")
}

model TemplatePedidoPdf {
  id_template_pedido_pdf            String   @id @default(cuid())
  id_organizacao                    String
  id_produto                        String?
  nome_template_pedido_pdf          String
  descricao_template_pedido_pdf     String?
  conteudo_html_template_pedido_pdf String
  data_criacao_template_pedido_pdf  DateTime @default(now())
  data_atualizacao_template_pedido_pdf DateTime @updatedAt

  @@index([id_organizacao])
  @@index([id_organizacao, id_produto])
  @@map("template_pedido_pdf")
}

model TrackingItemsTransferidos {
  id                          String    @id @default(cuid())
  tenant_id                   String
  product_id                  String?
  pedido_origem_id            String
  item_origem_id              String
  cenario                     String
  quantidade_item_transferida Float
  destinos_json               String
  revertido                   Boolean   @default(false)
  revertido_em                DateTime?
  revertido_por               String?
  created_at                  DateTime  @default(now())
  created_by                  String
  pedido_origem               Pedido    @relation(fields: [pedido_origem_id], references: [id])

  // FASE 06B — Dt Transferência Qtd. do Pedido (timestamp da efetivação da transferência da quantidade)
  data_transferencia_qtd      DateTime?

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, pedido_origem_id])
  @@map("tracking_items_transferidos")
}

model ColunaUsuarioPedido {
  id               String                     @id @default(cuid())
  tenant_id        String
  product_id       String?
  nome             String
  chave            String
  tipo             String
  escopo           String
  visibilidade     String
  roles_permitidas String[]                   @default([])
  obrigatorio      Boolean                    @default(false)
  opcoes           String[]                   @default([])
  descricao        String?
  valor_padrao     String?
  ordem            Int                        @default(0)
  ativo            Boolean                    @default(true)
  created_by       String
  created_at       DateTime                   @default(now())
  updated_at       DateTime                   @updatedAt
  valores          ValorColunaUsuarioPedido[]

  @@unique([tenant_id, chave])
  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, ativo])
  @@map("coluna_usuario_pedido")
}

model ValorColunaUsuarioPedido {
  id         String              @id @default(cuid())
  tenant_id  String
  product_id String?
  coluna_id  String
  vinculo    String
  vinculo_id String
  valor      String
  coluna     ColunaUsuarioPedido @relation(fields: [coluna_id], references: [id])

  @@unique([tenant_id, coluna_id, vinculo_id])
  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, vinculo_id])
  @@map("valor_coluna_usuario_pedido")
}

model KanbanPreferencias {
  id           String   @id @default(cuid())
  tenant_id    String
  user_id      String
  preferencias Json
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@unique([tenant_id, user_id])
  @@index([tenant_id])
  @@index([tenant_id, user_id])
  @@map("kanban_preferencias")
}

/// Configuração de widgets do Dashboard por tenant/produto.
model DashboardPreferencias {
  id           String   @id @default(cuid())
  tenant_id    String
  product_id   String
  widgets_json String   @default("[]") @db.Text
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@unique([tenant_id, product_id])
  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@map("dashboard_preferencias")
}

/// Configuração de casas decimais e formato de data por workspace (tenant).
model PedidoCasasDecimais {
  id         String  @id @default(cuid())
  tenant_id  String  @unique
  product_id String?

  valor_total_pedido                Int @default(2)
  valor_unitario_item               Int @default(2)
  quantidade_total_inicial_pedido   Int @default(2)
  quantidade_pronta_pedido_total    Int @default(2)
  saldo_itens_do_pedido             Int @default(2)
  quantidade_transferida_total      Int @default(2)
  quantidade_cancelada_total_pedido Int @default(2)
  peso_liquido_total_pedido         Int @default(3)
  peso_bruto_total_pedido           Int @default(3)
  cubagem_total_pedido              Int @default(3)

  formato_data String @default("DD/MM/AAAA")

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@map("pedido_casas_decimais")
}

/// Configuração da fórmula do Saldo do Pedido por workspace (tenant).
model PedidoSaldoFormula {
  id_pedido_saldo_formula String  @id @default(cuid())
  id_organizacao          String  @unique
  id_produto              String?

  formula_expressao_pedido_saldo_formula String @default("quantidade_total_inicial_pedido - quantidade_transferida_total - quantidade_cancelada_total_pedido")

  data_criacao_pedido_saldo_formula     DateTime @default(now())
  data_atualizacao_pedido_saldo_formula DateTime @updatedAt

  @@index([id_organizacao])
  @@index([id_organizacao, id_produto])
  @@map("pedido_saldo_formula")
}

/// Painéis do Dashboard por usuário.
model DashboardPainel {
  id           String   @id @default(cuid())
  tenant_id    String
  user_id      String
  nome         String
  ordem        Int      @default(0)
  is_visivel   Boolean  @default(true)
  widgets_json String   @default("[]") @db.Text
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@index([tenant_id])
  @@index([tenant_id, user_id])
  @@map("dashboard_painel")
}

// ============================================================================
// FASE 06B — Modelos novos (snapshot Cadastros + config de atualização)
// Nomenclatura DDD aplicada: id_organizacao / id_workspace.
// (Modelos legados acima ainda usam tenant_id/company_id — renomeação massiva
// fica para sub-fase própria após a planilha DDD geral.)
// ============================================================================

/// Snapshot congelado de uma Empresa (importador / exportador / fabricante / agente
/// / despachante / armador) no momento da emissão ou re-snapshot do pedido.
/// Referência ao banco Cadastros via SUID lógico (sem FK física).
model PedidoSnapshotEmpresa {
  id                    String   @id @default(cuid())
  id_organizacao        String
  id_workspace          String?
  id_pedido             String
  papel                 String   // 'importador' | 'exportador' | 'fabricante' | 'agente' | 'despachante' | 'armador'

  // Identidade
  suid_empresa          String   // referência lógica ao Cadastros (sem FK física)
  nome_empresa          String
  nome_fantasia         String?
  documento_principal   String   // CNPJ / EIN / VAT / TIN
  tipo_documento        String   // 'CNPJ' | 'EIN' | 'VAT' | 'TIN' | etc.
  cnpj_raiz             String?  // primeiros 8 dígitos do CNPJ — para empresas BR

  // Endereço
  endereco_logradouro   String?
  endereco_numero       String?
  endereco_complemento  String?
  endereco_bairro       String?
  endereco_cidade       String?
  endereco_uf           String?  // estado / província
  endereco_cep          String?  // zipcode
  endereco_pais         String?  // ISO-3166 alpha-2

  // Contato (principalmente exportador)
  contato_nome          String?
  contato_email         String?
  contato_whatsapp      String?
  contato_cargo         String?
  contato_departamento  String?

  // Relação Exportador <-> Fabricante (preenchido quando papel = exportador)
  exportador_e_fabricante      Boolean?
  relacao_exportador_fabricante String? // texto livre / enum a definir

  // Metadados do snapshot
  congelado_em          DateTime @default(now())
  motivo_congelamento   String   // 'emissao' | 'atualizacao_manual' | 'transicao_status'

  pedido                Pedido   @relation(fields: [id_pedido], references: [id], onDelete: Cascade)

  @@index([id_organizacao])
  @@index([id_organizacao, id_pedido])
  @@index([id_organizacao, suid_empresa])
  @@index([id_organizacao, papel])
  @@map("pedido_snapshot_empresa")
}

/// Snapshot congelado da OPE (Operação) vinculada ao pedido,
/// sincronizada do banco Cadastros (que por sua vez vem do Portal Único).
model PedidoSnapshotOpe {
  id                    String   @id @default(cuid())
  id_organizacao        String
  id_workspace          String?
  id_pedido             String

  // Identidade da OPE
  codigo_ope            String   // "Código OPE - Catálogo"
  versao_ope            String?  // "Versão OPE - Catálogo"
  situacao_ope          String?  // "Situação OPE - Catálogo"
  nome_ope              String?  // "Nome OPE - Catálogo"
  cnpj_raiz_empresa     String?  // "CNPJ Raiz Empresa - Catálogo" — 8 primeiros dígitos do CNPJ da empresa dona da OPE

  // Endereço da OPE
  pais_ope              String?
  estado_ope            String?
  cidade_ope            String?
  endereco_ope          String?
  zip_ope               String?
  tin_ope               String?
  email_ope             String?

  // Metadados
  congelado_em          DateTime @default(now())
  motivo_congelamento   String

  pedido                Pedido   @relation(fields: [id_pedido], references: [id], onDelete: Cascade)

  @@index([id_organizacao])
  @@index([id_organizacao, id_pedido])
  @@index([id_organizacao, codigo_ope])
  @@map("pedido_snapshot_ope")
}

/// Política por workspace de quando re-snapshotar dados do Cadastros nos pedidos.
/// Usado pelo fluxo "atualização represada" e pelo banner retroativo (FASE 06E).
model PedidoConfigAtualizacaoCadastros {
  id                       String   @id @default(cuid())
  id_organizacao           String
  id_workspace             String

  // Política de atualização por papel (Empresa)
  atualiza_importador      Boolean  @default(false)
  atualiza_exportador      Boolean  @default(false)
  atualiza_fabricante      Boolean  @default(false)
  atualiza_agente          Boolean  @default(false)
  atualiza_despachante     Boolean  @default(false)
  atualiza_armador         Boolean  @default(false)

  // Política de atualização da OPE
  atualiza_ope             Boolean  @default(false)

  // Em quais transições de status re-snapshotar
  resnap_em_emissao        Boolean  @default(true)
  resnap_em_embarque       Boolean  @default(false)
  resnap_em_desembaraco    Boolean  @default(false)

  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt

  @@unique([id_organizacao, id_workspace])
  @@index([id_organizacao])
  @@map("pedido_config_atualizacao_cadastros")
}

