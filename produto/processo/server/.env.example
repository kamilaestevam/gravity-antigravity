# .env.example — Processo Server
# Skill: antigravity-criar-produto (Passo 10)
# NUNCA commitar o .env real. Copiar este arquivo para .env e preencher os valores.

# --- Banco de Dados ------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host:5432/processo-db

# --- Autenticacao entre servicos -----------------------------------------------
# Deve ser igual ao CHAVE_SERVICO_INTERNO do Configurador e outros servicos
CHAVE_SERVICO_INTERNO=dev-key-mude-em-producao

# --- URLs de Servicos ----------------------------------------------------------
TENANT_SERVICES_URL=http://tenant-services.railway.internal:3001
CONFIGURATOR_URL=http://configurador.railway.internal:3000
CLIENT_URL=https://processo.gravity.com.br

# --- Servidor ------------------------------------------------------------------
PORT=8026
NODE_ENV=development
