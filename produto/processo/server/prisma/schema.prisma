// schema.base.prisma — Processo
// Composto via scripts/compose-schema.js -> gera schema.prisma final
// Skill: antigravity-criar-produto (Passo 8)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Modelos especificos do Processo sao definidos em fragment.prisma
// e compostos automaticamente pelo script compose-schema.js
// fragment.prisma — Processo
// Composto via scripts/compose-schema.js no schema final do produto.
// REGRA: todo model DEVE ter tenant_id (snake_case) e os indices obrigatorios.
// Skill: antigravity-tenant-isolation, antigravity-schema-composition

model Processo {
  id                  String   @id @default(cuid())
  tenant_id           String   // OBRIGATORIO — nunca nullable
  product_id          String?  // "processo" — permite queries isoladas por produto
  user_id             String?  // clerk_id do usuario que criou

  numero              String   // Numero do processo (ex: IMP-2024-001)
  referencia_interna  String?  // Referencia interna do cliente
  referencia_dati     String?  // Referencia do sistema Dati legado
  status              String   @default("aberto") // aberto | em_andamento | concluido | cancelado
  tipo                String   // importacao | exportacao
  responsavel_id      String?  // clerk_id do responsavel
  vendedor_id         String?  // clerk_id do vendedor
  setor_responsavel   String?  // Setor responsavel pelo processo

  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  // Relacoes
  etapas              ProcessoEtapa[]
  pedidos             Pedido[]
  followUps           FollowUp[]
  documentos          Documento[]
  estimativaCusto     EstimativaCusto?
  dadosTecnicos       DadosTecnicos?

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
  @@index([tenant_id, numero])
  @@map("processos")
}

model ProcessoEtapa {
  id             String    @id @default(cuid())
  tenant_id      String
  product_id     String?
  user_id        String?

  processo_id    String
  nome           String    // pedido | carga | embarque | chegada | liberacao | entrega
  status         String    @default("pendente") // concluido | atual | pendente
  data_prevista  DateTime?
  data_realizada DateTime?
  observacao     String?

  processo       Processo  @relation(fields: [processo_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, processo_id])
  @@map("processo_etapas")
}

model Pedido {
  id              String   @id @default(cuid())
  tenant_id       String
  product_id      String?
  user_id         String?

  processo_id     String
  numero          String   // Numero da PO
  exportador_nome String?
  exportador_pais String?  // ISO 2 letras
  valor_fob       Float    @default(0)
  moeda           String   @default("USD")
  peso_bruto      Float    @default(0)
  status          String   @default("pendente") // pendente | confirmado | embarcado

  processo        Processo     @relation(fields: [processo_id], references: [id], onDelete: Cascade)
  itens           PedidoItem[]

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, processo_id])
  @@map("pedidos")
}

model PedidoItem {
  id             String  @id @default(cuid())
  tenant_id      String
  product_id     String?
  user_id        String?

  pedido_id      String
  numero_item    String  // Numero sequencial do item
  descricao      String
  ncm            String? // NCM do item
  quantidade     Float   @default(0)
  unidade        String  @default("UN") // UN | KG | M | etc
  valor_unitario Float   @default(0)
  valor_total    Float   @default(0)
  moeda          String  @default("USD")
  status_li      String  @default("pendente") // pendente | deferida | indeferida

  pedido         Pedido  @relation(fields: [pedido_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, pedido_id])
  @@map("pedido_itens")
}

model FollowUp {
  id            String   @id @default(cuid())
  tenant_id     String
  product_id    String?
  user_id       String?

  processo_id   String
  titulo        String
  descricao     String?
  tipo          String   @default("info") // info | desvio | atualizacao | documento
  categoria     String   @default("sistema") // exportador | logistica | despachante | financeiro | sistema
  usuario_id    String?  // clerk_id de quem registrou
  usuario_nome  String?  // Nome de quem registrou (desnormalizado para timeline)

  created_at    DateTime @default(now())

  processo      Processo @relation(fields: [processo_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, processo_id])
  @@map("follow_ups")
}

model Documento {
  id             String   @id @default(cuid())
  tenant_id      String
  product_id     String?
  user_id        String?

  processo_id    String
  nome           String   // Nome do arquivo
  tipo_arquivo   String   // pdf | xlsx | xml | img
  tamanho_bytes  Int      @default(0)
  url            String   // URL do arquivo no storage
  categoria      String   @default("outro") // bl | po | di | li | nfe | outro

  created_at     DateTime @default(now())

  processo       Processo @relation(fields: [processo_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, processo_id])
  @@map("documentos")
}

model EstimativaCusto {
  id           String  @id @default(cuid())
  tenant_id    String
  product_id   String?
  user_id      String?

  processo_id  String  @unique
  impostos     Float   @default(0)
  frete        Float   @default(0)
  despacho     Float   @default(0)
  outros       Float   @default(0)
  total        Float   @default(0)
  moeda        String  @default("BRL")

  processo     Processo @relation(fields: [processo_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@map("estimativas_custo")
}

model DadosTecnicos {
  id                     String  @id @default(cuid())
  tenant_id              String
  product_id             String?
  user_id                String?

  processo_id            String  @unique

  // Importador
  importador_nome        String?
  importador_cnpj        String?
  importador_endereco    String?

  // Exportador
  exportador_nome        String?
  exportador_pais        String?
  exportador_endereco    String?

  // Transporte
  modal                  String? // maritimo | aereo | rodoviario | ferroviario
  porto_embarque         String?
  porto_destino          String?
  navio_voo              String?
  data_embarque          DateTime?
  data_chegada_prevista  DateTime?
  data_chegada_real      DateTime?
  bl_numero              String?
  container_numero       String?

  // Despacho
  despachante_nome       String?
  despachante_contato    String?
  di_numero              String?
  di_data                DateTime?
  canal                  String? // verde | amarelo | vermelho | cinza

  // Seguro
  seguro_apolice         String?
  seguro_valor           Float?
  seguro_moeda           String?

  processo               Processo @relation(fields: [processo_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@map("dados_tecnicos")
}
