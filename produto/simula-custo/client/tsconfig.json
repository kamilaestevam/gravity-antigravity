{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@nucleo/*": [
        "../../../nucleo-global/Botoes/*/src/index.ts",
        "../../../nucleo-global/Campos/*/src/index.ts",
        "../../../nucleo-global/Feedback/*/src/index.ts",
        "../../../nucleo-global/Layout/*/src/index.ts",
        "../../../nucleo-global/Modais/*/src/index.ts",
        "../../../nucleo-global/Tabelas/*/src/index.ts",
        "../../../nucleo-global/Utilidades/*/src/index.ts",
        "../../../nucleo-global/*/src/index.ts"
      ],
      "@shell":    ["../../../servicos-global/shell/index.ts"],
      "@shell/*":  ["../../../servicos-global/shell/*"],
      "@tenant/*": ["../../../servicos-global/tenant/*"],
      "@produto/*": ["../../../servicos-global/produto/*"]
    }
  },
  "include": ["src"]
}
