// fragment.prisma — SimulaCusto
// Composto via scripts/compose-schema.js no schema final do produto.
// REGRA: todo model DEVE ter tenant_id (snake_case) e os 3 índices obrigatórios.
// Skill: antigravity-tenant-isolation, antigravity-schema-composition

model Estimativa {
  id          String   @id @default(cuid())
  tenant_id   String   // OBRIGATÓRIO — nunca nullable
  product_id  String?  // "simula-custo" — permite queries isoladas por produto
  user_id     String   // clerk_id do usuário que criou a estimativa

  // Dados da Operação
  ncm              String
  pais_origem      String
  uf_desembaraco   String
  data_simulacao   DateTime @default(now())

  // Valores de Entrada (moeda original)
  valor_produto    Float
  moeda_produto    String
  ptax_utilizada   Float
  valor_frete      Float    @default(0)
  moeda_frete      String
  valor_seguro     Float    @default(0)
  moeda_seguro     String

  // Alíquotas utilizadas
  aliquota_ii      Float    @default(0)
  aliquota_ipi     Float    @default(0)
  aliquota_pis     Float    @default(0)
  aliquota_cofins  Float    @default(0)
  aliquota_icms    Float    @default(0)

  // Tributos calculados (em BRL)
  valor_ii         Float    @default(0)
  valor_ipi        Float    @default(0)
  valor_pis        Float    @default(0)
  valor_cofins     Float    @default(0)
  valor_icms       Float    @default(0)
  total_tributos   Float    @default(0)

  // Landed Cost Final em BRL
  landed_cost_brl  Float    @default(0)

  // Controle de Status
  status           String   @default("rascunho") // rascunho | criada | arquivada
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  taxas            TaxaEstimativa[]

  // Índices obrigatórios (skill: antigravity-tenant-isolation)
  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
  @@map("estimativas_trade")
}

model TaxaEstimativa {
  id            String     @id @default(cuid())
  tenant_id     String     // OBRIGATÓRIO
  estimativa_id String
  tipo          String     // "origem" | "destino"
  nome          String
  valor         Float
  moeda         String

  estimativa    Estimativa @relation(fields: [estimativa_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([tenant_id, estimativa_id])
  @@map("taxas_estimativa_trade")
}

model CacheAliquota {
  ncm              String   @id
  aliquota_ii      Float
  aliquota_ipi     Float
  aliquota_pis     Float
  aliquota_cofins  Float
  fonte            String   @default("siscomex") // siscomex | tipi_fallback
  updated_at       DateTime @updatedAt

  @@map("cache_aliquotas_ncm")
}

model CacheCambio {
  moeda        String   @id
  ptax_venda   Float
  ptax_compra  Float
  data_cotacao DateTime
  updated_at   DateTime @updatedAt

  @@map("cache_cambio_bacen")
}
