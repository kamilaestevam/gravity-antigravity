# Connection string para o banco gravity-cadastros (Railway).
CADASTROS_DATABASE_URL=

# Chave compartilhada entre serviços (validada via header x-internal-key).
CHAVE_SERVICO_INTERNO=

# Porta do serviço (default 8030).
PORT=8030

# URLs dos produtos consumidores — usadas pelo endpoint preview-impacto.
# Se ausentes, o produto correspondente retorna status='indisponivel'.
PEDIDO_BASE_URL=
LPCO_BASE_URL=
NF_IMPORTACAO_BASE_URL=
