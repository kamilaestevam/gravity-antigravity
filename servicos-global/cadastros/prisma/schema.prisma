// ---------------------------------------------------------------------
// Empresa — identidade 1:1 da organização (Cadastros §4.1)
// Separada de Fornecedor (parceiros/contrapartes).
// ---------------------------------------------------------------------
model Empresa {
  id_empresa String @id

  id_organizacao_empresa String @unique(map: "empresa_id_organizacao_empresa_key")

  nome_empresa              String
  cnpj_empresa              String?
  tin_empresa               String?
  pais_empresa              String
  estado_provincia_empresa  String?
  cidade_empresa            String?
  endereco_empresa          String?
  cep_zipcode_empresa       String?
  email_principal_empresa   String?
  telefone_principal_empresa String?
  whatsapp_principal_empresa String?

  pode_ser_importador_empresa                              Boolean @default(false)
  pode_ser_exportador_empresa                              Boolean @default(false)
  pode_ser_fabricante_empresa                              Boolean @default(false)
  pode_ser_agente_empresa                                  Boolean @default(false)
  pode_ser_despachante_empresa                             Boolean @default(false)
  pode_ser_armador_empresa                                 Boolean @default(false)
  pode_ser_cia_aerea_empresa                               Boolean @default(false)
  pode_ser_transportadora_rodoviaria_nacional_empresa      Boolean @default(false)
  pode_ser_transportadora_rodoviaria_internacional_empresa Boolean @default(false)
  pode_ser_armazem_alfandegado_empresa                     Boolean @default(false)
  pode_ser_armazem_nacional_empresa                        Boolean @default(false)
  pode_ser_banco_empresa                                   Boolean @default(false)
  pode_ser_seguradora_internacional_empresa                Boolean @default(false)
  pode_ser_seguradora_corretora_cambio_empresa             Boolean @default(false)

  ativo_empresa         Boolean  @default(true)
  criado_em_empresa     DateTime @default(now())
  atualizado_em_empresa DateTime @updatedAt

  @@unique([id_organizacao_empresa, cnpj_empresa],                 map: "emp_unq_org_cnpj")
  @@unique([id_organizacao_empresa, tin_empresa, pais_empresa],    map: "emp_unq_org_tin_pais")
  @@index([id_organizacao_empresa],                                map: "emp_org_idx")
  @@index([id_organizacao_empresa, nome_empresa],                  map: "emp_org_nome_idx")
  @@map("empresa")
}

// ---------------------------------------------------------------------
// Fornecedor — cartório de identidades COMEX (per-tenant)
// ---------------------------------------------------------------------
// Dois regimes:
// - Parceiro pedido (exportador Shenzhen): id_fornecedor por org cadastro.
// - Prestador portal (agente CNPJ): um id_fornecedor, várias fornecedor_organizacao.
//
// Tipo visual DERIVADO das flags pode_ser_*, NÃO enum único no master.
// ---------------------------------------------------------------------
model Fornecedor {
  id_fornecedor String @id

  id_organizacao_cadastro_fornecedor String
  id_produto_fornecedor              String?
  id_usuario_cadastro_fornecedor     String?

  nome_fornecedor              String
  cnpj_fornecedor              String?
  tin_fornecedor               String?
  pais_fornecedor              String
  estado_provincia_fornecedor  String?
  cidade_fornecedor            String?
  endereco_fornecedor          String?
  cep_zipcode_fornecedor       String?
  email_principal_fornecedor   String?
  telefone_principal_fornecedor String?
  whatsapp_principal_fornecedor String?

  pode_ser_importador_fornecedor                              Boolean @default(false)
  pode_ser_exportador_fornecedor                              Boolean @default(false)
  pode_ser_fabricante_fornecedor                              Boolean @default(false)
  pode_ser_agente_fornecedor                                  Boolean @default(false)
  pode_ser_despachante_fornecedor                             Boolean @default(false)
  pode_ser_armador_fornecedor                                 Boolean @default(false)
  pode_ser_armazem_alfandegado_fornecedor                     Boolean @default(false)
  pode_ser_transportadora_rodoviaria_nacional_fornecedor      Boolean @default(false)
  pode_ser_cia_aerea_fornecedor                               Boolean @default(false)
  pode_ser_transportadora_rodoviaria_internacional_fornecedor Boolean @default(false)
  pode_ser_seguradora_internacional_fornecedor                Boolean @default(false)
  pode_ser_seguradora_corretora_cambio_fornecedor             Boolean @default(false)
  pode_ser_banco_fornecedor                                   Boolean @default(false)
  pode_ser_armazem_nacional_fornecedor                        Boolean @default(false)

  ativo_fornecedor         Boolean  @default(true)
  criado_em_fornecedor     DateTime @default(now())
  atualizado_em_fornecedor DateTime @updatedAt

  fornecedores_organizacao FornecedorOrganizacao[]

  @@unique([id_organizacao_cadastro_fornecedor, cnpj_fornecedor],                          map: "forn_unq_org_cnpj")
  @@unique([id_organizacao_cadastro_fornecedor, tin_fornecedor, pais_fornecedor],          map: "forn_unq_org_tin_pais")
  @@index([id_organizacao_cadastro_fornecedor],                                            map: "forn_org_idx")
  @@index([id_organizacao_cadastro_fornecedor, id_produto_fornecedor],                     map: "forn_org_prd_idx")
  @@index([id_organizacao_cadastro_fornecedor, id_usuario_cadastro_fornecedor],            map: "forn_org_usr_idx")
  @@index([id_organizacao_cadastro_fornecedor, nome_fornecedor],                           map: "forn_org_nome_idx")
  @@map("fornecedor")
}

// ---------------------------------------------------------------------
// FornecedorOrganizacao — vínculo fornecedor ↔ organização cliente (SSOT)
// ---------------------------------------------------------------------
// SSOT Cadastros para todos os produtos Gravity. Substitui
// configurador.fornecedor_organizacao (remoção no Configurador = passo 02).
//
// id_fornecedor → fornecedor.id_fornecedor (cartório).
// id_usuario    = Configurador.usuario.id_usuario (FK lógica). NÃO há id_fornecedor em usuario.
// Sem snapshot nesta tabela — dados vivos via FK; snapshot δ no Pedido/contrato.
// Mesmo id_fornecedor pode ter várias id_organizacao (troca de crachá portal).
// ---------------------------------------------------------------------

enum TipoFornecedorOrganizacao {
  AGENTE_CARGA
  DESPACHANTE_ADUANEIRO
  ARMADOR
  CIA_AEREA
  TRANSPORTADORA_RODOVIARIA_NACIONAL
  TRANSPORTADORA_RODOVIARIA_INTERNACIONAL
  ARMAZEM_ALFANDEGADO
  ARMAZEM_NACIONAL
  BANCO
  SEGURADORA_INTERNACIONAL
  CORRETORA_CAMBIO
  FABRICANTE
}

enum StatusFornecedorOrganizacao {
  ATIVO
  INATIVO
  PENDENTE_APROVACAO
}

model FornecedorOrganizacao {
  id_fornecedor_organizacao String @id @default(cuid())

  id_fornecedor  String
  // Organização Gravity cliente que habilita/contrata o fornecedor
  id_organizacao String

  tipo_fornecedor_organizacao   TipoFornecedorOrganizacao
  status_fornecedor_organizacao StatusFornecedorOrganizacao @default(ATIVO)

  // Usuário FORNECEDOR habilitado (Configurador.usuario.id_usuario) — cross-DB
  id_usuario String?

  data_criacao_fornecedor_organizacao     DateTime @default(now())
  data_atualizacao_fornecedor_organizacao DateTime @updatedAt

  fornecedor Fornecedor @relation(fields: [id_fornecedor], references: [id_fornecedor], onDelete: Restrict)

  @@unique([id_fornecedor, id_organizacao, tipo_fornecedor_organizacao], map: "fornecedor_organizacao_forn_org_tipo_unq")
  @@index([id_organizacao],                                              map: "fornecedor_organizacao_org_idx")
  @@index([id_organizacao, id_fornecedor],                               map: "fornecedor_organizacao_org_forn_idx")
  @@index([id_organizacao, id_usuario],                                  map: "fornecedor_organizacao_org_usr_idx")
  @@index([id_fornecedor],                                               map: "fornecedor_organizacao_forn_idx")
  @@map("fornecedor_organizacao")
}

// ---------------------------------------------------------------------
// Catálogos globais (Moeda, Unidade, Ncm, Pais) — sem id_organizacao
// Decisão arquitetural: catálogos compartilhados entre todos os tenants.
// ---------------------------------------------------------------------

/// Pais — fonte única da verdade para país no monorepo Gravity.
/// 252 países seedeados de planilha consolidada (RFB + BACEN + SPED + ISO).
/// Toda entidade que referencia país (Empresa, Workspace, Organizacao,
/// AgenteCarga, Seguradora, etc.) deve apontar para id_pais (lookup lógico
/// cross-banco — sem FK física pois entidades vivem em DBs distintos).
/// Lei: skills/governanca/lei/cadastros-snapshot-policy/SKILL.md
model Pais {
  id_pais                            String   @id @default(cuid())

  // Nomes (RFB / referência internacional)
  nome_pais_portugues                String   @unique
  nome_pais_ingles                   String

  // Códigos brasileiros (COMEX, fiscal, contábil)
  // NÃO UNIQUE: planilha consolidada tem 4 duplicatas legítimas em
  // codigo_pais_portal_unico_siscomex (Receita Federal usa o mesmo código
  // para grupos de territórios — ex: 359 cobre Antártida e Ilha de Man).
  codigo_pais_portal_unico_siscomex  String?
  codigo_pais_bacen_4                String?
  codigo_pais_bacen_5                String?
  codigo_pais_sped_nfe               String?
  codigo_pais_sped_efd               String?

  // Códigos ISO 3166-1 (integrações internacionais)
  codigo_pais_iso_alpha2             String?  @unique
  codigo_pais_iso_alpha3             String?  @unique
  codigo_pais_iso_numerico           String?

  ativo_pais                         Boolean  @default(true)

  @@index([nome_pais_portugues])
  @@map("pais")
}

model Moeda {
  codigo_moeda   String  @id   // BRL, USD, EUR, CNY
  nome_moeda     String        // Real Brasileiro, Dólar Americano, Euro, Yuan
  simbolo_moeda  String
  ativo_moeda    Boolean @default(true)

  @@map("moeda")
}

model Unidade {
  codigo_unidade String  @id   // KG, UN, M, L
  nome_unidade   String
  tipo_unidade   String        // peso, quantidade, comprimento, volume
  ativo_unidade  Boolean @default(true)

  @@map("unidade")
}

// ---------------------------------------------------------------------
// Incoterm — catálogo global dos termos da ICC (Incoterms 2020).
// Padrão internacional fixo. Quando a ICC publicar Incoterms 2030,
// criar nova versao_incoterm e manter compatibilidade.
// ---------------------------------------------------------------------
model Incoterm {
  codigo_incoterm    String  @id   // FOB, CIF, EXW, CFR, DDP, DAP, FCA, CPT, CIP, DPU, FAS
  nome_incoterm      String        // "Free On Board", "Cost Insurance and Freight"
  descricao_incoterm String?
  modal_transporte   String        // "maritimo" | "qualquer"
  versao_incoterm    String  @default("2020")
  ativo_incoterm     Boolean @default(true)

  @@map("incoterm")
}

// ---------------------------------------------------------------------
// Porto — catálogo global de portos marítimos/fluviais (UN/LOCODE).
// Fonte: UNECE UN/LOCODE (datahub.io), ~6.000 portos ativos.
// Critério de inclusão: Function contém "1" (port) ou "8" (inland water).
// Atualizado 2x/ano pelo UN (via seed script manual).
// Catálogo global — sem id_organizacao.
// Lei: skills/governanca/lei/cadastros-snapshot-policy/SKILL.md
// ---------------------------------------------------------------------

model Porto {
  id_porto                    String   @id @default(cuid())

  // UN/LOCODE — identificação única internacional
  codigo_unlocode_porto       String   @unique   // ex: "BRSSZ", "USNYC", "CNSHA"
  codigo_pais_porto           String              // ISO alpha-2 (BR, US, CN)
  codigo_local_porto          String              // 3 chars UNLOCODE (SSZ, NYC, SHA)

  // Nomes
  nome_porto                  String              // Santos, New York, Shanghai
  nome_ascii_porto            String              // sem diacríticos (busca)

  // Localização
  subdivisao_porto            String?             // UF/estado/província (SP, NY, SH)
  latitude_porto              Float?
  longitude_porto             Float?

  // IATA (quando porto coincide com localidade de aeroporto)
  codigo_iata_porto           String?

  // Estado
  ativo_porto                 Boolean  @default(true)

  @@index([codigo_pais_porto],           map: "porto_pais_idx")
  @@index([nome_porto],                  map: "porto_nome_idx")
  @@index([nome_ascii_porto],            map: "porto_nome_ascii_idx")
  @@index([ativo_porto],                 map: "porto_ativo_idx")
  @@map("porto")
}

// ---------------------------------------------------------------------
// Aeroporto — catálogo global de aeroportos (UN/LOCODE + IATA).
// Fonte: UNECE UN/LOCODE (datahub.io), ~4.000 aeroportos ativos.
// Critério de inclusão: Function contém "4" (airport).
// Atualizado 2x/ano pelo UN (via seed script manual).
// Catálogo global — sem id_organizacao.
// Lei: skills/governanca/lei/cadastros-snapshot-policy/SKILL.md
// ---------------------------------------------------------------------

model Aeroporto {
  id_aeroporto                    String   @id @default(cuid())

  // UN/LOCODE — identificação única internacional
  codigo_unlocode_aeroporto       String   @unique   // ex: "BRGRU", "USJFK", "CNPVG"
  codigo_pais_aeroporto           String              // ISO alpha-2 (BR, US, CN)
  codigo_local_aeroporto          String              // 3 chars UNLOCODE (GRU, JFK, PVG)

  // Nomes
  nome_aeroporto                  String              // Guarulhos, John F. Kennedy, Pudong
  nome_ascii_aeroporto            String              // sem diacríticos (busca)

  // Localização
  subdivisao_aeroporto            String?             // UF/estado/província (SP, NY, SH)
  latitude_aeroporto              Float?
  longitude_aeroporto             Float?

  // IATA — código de 3 letras do aeroporto (fundamental para aéreo)
  codigo_iata_aeroporto           String?  @unique    // GRU, JFK, PVG

  // Estado
  ativo_aeroporto                 Boolean  @default(true)

  @@index([codigo_pais_aeroporto],           map: "aeroporto_pais_idx")
  @@index([nome_aeroporto],                  map: "aeroporto_nome_idx")
  @@index([nome_ascii_aeroporto],            map: "aeroporto_nome_ascii_idx")
  @@index([ativo_aeroporto],                 map: "aeroporto_ativo_idx")
  @@map("aeroporto")
}

// ---------------------------------------------------------------------
// Container — catálogo global / fonte única da verdade (ISO 6346).
// Cada registro = um tipo+tamanho de container existente no mundo.
// ~25 tipos práticos. Catálogo global — sem id_organizacao.
// Produtos fazem snapshot deste catálogo nas suas tabelas filhas:
//   - BID Frete:     container_dados_bid_frete   (snapshot catálogo)
//   - Processo:      container_processo           (snapshot + operacional)
//   - NF Importação: container_nf_importacao      (snapshot + operacional)
// Lei: skills/governanca/lei/cadastros-snapshot-policy/SKILL.md
// ---------------------------------------------------------------------

model Container {
  id_container                       String         @id @default(cuid())

  // Tipo funcional (enum)
  tipo_container                     ContainerTipo

  // Tamanho
  tamanho_container                  String              // "20'" | "40'" | "40'HC" | "45'"

  // ISO 6346 — código de 4 caracteres
  codigo_iso_container               String?  @unique    // ex: "22G0", "45R1", "42U1"

  // Armador proprietário do container
  armador_dono_container             String?             // ex: "MSC", "Maersk", "Hapag-Lloyd", "CMA CGM"

  // Estado
  ativo_container                    Boolean  @default(true)

  @@index([tipo_container],                  map: "container_tipo_idx")
  @@index([tamanho_container],               map: "container_tamanho_idx")
  @@index([ativo_container],                 map: "container_ativo_idx")
  @@map("container")
}

// ---------------------------------------------------------------------
// Enum ContainerTipo — tipos funcionais ISO 6346 + Siscomex Tabela EF.
// Cobre 99% do frete marítimo prático.
// ---------------------------------------------------------------------
enum ContainerTipo {
  DRY
  REEFER
  OPEN_TOP
  FLAT_RACK
  TANK
  BULK
  PLATAFORMA
}

// ---------------------------------------------------------------------
// NcmSync — catálogo NCM sincronizado do Portal Único Siscomex
// (renomeado de "Ncm" para evitar confusão com a coluna "ncm_item" das
// tabelas de produto. O job diário de sync mora aqui no Cadastros).
// Catálogo global — sem id_organizacao (alíquotas vêm da Receita Federal,
// iguais para todas as organizações).
// ---------------------------------------------------------------------

model NcmSync {
  codigo_ncm_sync    String   @id    // 8 dígitos — chave natural

  descricao_ncm_sync String
  ipi_ncm_sync       Float?
  ii_ncm_sync        Float?
  pis_ncm_sync       Float?
  cofins_ncm_sync    Float?
  ativo_ncm_sync     Boolean  @default(true)

  // Metadados do Portal Único
  data_inicio_ncm_sync DateTime?
  data_fim_ncm_sync    DateTime?

  // Referência ao NcmSyncLog que inseriu/atualizou este código
  id_ncm_sync_log    String?

  // Timestamps
  data_criacao_ncm_sync     DateTime @default(now())
  data_atualizacao_ncm_sync DateTime @updatedAt

  @@index([ativo_ncm_sync],          map: "nsy_ativo_idx")
  @@index([id_ncm_sync_log],         map: "nsy_log_idx")
  @@map("ncm_sync")
}

// ---------------------------------------------------------------------
// NcmSyncLog — histórico de cada sincronização com o Portal Único.
// Catálogo global — sem id_organizacao (sync é universal).
// ---------------------------------------------------------------------

model NcmSyncLog {
  id_ncm_sync_log         String    @id @default(cuid())

  // Timestamps de execução
  data_inicio_ncm_sync_log    DateTime  @default(now())
  data_conclusao_ncm_sync_log DateTime?

  // Status (enum PT)
  status_ncm_sync_log         NcmSyncStatusSincronizacao @default(EXECUTANDO)

  // Totais do diff
  total_ncm_sync_log        Int @default(0)
  adicionados_ncm_sync_log  Int @default(0)
  alterados_ncm_sync_log    Int @default(0)
  removidos_ncm_sync_log    Int @default(0)

  // Origem do trigger
  origem_ncm_sync_log        NcmSyncOrigemSincronizacao @default(JOB)
  disparado_por_ncm_sync_log String?   // id_usuario que disparou se MANUAL

  // Erro (apenas em caso de falha)
  mensagem_erro_ncm_sync_log String?

  // Timestamps
  data_criacao_ncm_sync_log     DateTime @default(now())
  data_atualizacao_ncm_sync_log DateTime @updatedAt

  @@index([status_ncm_sync_log],      map: "nsl_status_idx")
  @@index([data_inicio_ncm_sync_log], map: "nsl_inicio_idx")
  @@map("ncm_sync_log")
}

// ---------------------------------------------------------------------
// NcmSyncAgendamento — configuração singleton do job de sincronização.
// id_ncm_sync_agendamento = 'default' — registro único.
// ---------------------------------------------------------------------

model NcmSyncAgendamento {
  id_ncm_sync_agendamento String   @id @default("default")

  ativo_ncm_sync_agendamento          Boolean  @default(false)
  cron_expressao_ncm_sync_agendamento String   @default("0 2 * * *")   // 2am diário (America/Sao_Paulo)
  notificadores_ncm_sync_agendamento  Json     @default("[]")            // Array<NcmNotificador>

  data_criacao_ncm_sync_agendamento     DateTime @default(now())
  data_atualizacao_ncm_sync_agendamento DateTime @updatedAt

  @@map("ncm_sync_agendamento")
}

// ---------------------------------------------------------------------
// Enums NCM Sync (valores em PT-BR)
// ---------------------------------------------------------------------

enum NcmSyncStatusSincronizacao {
  EXECUTANDO
  SUCESSO
  ERRO
}

enum NcmSyncOrigemSincronizacao {
  JOB
  MANUAL
}

// ---------------------------------------------------------------------
// Ope — sincronizado de Portal Único (fonte da verdade SISCOMEX)
// ---------------------------------------------------------------------
model Ope {
  suid_ope                  String   @id

  // Identificação tenant — TODO field termina em _ope (DDD ONDA 38)
  id_organizacao_ope        String
  id_produto_ope            String?
  id_usuario_ope            String?

  codigo_portal_unico_ope   String   @unique(map: "ope_unq_codigo_portal_unico")
  situacao_ope              String   // espelho do status SISCOMEX
  versao_ope                String
  nome_ope                  String
  cnpj_raiz_empresa_ope     String
  pais_ope                  String
  estado_ope                String?
  cidade_ope                String?
  endereco_ope              String?
  zip_ope                   String?
  tin_ope                   String?
  email_ope                 String?
  ultima_sincronizacao_ope  DateTime
  origem_ope                String   @default("portal_unico")

  @@index([id_organizacao_ope],                          map: "ope_org_idx")
  @@index([id_organizacao_ope, id_produto_ope],          map: "ope_org_prd_idx")
  @@index([id_organizacao_ope, id_usuario_ope],          map: "ope_org_usr_idx")
  @@map("ope")
}

// ---------------------------------------------------------------------
// OPEHistoricoStatus — log de transições de status do OPE
// Onda 38: corrigido sufixo (era _historico_status_ope; correto é
// _ope_historico_status casando com @@map "ope_historico_status").
// Onda DB-1 (DDD): renomeado de OpeHistoricoStatus para OPEHistoricoStatus.
// ---------------------------------------------------------------------
model OPEHistoricoStatus {
  id_ope_historico_status                String   @id @default(cuid())

  // Identificação tenant
  id_organizacao_ope_historico_status    String?
  id_produto_ope_historico_status        String?
  id_usuario_ope_historico_status        String?

  suid_ope_historico_status              String
  status_anterior_ope_historico_status   String?
  status_novo_ope_historico_status       String
  origem_ope_historico_status            String   // portal_unico, manual, sistema
  payload_ope_historico_status           Json
  registrado_em_ope_historico_status     DateTime @default(now())

  @@index([suid_ope_historico_status],                                   map: "ohs_suid_idx")
  @@index([registrado_em_ope_historico_status],                          map: "ohs_data_idx")
  @@index([id_organizacao_ope_historico_status],                         map: "ohs_org_idx")
  @@index([id_organizacao_ope_historico_status, id_produto_ope_historico_status], map: "ohs_org_prd_idx")
  @@index([id_organizacao_ope_historico_status, id_usuario_ope_historico_status], map: "ohs_org_usr_idx")
  @@map("ope_historico_status")
}
