# .env.example (Configurador)

# Server
PORT=8005
NODE_ENV=development

# Database
# URL do banco de dados Configurador (ex: postgresql://user:pass@localhost:5432/configurador)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/configurador_dev

# Auth (Clerk)
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Payments (Stripe)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# S2S Communication
# Chave de segurança para chamadas internas entre microserviços
INTERNAL_SERVICE_KEY=develop-internal-key
