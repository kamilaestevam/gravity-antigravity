# Variáveis de ambiente — Configurador
# Porta: 8005

# Banco de dados exclusivo do Configurador
CONFIGURADOR_DATABASE_URL=postgresql://user:password@localhost:5432/configurador_db

# Clerk — autenticação de usuários
CLERK_SECRET_KEY=sk_live_...
CLERK_WEBHOOK_SECRET=whsec_...

# Stripe — billing e assinaturas
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# IDs de preço no Stripe (criar no dashboard do Stripe)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# Chave interna para chamadas S2S entre serviços
INTERNAL_SERVICE_KEY=supersecretkey-min-32-chars

# Porta do servidor (padrão: 8005)
PORT=8005

# URL do frontend (para CORS em desenvolvimento)
FRONTEND_URL=http://localhost:5173
