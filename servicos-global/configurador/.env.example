# .env.example (Configurador)

# Server
PORT=8005
NODE_ENV=development

# ─── Bancos de Dados ─────────────────────────────────────────────────────────
# Banco do Configurador — identidade global: organizacao, usuario, workspace, permissoes
# Usado pelo servidor Express e pelos scripts de seed/migração de infra
CONFIGURADOR_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/configurador_dev

# Banco Compartilhado — tenant services (email, dashboard, gabi, etc.) + produto Pedido
# Usado pelos scripts de migração Schema-per-Tenant (scripts/ativamente/migrate-tenants/)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shared_dev

# Auth (Clerk)
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# URL absoluta da app — usada pelo backend para gerar `redirectUrl` em
# `clerkClient.invitations.createInvitation()`. Sem essa env, o Clerk envia o
# convidado para o Account Portal hospedado (`*.accounts.dev/sign-up/continue`)
# em vez da nossa tela /cadastro/continuar.
# Dev: http://localhost:8000
# Prod: https://configurador.gravity.com.br
APP_BASE_URL=http://localhost:8000

# ─── Billing ────────────────────────────────────────────────────────────────
# Provider de cobrança ativo. Opções: conta_azul (OFICIAL) | itau | santander
# Provider OFICIAL do Gravity: conta_azul (cobrança + NFS-e integrado via ERP)
# Ver docs/BILLING.md para arquitetura e checklist de ativação.
BILLING_PROVIDER=conta_azul

# Conta Azul (PROVIDER OFICIAL — ver BILLING.md para OAuth2 setup)
# Requer plano Pro/Enterprise + A1 + IM Floripa + fluxo OAuth executado uma vez
# CONTA_AZUL_CLIENT_ID=
# CONTA_AZUL_CLIENT_SECRET=
# CONTA_AZUL_REDIRECT_URI=https://configurador.gravity.com.br/api/v1/faturas/conta-azul/oauth-callback
# CONTA_AZUL_REFRESH_TOKEN=
# CONTA_AZUL_ENVIRONMENT=sandbox

# Itaú (skeleton — contratar convênio + mTLS cert antes de ativar)
# ITAU_CLIENT_ID=
# ITAU_CLIENT_SECRET=
# ITAU_MTLS_CERT_PATH=
# ITAU_MTLS_KEY_PATH=
# ITAU_CONVENIO_ID=
# ITAU_CARTEIRA=
# ITAU_ENVIRONMENT=sandbox

# Santander (skeleton — contratar convênio + A1 cert antes de ativar)
# SANTANDER_CLIENT_ID=
# SANTANDER_CLIENT_SECRET=
# SANTANDER_CERT_PATH=
# SANTANDER_CERT_PASSWORD=
# SANTANDER_CONVENIO=
# SANTANDER_WORKSPACE_ID=
# SANTANDER_ENVIRONMENT=sandbox

# ─── NFS-e ─────────────────────────────────────────────────────────────────
# Provider de emissão de NFS-e. Opções: conta_azul (OFICIAL) | abrasf_florianopolis | (vazio = desabilitado)
# Quando BILLING_PROVIDER=conta_azul, use NFSE_PROVIDER=conta_azul para que ambos
# usem o mesmo refresh_token OAuth2.
# NFSE_PROVIDER=conta_azul

# NFS-e Florianópolis (skeleton ABRASF 2.03)
# NFSE_FLORIPA_INSCRICAO_MUNICIPAL=
# NFSE_FLORIPA_CODIGO_MUNICIPIO=4205407
# NFSE_FLORIPA_CERT_PATH=
# NFSE_FLORIPA_CERT_PASSWORD=
# NFSE_FLORIPA_ENVIRONMENT=hom
# NFSE_FLORIPA_CODIGO_SERVICO=1.05
# NFSE_FLORIPA_ALIQUOTA_ISS=2.5

# ─── S2S ────────────────────────────────────────────────────────────────────
# Chave de segurança para chamadas internas entre microserviços
CHAVE_INTERNA_SERVICO=develop-internal-key

# ─── Serviços de Plataforma ─────────────────────────────────────────────────
GABI_SERVICE_URL=http://localhost:8009
