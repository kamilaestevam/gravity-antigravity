{
    "name": "gravity-configurador",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "tsx watch --env-file=../../.env.local --env-file=.env server/index.ts",
        "dev:client": "vite",
        "dev:full": "tsx watch --env-file=../../.env.local --env-file=.env server/index.ts & vite & wait",
        "start": "node dist/server/index.js",
        "typecheck": "tsc --noEmit",
        "prisma:generate": "prisma generate --schema=../../configurador/prisma/schema.prisma",
        "prisma:migrate": "prisma migrate dev --schema=../../configurador/prisma/schema.prisma",
        "prisma:studio": "prisma studio --schema=../../configurador/prisma/schema.prisma",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@clerk/clerk-react": "^5.61.4",
        "@clerk/clerk-sdk-node": "^5.0.0",
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@google/generative-ai": "^0.21.0",
        "@phosphor-icons/react": "^2.1.10",
        "@prisma/client": "^5.13.0",
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "exceljs": "^4.4.0",
        "express": "^4.19.0",
        "i18next": "^26.0.1",
        "jspdf": "^4.2.1",
        "jspdf-autotable": "^5.0.7",
        "lucide-react": "^1.7.0",
        "react": "^18.3.0",
        "react-dom": "^18.3.0",
        "react-i18next": "^17.0.1",
        "react-router-dom": "^6.30.3",
        "svix": "^1.15.0",
        "xlsx": "^0.18.5",
        "zod": "^3.23.0",
        "zustand": "^5.0.12"
    },
    "devDependencies": {
        "@types/cors": "^2.8.19",
        "@types/express": "^4.17.21",
        "@types/node": "^20.0.0",
        "@types/react": "^18.3.0",
        "@types/react-dom": "^18.3.0",
        "@types/supertest": "^7.2.0",
        "@vitejs/plugin-react": "^4.7.0",
        "prisma": "^5.13.0",
        "supertest": "^7.2.2",
        "tsx": "^4.11.0",
        "typescript": "^5.4.0",
        "vite": "^5.4.21",
        "vitest": "^1.6.1"
    }
}
