{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "paths": {
      "@nucleo/botao-global": ["../../nucleo-global/botao-global/src/index.ts"],
      "@nucleo/tabela-global": ["../../nucleo-global/tabela-global/src/index.ts"],
      "@nucleo/utils": ["../../nucleo-global/utils/src/index.ts"],
      "@nucleo/*": ["../../nucleo-global/*/src/index.ts"],
      "@tenant/*": ["../tenant/*"],
      "@produto/*": ["../produto/*"]
    }
  },
  "include": [
    "src/**/*",
    "server/**/*",
    "../../nucleo-global/botao-global/src/**/*",
    "../../nucleo-global/tabela-global/src/**/*",
    "../../nucleo-global/utils/src/**/*",
    "../../nucleo-global/stat-card-global/src/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}

