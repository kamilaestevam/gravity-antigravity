# ============================================================
# servicos-global/marketplace — .env.example
# Copie para .env e preencha com os valores reais.
# NUNCA commite o arquivo .env com valores reais.
# Versões: T26000001 (Staging) / P26000001 (Produção)
# ============================================================

# --- Autenticação (Clerk — Público) ---
# Usada no frontend Next.js do Marketplace
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# --- URL do Configurador ---
# Staging: URL pública do Configurador no Railway (T26000001)
# Produção: URL pública do Configurador no Railway (P26000001)
NEXT_PUBLIC_CONFIGURATOR_URL=https://configurador-staging.railway.app
CONFIGURATOR_INTERNAL_URL=http://configurador.railway.internal:3000

# --- Ambiente ---
# Valores: development | staging | production
NODE_ENV=development
PORT=3000

# --- Observabilidade ---
NEXT_PUBLIC_SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project_id>
SENTRY_AUTH_TOKEN=...
