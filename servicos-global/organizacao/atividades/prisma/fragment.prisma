// servicos-global/tenant/atividades/prisma/fragment.prisma
// AGENTE ATIVIDADES — Minhas Atividades (Tasks Board)
//
// Fragment Prisma para o serviço de Atividades — portado do Journey tasks-board.
// Suporta Kanban (4 colunas), drag-and-drop, timer, participantes e vínculo a processo.
// Não editar o schema.prisma final — apenas este fragment.
// O Coordenador compõe o schema via scripts/ativamente/compose-tenant-schema.ts.

// ---------------------------------------------------------------------------
// AtividadesDados — tarefas e interações cross-produto do usuário logado
// ---------------------------------------------------------------------------

model AtividadesDados {
  id_atividades_dados             String  @id @default(cuid())
  id_organizacao_atividades_dados String
  id_usuario_atividades_dados     String? // criador da atividade

  // Conteúdo
  titulo_atividades_dados    String
  descricao_atividades_dados String?

  // Tipo de atividade (igual ao Journey)
  // Valores: "Comentário" | "Reunião" | "Chamados HD" | "Chamados CS" | "Ação necessária" | "Tarefa" | "Outros"
  tipo_atividades_dados String @default("Tarefa")

  // Status Kanban (colunas do board)
  // Valores: "A Fazer" | "Em Andamento" | "Concluída" | "Cancelada"
  status_atividades_dados String @default("A Fazer")

  // Prioridade
  // Valores: "baixa" | "média" | "alta" | "urgente"
  prioridade_atividades_dados String?

  // Temporal
  data_atividade_atividades_dados  DateTime?
  data_vencimento_atividades_dados DateTime?

  // Tempo trabalhado (acumulado de todas as sessões)
  tempo_gasto_minutos_atividades_dados Int @default(0)

  // Próximo passo
  proximo_passo_titulo_atividades_dados String?
  proximo_passo_data_atividades_dados   DateTime?

  // Lembrete
  lembrete_em_atividades_dados       DateTime?
  lembrete_email_atividades_dados    Boolean @default(false)
  lembrete_whatsapp_atividades_dados Boolean @default(false)

  // Notificação ao atribuir
  notificar_ao_atribuir_atividades_dados Boolean @default(false)

  // Vínculos opcionais
  id_processo_atividades_dados String? // link opcional a um Processo Comex (para navegar)

  // Metadados
  data_criacao_atividades_dados    DateTime @default(now())
  data_atualizacao_atividades_dados DateTime @updatedAt

  // Relações
  participantes_atividades_dados UsuariosAtividades[]
  sessoes_timer_atividades_dados UsuariosAtividadesTempo[]

  @@index([id_organizacao_atividades_dados], map: "ad_org_idx")
  @@index([id_organizacao_atividades_dados, id_usuario_atividades_dados], map: "ad_org_user_idx")
  @@index([id_organizacao_atividades_dados, status_atividades_dados], map: "ad_org_status_idx")
  @@map("atividades_dados")
}

// ---------------------------------------------------------------------------
// UsuariosAtividades — usuários atribuídos à atividade (M2M)
// ---------------------------------------------------------------------------

model UsuariosAtividades {
  id_atividades_participantes              String  @id @default(cuid())
  id_atividades_dados_atividades_participantes String
  id_usuario_atividades_participantes      String
  nome_usuario_atividades_participantes    String? // cache de nome para exibição sem JOIN extra

  atividade_atividades_participantes AtividadesDados @relation(fields: [id_atividades_dados_atividades_participantes], references: [id_atividades_dados], onDelete: Cascade)

  @@unique([id_atividades_dados_atividades_participantes, id_usuario_atividades_participantes], map: "ap_atv_user_unq")
  @@index([id_atividades_dados_atividades_participantes], map: "ap_atv_idx")
  @@map("atividades_participantes")
}

// ---------------------------------------------------------------------------
// UsuariosAtividadesTempo — sessões do cronômetro registradas
// ---------------------------------------------------------------------------

model UsuariosAtividadesTempo {
  id_atividades_tempo              String   @id @default(cuid())
  id_atividades_dados_atividades_tempo String
  iniciado_em_atividades_tempo     DateTime
  duracao_min_atividades_tempo     Int
  assunto_atividades_tempo         String?

  atividade_atividades_tempo AtividadesDados @relation(fields: [id_atividades_dados_atividades_tempo], references: [id_atividades_dados], onDelete: Cascade)

  @@index([id_atividades_dados_atividades_tempo], map: "at_atv_idx")
  @@map("atividades_tempo")
}
