// ---------------------------------------------------------------------------
// AtividadesCronometro
// Sessão de tempo registrada (concluída ou manual).
// ---------------------------------------------------------------------------

model AtividadesCronometro {
  id_atividades_cronometro             String  @id @default(cuid())

  // Campos de isolamento — obrigatórios
  id_organizacao_atividades_cronometro String
  id_produto_atividades_cronometro     String?
  id_usuario_atividades_cronometro     String

  // Relacionamento
  id_atividade_atividades_cronometro   String

  // Dados da sessão
  data_inicio_atividades_cronometro    DateTime
  data_fim_atividades_cronometro       DateTime?
  duracao_minutos_atividades_cronometro Int?     // null = timer ainda ativo (em progresso)
  manual_atividades_cronometro         Boolean  @default(false)

  // Assunto e vínculo
  assunto_atividades_cronometro        String?  // texto livre do assunto
  tipo_vinculo_atividades_cronometro   String?  // nf | meeting | process | custom
  id_vinculo_atividades_cronometro     String?  // ID do item vinculado
  rotulo_vinculo_atividades_cronometro String?  // label de exibição do item vinculado

  // Timestamps
  data_criacao_atividades_cronometro     DateTime @default(now())
  data_atualizacao_atividades_cronometro DateTime @updatedAt

  // Índices obrigatórios — padrão do projeto
  @@index([id_organizacao_atividades_cronometro], map: "ac_org_idx")
  @@index([id_organizacao_atividades_cronometro, id_produto_atividades_cronometro], map: "ac_org_prd_idx")
  @@index([id_organizacao_atividades_cronometro, id_usuario_atividades_cronometro], map: "ac_org_usr_idx")
  @@index([id_organizacao_atividades_cronometro, id_usuario_atividades_cronometro, data_inicio_atividades_cronometro], map: "ac_org_usr_dt_idx")
  @@index([id_organizacao_atividades_cronometro, id_atividade_atividades_cronometro], map: "ac_org_atv_idx")
  @@map("atividades_cronometro")
}

// ---------------------------------------------------------------------------
// AtividadesTimer
// Estado do timer em execução (um por usuário).
// Removido quando a sessão é finalizada — o histórico fica em AtividadesCronometro.
// ---------------------------------------------------------------------------

model AtividadesTimer {
  id_atividades_timer                  String  @id @default(cuid())

  // Campos de isolamento
  id_organizacao_atividades_timer      String
  id_usuario_atividades_timer          String  @unique(map: "atm_usr_unq") // um timer ativo por usuário

  // Relacionamento
  id_atividade_atividades_timer        String

  // Estado do timer
  data_inicio_atividades_timer         DateTime
  data_pausa_atividades_timer          DateTime?
  segundos_acumulados_atividades_timer Int      @default(0) // segundos acumulados antes de pausas

  // Timestamps
  data_criacao_atividades_timer        DateTime @default(now())
  data_atualizacao_atividades_timer    DateTime @updatedAt

  // Índices obrigatórios
  @@index([id_organizacao_atividades_timer], map: "atm_org_idx")
  @@index([id_organizacao_atividades_timer, id_usuario_atividades_timer], map: "atm_org_usr_idx")
  @@index([id_usuario_atividades_timer], map: "atm_usr_idx")
  @@map("atividades_timer")
}

// ---------------------------------------------------------------------------
// TempoCriacaoRelatorio
// Cache de relatórios de tempo pré-computados para performance.
// ---------------------------------------------------------------------------

model TempoCriacaoRelatorio {
  id_tempo_criacao_relatorio             String @id @default(cuid())

  id_organizacao_tempo_criacao_relatorio String
  id_usuario_tempo_criacao_relatorio     String?
  id_produto_tempo_criacao_relatorio     String?

  periodo_inicio_tempo_criacao_relatorio DateTime
  periodo_fim_tempo_criacao_relatorio    DateTime
  total_minutos_tempo_criacao_relatorio  Int
  payload_tempo_criacao_relatorio        String  // JSON serializado com breakdown por atividade

  data_computacao_tempo_criacao_relatorio DateTime @default(now())
  data_expiracao_tempo_criacao_relatorio  DateTime

  @@index([id_organizacao_tempo_criacao_relatorio], map: "tcr_org_idx")
  @@index([id_organizacao_tempo_criacao_relatorio, id_produto_tempo_criacao_relatorio], map: "tcr_org_prd_idx")
  @@index([id_organizacao_tempo_criacao_relatorio, id_usuario_tempo_criacao_relatorio], map: "tcr_org_usr_idx")
  @@index([id_organizacao_tempo_criacao_relatorio, periodo_inicio_tempo_criacao_relatorio, periodo_fim_tempo_criacao_relatorio], map: "tcr_org_per_idx")
  @@map("tempo_criacao_relatorio")
}
