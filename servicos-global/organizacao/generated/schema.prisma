// --- Fragment: atividades ---
// servicos-global/tenant/atividades/prisma/fragment.prisma
// AGENTE ATIVIDADES — Minhas Atividades (Tasks Board)
//
// Fragment Prisma para o serviço de Atividades — portado do Journey tasks-board.
// Suporta Kanban (4 colunas), drag-and-drop, timer, participantes e vínculo a processo.
// Não editar o schema.prisma final — apenas este fragment.
// O Coordenador compõe o schema via scripts/ativamente/compose-tenant-schema.ts.

// ---------------------------------------------------------------------------
// AtividadesDados — tarefas e interações cross-produto do usuário logado
// ---------------------------------------------------------------------------

model AtividadesDados {
  id_atividades_dados             String  @id @default(cuid())
  id_organizacao_atividades_dados String
  id_usuario_atividades_dados     String? // criador da atividade

  // Conteúdo
  titulo_atividades_dados    String
  descricao_atividades_dados String?

  // Tipo de atividade (igual ao Journey)
  // Valores: "Comentário" | "Reunião" | "Chamados HD" | "Chamados CS" | "Ação necessária" | "Tarefa" | "Outros"
  tipo_atividades_dados String @default("Tarefa")

  // Status Kanban (colunas do board)
  // Valores: "A Fazer" | "Em Andamento" | "Concluída" | "Cancelada"
  status_atividades_dados String @default("A Fazer")

  // Prioridade
  // Valores: "baixa" | "média" | "alta" | "urgente"
  prioridade_atividades_dados String?

  // Temporal
  data_atividade_atividades_dados  DateTime?
  data_vencimento_atividades_dados DateTime?

  // Tempo trabalhado (acumulado de todas as sessões)
  tempo_gasto_minutos_atividades_dados Int @default(0)

  // Próximo passo
  proximo_passo_titulo_atividades_dados String?
  proximo_passo_data_atividades_dados   DateTime?

  // Lembrete
  lembrete_em_atividades_dados       DateTime?
  lembrete_email_atividades_dados    Boolean   @default(false)
  lembrete_whatsapp_atividades_dados Boolean   @default(false)

  // Notificação ao atribuir
  notificar_ao_atribuir_atividades_dados Boolean @default(false)

  // Vínculos opcionais
  id_processo_atividades_dados String? // link opcional a um Processo Comex (para navegar)

  // Metadados
  data_criacao_atividades_dados     DateTime @default(now())
  data_atualizacao_atividades_dados DateTime @updatedAt

  // Relações
  participantes_atividades_dados UsuariosAtividades[]
  sessoes_timer_atividades_dados UsuariosAtividadesTempo[]

  @@index([id_organizacao_atividades_dados], map: "ad_org_idx")
  @@index([id_organizacao_atividades_dados, id_usuario_atividades_dados], map: "ad_org_user_idx")
  @@index([id_organizacao_atividades_dados, status_atividades_dados], map: "ad_org_status_idx")
  @@map("atividades_dados")
}

// ---------------------------------------------------------------------------
// UsuariosAtividades — usuários atribuídos à atividade (M2M)
// ---------------------------------------------------------------------------

model UsuariosAtividades {
  id_atividades_participantes                  String  @id @default(cuid())
  id_atividades_dados_atividades_participantes String
  id_usuario_atividades_participantes          String
  nome_usuario_atividades_participantes        String? // cache de nome para exibição sem JOIN extra

  atividade_atividades_participantes AtividadesDados @relation(fields: [id_atividades_dados_atividades_participantes], references: [id_atividades_dados], onDelete: Cascade)

  @@unique([id_atividades_dados_atividades_participantes, id_usuario_atividades_participantes], map: "ap_atv_user_unq")
  @@index([id_atividades_dados_atividades_participantes], map: "ap_atv_idx")
  @@map("atividades_participantes")
}

// ---------------------------------------------------------------------------
// UsuariosAtividadesTempo — sessões do cronômetro registradas
// ---------------------------------------------------------------------------

model UsuariosAtividadesTempo {
  id_atividades_tempo                  String   @id @default(cuid())
  id_atividades_dados_atividades_tempo String
  iniciado_em_atividades_tempo         DateTime
  duracao_min_atividades_tempo         Int
  assunto_atividades_tempo             String?

  atividade_atividades_tempo AtividadesDados @relation(fields: [id_atividades_dados_atividades_tempo], references: [id_atividades_dados], onDelete: Cascade)

  @@index([id_atividades_dados_atividades_tempo], map: "at_atv_idx")
  @@map("atividades_tempo")
}

// --- Fragment: cronometro ---
// servicos-global/tenant/cronometro/prisma/fragment.prisma
// AGENTE CRONÔMETRO — ONDA 27 (DDD Servicos)
//
// Fragment Prisma do serviço de Cronômetro.
// Não editar schema.prisma diretamente — apenas este fragment.
// O Coordenador compõe o schema final via scripts/ativamente/compose-tenant-schema.ts

// ---------------------------------------------------------------------------
// UsuarioHistoricoCronometro
// Sessão de tempo registrada (concluída ou manual).
// ---------------------------------------------------------------------------

model UsuarioHistoricoCronometro {
  id_atividades_cronometro String @id @default(cuid())

  // Campos de isolamento — obrigatórios
  id_organizacao_atividades_cronometro String
  id_produto_atividades_cronometro     String?
  id_usuario_atividades_cronometro     String

  // Relacionamento
  id_atividade_atividades_cronometro String

  // Dados da sessão
  data_inicio_atividades_cronometro     DateTime
  data_fim_atividades_cronometro        DateTime?
  duracao_minutos_atividades_cronometro Int? // null = timer ainda ativo (em progresso)
  manual_atividades_cronometro          Boolean   @default(false)

  // Assunto e vínculo
  assunto_atividades_cronometro        String? // texto livre do assunto
  tipo_vinculo_atividades_cronometro   String? // nf | meeting | process | custom
  id_vinculo_atividades_cronometro     String? // ID do item vinculado
  rotulo_vinculo_atividades_cronometro String? // label de exibição do item vinculado

  // Timestamps
  data_criacao_atividades_cronometro     DateTime @default(now())
  data_atualizacao_atividades_cronometro DateTime @updatedAt

  // Índices obrigatórios — padrão do projeto
  @@index([id_organizacao_atividades_cronometro], map: "ac_org_idx")
  @@index([id_organizacao_atividades_cronometro, id_produto_atividades_cronometro], map: "ac_org_prd_idx")
  @@index([id_organizacao_atividades_cronometro, id_usuario_atividades_cronometro], map: "ac_org_usr_idx")
  @@index([id_organizacao_atividades_cronometro, id_usuario_atividades_cronometro, data_inicio_atividades_cronometro], map: "ac_org_usr_dt_idx")
  @@index([id_organizacao_atividades_cronometro, id_atividade_atividades_cronometro], map: "ac_org_atv_idx")
  @@map("atividades_cronometro")
}

// ---------------------------------------------------------------------------
// UsuarioStatusCronometro
// Estado do timer em execução (um por usuário).
// Removido quando a sessão é finalizada — o histórico fica em UsuarioHistoricoCronometro.
// ---------------------------------------------------------------------------

model UsuarioStatusCronometro {
  id_atividades_timer String @id @default(cuid())

  // Campos de isolamento
  id_organizacao_atividades_timer String
  id_usuario_atividades_timer     String @unique(map: "atm_usr_unq") // um timer ativo por usuário

  // Relacionamento
  id_atividade_atividades_timer String

  // Estado do timer
  data_inicio_atividades_timer         DateTime
  data_pausa_atividades_timer          DateTime?
  segundos_acumulados_atividades_timer Int       @default(0) // segundos acumulados antes de pausas

  // Timestamps
  data_criacao_atividades_timer     DateTime @default(now())
  data_atualizacao_atividades_timer DateTime @updatedAt

  // Índices obrigatórios
  @@index([id_organizacao_atividades_timer], map: "atm_org_idx")
  @@index([id_organizacao_atividades_timer, id_usuario_atividades_timer], map: "atm_org_usr_idx")
  @@index([id_usuario_atividades_timer], map: "atm_usr_idx")
  @@map("atividades_timer")
}

// ---------------------------------------------------------------------------
// RelatorioTempoPeriodo
// Cache de relatórios de tempo pré-computados para performance.
// ---------------------------------------------------------------------------

model RelatorioTempoPeriodo {
  id_tempo_criacao_relatorio String @id @default(cuid())

  id_organizacao_tempo_criacao_relatorio String
  id_usuario_tempo_criacao_relatorio     String?
  id_produto_tempo_criacao_relatorio     String?

  periodo_inicio_tempo_criacao_relatorio DateTime
  periodo_fim_tempo_criacao_relatorio    DateTime
  total_minutos_tempo_criacao_relatorio  Int
  payload_tempo_criacao_relatorio        String // JSON serializado com breakdown por atividade

  data_computacao_tempo_criacao_relatorio DateTime @default(now())
  data_expiracao_tempo_criacao_relatorio  DateTime

  @@index([id_organizacao_tempo_criacao_relatorio], map: "tcr_org_idx")
  @@index([id_organizacao_tempo_criacao_relatorio, id_produto_tempo_criacao_relatorio], map: "tcr_org_prd_idx")
  @@index([id_organizacao_tempo_criacao_relatorio, id_usuario_tempo_criacao_relatorio], map: "tcr_org_usr_idx")
  @@index([id_organizacao_tempo_criacao_relatorio, periodo_inicio_tempo_criacao_relatorio, periodo_fim_tempo_criacao_relatorio], map: "tcr_org_per_idx")
  @@map("tempo_criacao_relatorio")
}

// --- Fragment: email ---
// servicos-global/tenant/email/prisma/fragment.prisma
// AGENTE EMAIL — ONDA 28 (DDD Servicos)
//
// Fragment Prisma para o serviço de Email (envio Resend, templates, histórico).
// Não editar o schema.prisma final — apenas este fragment.
// O Coordenador compõe o schema via scripts/ativamente/compose-tenant-schema.ts.

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum EmailStatus {
  PENDENTE
  PROCESSANDO
  ENVIADO
  FALHOU
  CANCELADO
}

enum EmailDirecao {
  RECEBIDO
  ENVIADO
}

enum EmailThreadAtiva {
  ABERTA
  ARQUIVADA
  RESOLVIDA
}

enum EmailSentimento {
  MUITO_POSITIVO
  POSITIVO
  NEUTRO
  NEGATIVO
  MUITO_NEGATIVO
}

enum EmailFilaPrioridade {
  BAIXA
  NORMAL
  ALTA
  URGENTE
}

// ---------------------------------------------------------------------------
// EmailAssuntosParticipantes — thread de conversa (agrupa mensagens de ida e volta)
// ---------------------------------------------------------------------------

model EmailAssuntosParticipantes {
  id_email_assuntos_participantes             String  @id @default(cuid())
  id_organizacao_email_assuntos_participantes String
  id_produto_email_assuntos_participantes     String?
  id_usuario_email_assuntos_participantes     String?

  assunto_email_assuntos_participantes            String
  status_email_assuntos_participantes             EmailThreadAtiva @default(ABERTA)
  sentimento_email_assuntos_participantes         Float            @default(0) // -1 a 1
  rotulo_sentimento_email_assuntos_participantes  EmailSentimento  @default(NEUTRO)
  contagem_mensagens_email_assuntos_participantes Int              @default(0)
  ultimo_contato_email_assuntos_participantes     DateTime?
  deep_link_email_assuntos_participantes          String? // ex: /email/thread/{id}

  data_criacao_email_assuntos_participantes     DateTime @default(now())
  data_atualizacao_email_assuntos_participantes DateTime @updatedAt

  mensagens_email_assuntos_participantes EmailMensagem[]

  @@index([id_organizacao_email_assuntos_participantes], map: "eap_org_idx")
  @@index([id_organizacao_email_assuntos_participantes, id_produto_email_assuntos_participantes], map: "eap_org_prd_idx")
  @@index([id_organizacao_email_assuntos_participantes, id_usuario_email_assuntos_participantes], map: "eap_org_usr_idx")
  @@map("email_assuntos_participantes")
}

// ---------------------------------------------------------------------------
// EmailMensagem — mensagem individual (inbound ou outbound)
// ---------------------------------------------------------------------------

model EmailMensagem {
  id_email_mensagem             String  @id @default(cuid())
  id_organizacao_email_mensagem String
  id_produto_email_mensagem     String?
  id_usuario_email_mensagem     String?

  id_thread_email_mensagem String
  thread_email_mensagem    EmailAssuntosParticipantes @relation(fields: [id_thread_email_mensagem], references: [id_email_assuntos_participantes])

  id_resend_email_mensagem       String?      @unique(map: "em_resend_unq")
  direcao_email_mensagem         EmailDirecao @default(ENVIADO)
  remetente_email_mensagem       String
  destinatario_email_mensagem    String
  assunto_email_mensagem         String?
  corpo_email_mensagem           String       @db.Text
  corpo_html_email_mensagem      String?      @db.Text
  chave_dedup_email_mensagem     String?      @unique(map: "em_dedup_unq")
  id_mensagem_pai_email_mensagem String?

  // Análise Gabi
  resposta_gabi_email_mensagem  String? @db.Text
  confianca_gabi_email_mensagem Float?
  acao_gabi_email_mensagem      String? // auto_replied | escalated_to_human | none

  data_envio_email_mensagem       DateTime @default(now())
  data_criacao_email_mensagem     DateTime @default(now())
  data_atualizacao_email_mensagem DateTime @updatedAt

  @@index([id_organizacao_email_mensagem], map: "em_org_idx")
  @@index([id_organizacao_email_mensagem, id_produto_email_mensagem], map: "em_org_prd_idx")
  @@index([id_organizacao_email_mensagem, id_usuario_email_mensagem], map: "em_org_usr_idx")
  @@index([id_thread_email_mensagem], map: "em_thread_idx")
  @@index([chave_dedup_email_mensagem], map: "em_dedup_idx")
  @@map("email_mensagem")
}

// ---------------------------------------------------------------------------
// EmailRegistroEnvio — log de todos os envios realizados (auditoria completa)
// ---------------------------------------------------------------------------

model EmailRegistroEnvio {
  id_email_registro_envio             String  @id @default(cuid())
  id_organizacao_email_registro_envio String
  id_produto_email_registro_envio     String?
  id_usuario_email_registro_envio     String?

  destinatario_email_registro_envio String
  remetente_email_registro_envio    String
  reply_to_email_registro_envio     String?
  assunto_email_registro_envio      String
  id_template_email_registro_envio  String?
  status_email_registro_envio       EmailStatus @default(PENDENTE)
  id_resend_email_registro_envio    String?     @unique(map: "ere_resend_unq")
  chave_dedup_email_registro_envio  String      @unique(map: "ere_dedup_unq")

  tentativas_email_registro_envio           Int       @default(0)
  max_tentativas_email_registro_envio       Int       @default(5)
  proxima_tentativa_em_email_registro_envio DateTime?
  mensagem_erro_email_registro_envio        String?   @db.Text
  data_envio_email_registro_envio           DateTime?

  data_criacao_email_registro_envio     DateTime @default(now())
  data_atualizacao_email_registro_envio DateTime @updatedAt

  @@index([id_organizacao_email_registro_envio], map: "ere_org_idx")
  @@index([id_organizacao_email_registro_envio, id_produto_email_registro_envio], map: "ere_org_prd_idx")
  @@index([id_organizacao_email_registro_envio, id_usuario_email_registro_envio], map: "ere_org_usr_idx")
  @@index([status_email_registro_envio], map: "ere_status_idx")
  @@index([chave_dedup_email_registro_envio], map: "ere_dedup_idx")
  @@map("email_registro_envio")
}

// ---------------------------------------------------------------------------
// EmailTemplate — templates de email editáveis por tenant
// ---------------------------------------------------------------------------

model EmailTemplate {
  id_template_email             String  @id @default(cuid())
  id_organizacao_template_email String
  id_produto_template_email     String?
  id_usuario_template_email     String?

  nome_template_email        String
  slug_template_email        String // ex: boas-vindas, recuperacao-senha
  assunto_template_email     String
  corpo_html_template_email  String   @db.Text
  corpo_texto_template_email String?  @db.Text
  variaveis_template_email   String[] // ex: ["nome", "plano", "url"]
  ativo_template_email       Boolean  @default(true)
  descricao_template_email   String?

  data_criacao_template_email     DateTime @default(now())
  data_atualizacao_template_email DateTime @updatedAt

  @@unique([id_organizacao_template_email, slug_template_email], map: "te_org_slug_unq")
  @@index([id_organizacao_template_email], map: "te_org_idx")
  @@index([id_organizacao_template_email, id_produto_template_email], map: "te_org_prd_idx")
  @@index([id_organizacao_template_email, id_usuario_template_email], map: "te_org_usr_idx")
  @@map("template_email")
}

// ---------------------------------------------------------------------------
// EmailFilaEnvio — fila de envio com controle de retry e backoff exponencial
// ---------------------------------------------------------------------------

model EmailFilaEnvio {
  id_email_fila_envio             String  @id @default(cuid())
  id_organizacao_email_fila_envio String
  id_produto_email_fila_envio     String?
  id_usuario_email_fila_envio     String?

  status_email_fila_envio           EmailStatus         @default(PENDENTE)
  prioridade_email_fila_envio       EmailFilaPrioridade @default(NORMAL)
  payload_email_fila_envio          String              @db.Text // JSON: { to, subject, body, ... }
  id_template_email_fila_envio      String?
  id_email_enviado_email_fila_envio String?

  tentativas_email_fila_envio           Int       @default(0)
  max_tentativas_email_fila_envio       Int       @default(5)
  proxima_tentativa_em_email_fila_envio DateTime?
  processado_em_email_fila_envio        DateTime?
  erro_email_fila_envio                 String?   @db.Text

  data_criacao_email_fila_envio     DateTime @default(now())
  data_atualizacao_email_fila_envio DateTime @updatedAt

  @@index([id_organizacao_email_fila_envio], map: "efe_org_idx")
  @@index([id_organizacao_email_fila_envio, id_produto_email_fila_envio], map: "efe_org_prd_idx")
  @@index([id_organizacao_email_fila_envio, id_usuario_email_fila_envio], map: "efe_org_usr_idx")
  @@index([status_email_fila_envio, proxima_tentativa_em_email_fila_envio], map: "efe_status_retry_idx")
  @@index([id_organizacao_email_fila_envio, status_email_fila_envio], map: "efe_org_status_idx")
  @@map("email_fila_envio")
}

