// --- Fragment: ncm-sync ---
// servicos-global/tenant/ncm-sync/prisma/fragment.prisma
// SERVIÇO NCM-SYNC — ONDA 36 (DDD Servicos)
//
// NcmItem         — tabela NCM cacheada do Portal Único Siscomex (atualizada diariamente)
// NcmLog          — histórico de cada sincronização com o Portal Único
// NCMAgendamento  — configuração singleton do job de sincronização

// ---------------------------------------------------------------------------
// NcmItem
// ---------------------------------------------------------------------------

model NcmItem {
  id_ncm_item String @id @default(cuid())

  // Identificação tenant
  id_organizacao_ncm_item String
  id_produto_ncm_item     String?
  id_usuario_ncm_item     String?

  // Dados NCM
  codigo_ncm_item    String // 8 dígitos — ex: "84713019"
  descricao_ncm_item String
  ativo_ncm_item     Boolean @default(true)

  // Metadados do Portal Único
  data_inicio_ncm_item DateTime?
  data_fim_ncm_item    DateTime?

  // Referência ao NcmLog que inseriu/atualizou este item
  id_sincronizacao_ncm_item String

  // Timestamps
  data_criacao_ncm_item     DateTime @default(now())
  data_atualizacao_ncm_item DateTime @updatedAt

  @@unique([id_organizacao_ncm_item, codigo_ncm_item], map: "ni_unq_org_codigo")
  @@index([id_organizacao_ncm_item], map: "ni_org_idx")
  @@index([id_organizacao_ncm_item, id_produto_ncm_item], map: "ni_org_prd_idx")
  @@index([id_organizacao_ncm_item, id_usuario_ncm_item], map: "ni_org_usr_idx")
  @@index([id_organizacao_ncm_item, ativo_ncm_item], map: "ni_org_ativo_idx")
  @@index([id_organizacao_ncm_item, codigo_ncm_item], map: "ni_org_codigo_idx")
  @@map("ncm_item")
}

// ---------------------------------------------------------------------------
// NcmLog — histórico de sincronização
// ---------------------------------------------------------------------------

model NcmLog {
  id_ncm_log String @id @default(cuid())

  // Identificação tenant
  id_organizacao_ncm_log String
  id_produto_ncm_log     String?
  id_usuario_ncm_log     String?

  // Timestamps de execução
  data_inicio_ncm_log    DateTime  @default(now())
  data_conclusao_ncm_log DateTime?

  // Status (enum PT)
  status_ncm_log NCMStatusSincronizacao @default(EXECUTANDO)

  // Totais do diff
  total_ncm_log       Int @default(0)
  adicionados_ncm_log Int @default(0)
  alterados_ncm_log   Int @default(0)
  removidos_ncm_log   Int @default(0)

  // Origem do trigger
  origem_ncm_log        NCMOrigemSincronizacao @default(JOB)
  disparado_por_ncm_log String? // user_id se MANUAL

  // Erro (apenas em caso de falha)
  mensagem_erro_ncm_log String?

  // Timestamps
  data_criacao_ncm_log     DateTime @default(now())
  data_atualizacao_ncm_log DateTime @updatedAt

  @@index([id_organizacao_ncm_log], map: "nl_org_idx")
  @@index([id_organizacao_ncm_log, id_produto_ncm_log], map: "nl_org_prd_idx")
  @@index([id_organizacao_ncm_log, id_usuario_ncm_log], map: "nl_org_usr_idx")
  @@index([id_organizacao_ncm_log, status_ncm_log], map: "nl_org_status_idx")
  @@index([id_organizacao_ncm_log, data_inicio_ncm_log], map: "nl_org_inicio_idx")
  @@map("ncm_log")
}

// ---------------------------------------------------------------------------
// NCMAgendamento — configuração singleton do job de sincronização
// id = 'default' — registro único (singleton global)
// id_organizacao_ncm_agendamento = '__system__' — satisfaz padrão de índices
// ---------------------------------------------------------------------------

model NCMAgendamento {
  id_ncm_agendamento             String  @id @default("default")
  id_organizacao_ncm_agendamento String  @default("__system__")
  id_produto_ncm_agendamento     String?
  id_usuario_ncm_agendamento     String?

  ativo_ncm_agendamento          Boolean @default(false)
  cron_expressao_ncm_agendamento String  @default("0 2 * * *") // 2am diário (America/Sao_Paulo)
  notificadores_ncm_agendamento  Json    @default("[]") // Array<NcmNotificador>

  data_criacao_ncm_agendamento     DateTime @default(now())
  data_atualizacao_ncm_agendamento DateTime @updatedAt

  @@index([id_organizacao_ncm_agendamento], map: "nag_org_idx")
  @@index([id_organizacao_ncm_agendamento, id_produto_ncm_agendamento], map: "nag_org_prd_idx")
  @@index([id_organizacao_ncm_agendamento, id_usuario_ncm_agendamento], map: "nag_org_usr_idx")
  @@map("ncm_agendamento")
}

// ---------------------------------------------------------------------------
// Enums (valores em PT-BR)
// ---------------------------------------------------------------------------

enum NCMStatusSincronizacao {
  EXECUTANDO
  SUCESSO
  ERRO
}

enum NCMOrigemSincronizacao {
  JOB
  MANUAL
}

// --- Fragment: notificacoes ---
// servicos-global/tenant/notificacoes/prisma/fragment.prisma
// SERVIÇO NOTIFICACOES — ONDA 37 (DDD Servicos)
//
// NotificacoesTituloCorpo — sininho in-app + tracking de entrega (email/WhatsApp)
// ContatoExterno          — agenda externa por organização (LGPD Art. 8)
// ConfiguracaoCanalOrganizacao — toggle email/whatsapp por organização (master-only)

// ---------------------------------------------------------------------------
// NotificacoesTituloCorpo
// ---------------------------------------------------------------------------

model NotificacoesTituloCorpo {
  id_notificacoes_titulo_corpo String @id @default(cuid())

  // Identificação tenant
  id_organizacao_notificacoes_titulo_corpo String
  id_produto_notificacoes_titulo_corpo     String?
  id_usuario_notificacoes_titulo_corpo     String // destinatário (Clerk ID ou email)

  // Conteúdo
  tipo_notificacoes_titulo_corpo     String // mencao | tarefa | sistema | aviso | compartilhamento | enviado
  titulo_notificacoes_titulo_corpo   String?
  mensagem_notificacoes_titulo_corpo String

  // Estado (REGRA 5: sem prefixo is_/has_)
  lida_notificacoes_titulo_corpo Boolean @default(false)

  // Pilar 2 — link contextual (entidade + id, NUNCA URL)
  entidade_alvo_notificacoes_titulo_corpo String?
  id_alvo_notificacoes_titulo_corpo       String?

  // Pilar 3 — tracking de entrega
  // pending → sent → delivered | bounced | failed
  status_entrega_notificacoes_titulo_corpo String  @default("pending")
  id_externo_notificacoes_titulo_corpo     String? // Resend message id (para reconciliar webhooks)

  // Timestamps
  data_criacao_notificacoes_titulo_corpo     DateTime @default(now())
  data_atualizacao_notificacoes_titulo_corpo DateTime @updatedAt

  @@index([id_organizacao_notificacoes_titulo_corpo], map: "nt_org_idx")
  @@index([id_organizacao_notificacoes_titulo_corpo, id_produto_notificacoes_titulo_corpo], map: "nt_org_prd_idx")
  @@index([id_organizacao_notificacoes_titulo_corpo, id_usuario_notificacoes_titulo_corpo], map: "nt_org_usr_idx")
  @@index([id_organizacao_notificacoes_titulo_corpo, id_usuario_notificacoes_titulo_corpo, lida_notificacoes_titulo_corpo], map: "nt_org_usr_lida_idx")
  @@index([id_organizacao_notificacoes_titulo_corpo, data_criacao_notificacoes_titulo_corpo], map: "nt_org_data_idx")
  @@index([id_organizacao_notificacoes_titulo_corpo, status_entrega_notificacoes_titulo_corpo], map: "nt_org_status_idx")
  @@index([id_externo_notificacoes_titulo_corpo], map: "nt_externo_idx")
  @@map("notificacoes_titulo_corpo")
}

// ---------------------------------------------------------------------------
// ContatoExterno — agenda de contatos para envio externo (LGPD Art. 8)
// id_usuario_contato_externo: Clerk user_id que criou o contato
// ---------------------------------------------------------------------------

model ContatoExterno {
  id_contato_externo String @id @default(cuid())

  // Identificação tenant
  id_organizacao_contato_externo String
  id_produto_contato_externo     String?
  id_usuario_contato_externo     String // criador (Clerk user_id)

  // Dados do contato
  nome_contato_externo               String    @db.VarChar(200)
  email_contato_externo              String?   @db.VarChar(255)
  whatsapp_telefone_contato_externo  String?   @db.VarChar(20) // E.164: +5511999999999
  whatsapp_opt_in_em_contato_externo DateTime? // LGPD Art. 8 — consentimento explícito
  observacoes_contato_externo        String?   @db.VarChar(500)

  // Timestamps
  data_criacao_contato_externo     DateTime @default(now())
  data_atualizacao_contato_externo DateTime @updatedAt

  @@index([id_organizacao_contato_externo], map: "cex_org_idx")
  @@index([id_organizacao_contato_externo, id_produto_contato_externo], map: "cex_org_prd_idx")
  @@index([id_organizacao_contato_externo, id_usuario_contato_externo], map: "cex_org_usr_idx")
  @@index([id_organizacao_contato_externo, email_contato_externo], map: "cex_org_email_idx")
  @@index([id_organizacao_contato_externo, whatsapp_telefone_contato_externo], map: "cex_org_whats_idx")
  @@map("contato_externo")
}

// ---------------------------------------------------------------------------
// ConfiguracaoCanalOrganizacao — toggle email/whatsapp por organização (singleton por tenant)
// id_usuario_configuracao_canal_tenant: último master que alterou
// REGRA 5: booleans usam o adjetivo (habilitado), sem prefixo is_/has_
// ---------------------------------------------------------------------------

model ConfiguracaoCanalOrganizacao {
  id_configuracao_canal_tenant String @id @default(cuid())

  // Identificação tenant — único por organização
  id_organizacao_configuracao_canal_tenant String  @unique
  id_produto_configuracao_canal_tenant     String?
  id_usuario_configuracao_canal_tenant     String? // último master que atualizou

  // Toggles (REGRA 5)
  email_habilitado_configuracao_canal_tenant    Boolean @default(true)
  whatsapp_habilitado_configuracao_canal_tenant Boolean @default(false)

  // Timestamps
  data_criacao_configuracao_canal_tenant     DateTime @default(now())
  data_atualizacao_configuracao_canal_tenant DateTime @updatedAt

  @@index([id_organizacao_configuracao_canal_tenant], map: "cct_org_idx")
  @@index([id_organizacao_configuracao_canal_tenant, id_produto_configuracao_canal_tenant], map: "cct_org_prd_idx")
  @@index([id_organizacao_configuracao_canal_tenant, id_usuario_configuracao_canal_tenant], map: "cct_org_usr_idx")
  @@map("configuracao_canal_tenant")
}
