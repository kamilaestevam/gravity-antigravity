// FASE 06B — Modelos novos (snapshot Cadastros + config de atualização)
// Nomenclatura DDD aplicada: id_organizacao / id_workspace.
// (Modelos legados acima ainda usam tenant_id/company_id — renomeação massiva
// fica para sub-fase própria após a planilha DDD geral.)
// ============================================================================

/// Snapshot congelado de uma Empresa (importador / exportador / fabricante / agente
/// / despachante / armador) no momento da emissão ou re-snapshot do pedido.
/// Referência ao banco Cadastros via SUID lógico (sem FK física).
model PedidoSnapshotEmpresa {
  id_pedido_snapshot_empresa String   @id @default(cuid())
  id_organizacao        String
  id_workspace          String?
  id_pedido             String
  papel                 String   // 'importador' | 'exportador' | 'fabricante' | 'agente' | 'despachante' | 'armador'

  // Identidade
  suid_empresa          String   // referência lógica ao Cadastros (sem FK física)
  nome_empresa          String
  nome_fantasia         String?
  documento_principal_pedido_snapshot_empresa String   // CNPJ / EIN / VAT / TIN
  tipo_documento_pedido_snapshot_empresa      String   // 'CNPJ' | 'EIN' | 'VAT' | 'TIN' | etc.
  cnpj_raiz_pedido_snapshot_empresa           String?  // primeiros 8 dígitos do CNPJ — para empresas BR

  // Endereço
  endereco_logradouro   String?
  endereco_numero       String?
  endereco_complemento  String?
  endereco_bairro       String?
  endereco_cidade       String?
  endereco_uf           String?  // estado / província
  endereco_cep          String?  // zipcode
  endereco_pais         String?  // ISO-3166 alpha-2

  // Contato (principalmente exportador)
  contato_nome          String?
  contato_email         String?
  contato_whatsapp      String?
  contato_cargo         String?
  contato_departamento  String?

  // Relação Exportador <-> Fabricante (preenchido quando papel = exportador)
  exportador_e_fabricante      Boolean?
  relacao_exportador_fabricante String? // texto livre / enum a definir

  // Metadados do snapshot
  congelado_em          DateTime @default(now())
  motivo_congelamento   String   // 'emissao' | 'atualizacao_manual' | 'transicao_status'

  pedido                PedidoColunasGerais @relation(fields: [id_pedido], references: [id_pedido], onDelete: Cascade)

  @@index([id_organizacao])
  @@index([id_organizacao, id_pedido])
  @@index([id_organizacao, suid_empresa])
  @@index([id_organizacao, papel])
  @@map("pedido_snapshot_empresa")
}

/// Snapshot congelado da OPE (Operação) vinculada ao pedido,
/// sincronizada do banco Cadastros (que por sua vez vem do Portal Único).
model PedidoOpeSnapshot {
  id_pedido_snapshot_ope                String   @id @default(cuid())
  id_organizacao_pedido_snapshot_ope    String
  id_workspace_pedido_snapshot_ope      String?
  id_pedido_pedido_snapshot_ope         String

  // Identidade da OPE
  codigo_ope_pedido_snapshot_ope        String
  versao_ope_pedido_snapshot_ope        String?
  situacao_ope_pedido_snapshot_ope      String?
  nome_ope_pedido_snapshot_ope          String?
  cnpj_raiz_empresa_pedido_snapshot_ope String?

  // Endereço da OPE
  pais_ope_pedido_snapshot_ope     String?
  estado_ope_pedido_snapshot_ope   String?
  cidade_ope_pedido_snapshot_ope   String?
  endereco_ope_pedido_snapshot_ope String?
  zip_ope_pedido_snapshot_ope      String?
  tin_ope_pedido_snapshot_ope      String?
  email_ope_pedido_snapshot_ope    String?

  // Metadados
  congelado_em_pedido_snapshot_ope        DateTime @default(now())
  motivo_congelamento_pedido_snapshot_ope String

  acesso_pedido_snapshot_ope PedidoColunasGerais @relation(fields: [id_pedido_pedido_snapshot_ope], references: [id_pedido], onDelete: Cascade)

  @@index([id_organizacao_pedido_snapshot_ope])
  @@index([id_organizacao_pedido_snapshot_ope, id_pedido_pedido_snapshot_ope])
  @@index([id_organizacao_pedido_snapshot_ope, codigo_ope_pedido_snapshot_ope])
  @@map("pedido_snapshot_ope")
}

/// Política por workspace de quando re-snapshotar dados do Cadastros nos pedidos.
/// Usado pelo fluxo "atualização represada" e pelo banner retroativo (FASE 06E).
model PedidoCadastroSincronizador {
  id_politica_snapshot_cadastros String   @id @default(cuid())
  id_organizacao           String
  id_workspace             String

  // Política de atualização por papel (Empresa) — renomeado para "matriz" (json/booleano agregado)
  matriz_snapshot_politica_snapshot_cadastros  Boolean  @default(false)
  atualiza_exportador_politica_snapshot_cadastros  Boolean  @default(false)
  atualiza_fabricante_politica_snapshot_cadastros  Boolean  @default(false)
  atualiza_agente_politica_snapshot_cadastros      Boolean  @default(false)
  atualiza_despachante_politica_snapshot_cadastros Boolean  @default(false)
  atualiza_armador_politica_snapshot_cadastros     Boolean  @default(false)

  // Política de atualização da OPE
  atualiza_ope_politica_snapshot_cadastros         Boolean  @default(false)

  // Em quais transições de status re-snapshotar
  gatilho_emissao_politica_snapshot_cadastros      Boolean  @default(true)
  gatilho_embarque_politica_snapshot_cadastros     Boolean  @default(false)
  gatilho_desembaraco_politica_snapshot_cadastros  Boolean  @default(false)

  data_criacao_politica_snapshot_cadastros     DateTime @default(now())
  data_atualizacao_politica_snapshot_cadastros DateTime @updatedAt

  @@unique([id_organizacao, id_workspace])
  @@index([id_organizacao])
  @@map("pedido_config_atualizacao_cadastros")
}

