# Financeiro Comex — Variáveis de Ambiente
# Copie para .env e preencha os valores

# Servidor
PORT=8029
NODE_ENV=development

# Banco de dados (Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/gravity_financeiro_comex?schema=public"

# Segurança inter-serviços
CHAVE_INTERNA_SERVICO=troque-por-chave-segura

# Auth (Clerk)
CLERK_SECRET_KEY=sk_test_...

# URLs de outros serviços
CLIENT_URL=http://localhost:5184
CONFIGURATOR_URL=http://localhost:8001

# Serviços tenant
HISTORICO_URL=http://localhost:8014
NOTIFICACOES_URL=http://localhost:8013
EMAIL_URL=http://localhost:8015
