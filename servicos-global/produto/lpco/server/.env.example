# .env.example — LPCO Server
# NUNCA commitar o .env real. Copiar este arquivo para .env e preencher os valores.

# ─── Banco de Dados ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/lpco-db

# ─── Autenticacao entre servicos ──────────────────────────────────────────────
CHAVE_INTERNA_SERVICO=dev-key-mude-em-producao

# ─── Clerk ─────────────────────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_live_...

# ─── URLs de Servicos ──────────────────────────────────────────────────────────
TENANT_SERVICES_URL=http://localhost:8010
CONFIGURATOR_URL=http://localhost:8003
CLIENT_URL=http://localhost:5182

# ─── Portal Unico Siscomex ────────────────────────────────────────────────────
PORTAL_UNICO_BASE_URL=https://api.portalunico.siscomex.gov.br
PORTAL_UNICO_TRAINING_URL=https://val.portalunico.siscomex.gov.br
PORTAL_UNICO_ENV=training

# ─── Criptografia (credenciais do Portal Unico) ──────────────────────────────
ENCRYPTION_KEY=gere-uma-chave-aes-256-aqui

# ─── Monitoramento ─────────────────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...

# ─── Servidor ──────────────────────────────────────────────────────────────────
PORT=8027
NODE_ENV=development

# ─── Testes ────────────────────────────────────────────────────────────────────
TEST_DATABASE_URL=postgresql://user:password@host:5432/lpco-db-test
