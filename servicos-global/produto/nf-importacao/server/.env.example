# .env.example — NF Importacao Server
# NUNCA commitar o .env real. Copiar este arquivo para .env e preencher os valores.

# ─── Banco de Dados ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/nf-importacao-db

# ─── Autenticacao entre servicos ──────────────────────────────────────────────
CHAVE_SERVICO_INTERNO=dev-key-mude-em-producao

# ─── Clerk ─────────────────────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_live_...

# ─── URLs de Servicos ──────────────────────────────────────────────────────────
TENANT_SERVICES_URL=http://localhost:8010
CONFIGURATOR_URL=http://localhost:8003
CLIENT_URL=http://localhost:5183

# ─── Integracao com Produto Processo ─────────────────────────────────────────
PROCESSO_SERVICE_URL=http://localhost:8029

# ─── Smart Read (OCR/IA para DI/DUIMP/Recibos) ──────────────────────────────
SMART_READ_PROVIDER=internal

# ─── Monitoramento ─────────────────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...

# ─── Servidor ──────────────────────────────────────────────────────────────────
PORT=8028
NODE_ENV=development

# ─── Testes ────────────────────────────────────────────────────────────────────
TEST_DATABASE_URL=postgresql://user:password@host:5432/nf-importacao-db-test
