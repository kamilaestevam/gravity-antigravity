# ── Servidor Pedido — variáveis de ambiente ───────────────────────────────────
# Copiar para .env e preencher os valores antes de iniciar o servidor.

# Banco de dados
DATABASE_URL=postgresql://user:password@localhost:5432/gravity_pedido

# Porta do servidor (padrão: 8030)
PORT=8030

# Origens permitidas pelo CORS (separadas por vírgula)
ALLOWED_ORIGINS=http://localhost:5179,http://localhost:8000

# Chave interna S2S — validada em toda chamada entre serviços.
# Rotacionar trimestralmente. Em dev: gravity-dev-internal-key-2026.
# IMPORTANTE: o mesmo valor PRECISA estar em todo serviço chamador/chamado
# (Cadastros, Configurador, etc.). Se faltar, processos-core/cadastrosClient.ts
# lança AppError(500) "INTERNAL_SERVICE_KEY ausente — pedido server não pode
# chamar Cadastros (S2S quebrado)".
CHAVE_SERVICO_INTERNO=
INTERNAL_SERVICE_KEY=

# ── API Cockpit (observabilidade e validação de tokens) ───────────────────────
# URL do serviço api-cockpit (porta padrão: 8016)
API_COCKPIT_URL=http://localhost:8016

# Habilitar envio de métricas para o api-cockpit (true | false)
OBSERVABILITY_ENABLED=true

# URL base da API (usada na spec OpenAPI)
API_BASE_URL=http://localhost:8030

# ── Clerk (autenticação de usuários do frontend) ──────────────────────────────
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
