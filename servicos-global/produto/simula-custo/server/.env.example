# .env.example — SimulaCusto Server
# Skill: antigravity-criar-produto (Passo 10)
# NUNCA commitar o .env real. Copiar este arquivo para .env e preencher os valores.

# ─── Banco de Dados ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/simulacusto-db

# ─── Autenticação entre serviços ──────────────────────────────────────────────
# Deve ser igual ao CHAVE_INTERNA_SERVICO do Configurador e outros serviços
CHAVE_INTERNA_SERVICO=dev-key-mude-em-producao

# ─── Clerk ─────────────────────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_live_...

# ─── URLs de Serviços ──────────────────────────────────────────────────────────
TENANT_SERVICES_URL=http://tenant-services.railway.internal:3001
CONFIGURATOR_URL=http://configurador.railway.internal:3000
CLIENT_URL=https://simulacusto.gravity.com.br

# ─── Integrações Externas ──────────────────────────────────────────────────────
SISCOMEX_BASE_URL=https://api-externa.portalunico.siscomex.gov.br/ttce/api/ext
SISCOMEX_HCAPTCHA_SITE_KEY=51829642-2c97-4db0-881c-d40b4ef3b259
CAPSOLVER_API_KEY=CAP-...
BACEN_URL=https://olinda.bcb.gov.br/olinda/servico/PTAX/versao/v1/odata

# ─── Monitoramento ─────────────────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...

# ─── Servidor ──────────────────────────────────────────────────────────────────
PORT=8020
NODE_ENV=development

# ─── Testes ────────────────────────────────────────────────────────────────────
TEST_DATABASE_URL=postgresql://user:password@host:5432/simulacusto-db-test
