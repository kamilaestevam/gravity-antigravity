# .env.example — Super-Servidor Tenant
# Copiar para .env e preencher os valores antes de iniciar.

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Banco de Dados ────────────────────────────────────────────────────────────
# Banco único compartilhado por todos os serviços tenant
ORGANIZACAO_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tenant_dev

# ── S2S — Comunicação Inter-Serviço ──────────────────────────────────────────
# Deve ser igual ao CHAVE_SERVICO_INTERNO dos produtos e do Configurador
CHAVE_SERVICO_INTERNO=develop-internal-key

# Origens permitidas pelo CORS (separadas por vírgula)
ALLOWED_ORIGINS=http://localhost:5179,http://localhost:5180,http://localhost:5181,http://localhost:5182,http://localhost:5183,http://localhost:5184,http://localhost:5002,http://localhost:5000,http://localhost:8000

# ── AI (Gabi) ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Messaging (Email) ─────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── Messaging (WhatsApp) ──────────────────────────────────────────────────────
META_WHATSAPP_TOKEN=...
META_WHATSAPP_PHONE_ID=...

# ── NCM Sync (Portal Único Siscomex) ─────────────────────────────────────────
# URL da tabela pública de NCMs (padrão já configurado, alterar apenas em ambientes restritos)
PORTAL_UNICO_CLASSIF_URL=https://portalunico.siscomex.gov.br/classif/api/publico/nomenclatura/download/json
# URL do endpoint TTCE para validação pontual de NCM
SISCOMEX_BASE_URL=https://api-externa.portalunico.siscomex.gov.br/ttce/api/ext
# Cron do job diário de sync (padrão: meia-noite, fuso America/Sao_Paulo)
NCM_SYNC_CRON=0 0 * * *
# Em desenvolvimento: usar mock local em vez de chamar a API real
NCM_MOCK=false

# ── Observabilidade ───────────────────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=info
SERVICE_NAME=tenant-server
