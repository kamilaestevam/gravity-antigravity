# Variáveis de ambiente — serviço Atividades (CRM)
# Copie este arquivo para .env e preencha os valores

# Banco de dados de tenant (compartilhado com todos os serviços de tenant)
ORGANIZACAO_DATABASE_URL=postgresql://user:password@localhost:5432/tenant_db

# Porta do servidor (padrão: 8006 em produção)
ATIVIDADES_PORT=8006

# Chave interna para chamadas entre serviços
CHAVE_SERVICO_INTERNO=your-secret-internal-key

# Ambiente
NODE_ENV=development
