# @tenant/email — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores

# ---- Banco de Dados ----------------------------------------------------------
ORGANIZACAO_DATABASE_URL=postgresql://user:password@localhost:5432/tenant_db

# ---- Servidor ----------------------------------------------------------------
PORT=8008
NODE_ENV=development

# ---- Segurança entre serviços ------------------------------------------------
CHAVE_INTERNA_SERVICO=

# ---- Resend — Envio de Emails -----------------------------------------------
RESEND_API_KEY=re_...
RESEND_WEBHOOK_SECRET=whsec_...

# ---- Configuração de Email ---------------------------------------------------
# Remetente padrão (nome e endereço)
EMAIL_FROM=Gravity <no-reply@resend.dev>
# Base do Reply-To dinâmico para threading via inbound webhook
# Formato: reply@seudominio.com.br  →  Reply-To: reply+{uuid}@seudominio.com.br
EMAIL_INBOUND_ADDRESS=reply@seudominio.com.br

# ---- Gabi — Controle de Custo (integração futura) ---------------------------
GABI_MONTHLY_LIMIT_USD=20
GABI_ALERT_PCT=80
GABI_ALERT_EMAIL=admin@seudominio.com.br
