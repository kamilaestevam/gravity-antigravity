// servicos-global/tenant/gabi/prisma/fragment.prisma
// AGENTE GABI — ONDA 34 (DDD Servicos)
//
// Fragment Prisma para o serviço da Gabi AI (agente autônomo).
// Coordenador compõe via scripts/ativamente/compose-tenant-schema.ts

// ---------------------------------------------------------------------------
// GabiConversaCompleta — conversa principal da Gabi com o usuário
// ---------------------------------------------------------------------------

model GabiConversaCompleta {
  id_gabi_conversa             String  @id @default(cuid())
  id_organizacao_gabi_conversa String
  id_produto_gabi_conversa     String?
  id_usuario_gabi_conversa     String?

  titulo_gabi_conversa         String?

  data_criacao_gabi_conversa     DateTime @default(now())
  data_atualizacao_gabi_conversa DateTime @updatedAt

  mensagens_gabi_conversa  GabiMensagemIndividual[]

  @@index([id_organizacao_gabi_conversa], map: "gco_org_idx")
  @@index([id_organizacao_gabi_conversa, id_produto_gabi_conversa], map: "gco_org_prd_idx")
  @@index([id_organizacao_gabi_conversa, id_usuario_gabi_conversa], map: "gco_org_usr_idx")
  @@map("gabi_conversa")
}

// ---------------------------------------------------------------------------
// GabiMensagemIndividual — mensagem individual da conversa
// ---------------------------------------------------------------------------

model GabiMensagemIndividual {
  id_gabi_mensagem             String  @id @default(cuid())
  id_organizacao_gabi_mensagem String
  id_produto_gabi_mensagem     String?
  id_usuario_gabi_mensagem     String?

  id_conversa_gabi_mensagem    String
  conversa_gabi_mensagem       GabiConversaCompleta @relation(fields: [id_conversa_gabi_mensagem], references: [id_gabi_conversa], onDelete: Cascade)

  papel_gabi_mensagem          String   // 'user' | 'assistant' | 'system'
  conteudo_gabi_mensagem       String   @db.Text
  anexos_gabi_mensagem         String?  // JSON encodado com links/detalhes de arquivos

  data_criacao_gabi_mensagem     DateTime @default(now())
  data_atualizacao_gabi_mensagem DateTime @updatedAt

  @@index([id_organizacao_gabi_mensagem], map: "gme_org_idx")
  @@index([id_organizacao_gabi_mensagem, id_produto_gabi_mensagem], map: "gme_org_prd_idx")
  @@index([id_organizacao_gabi_mensagem, id_usuario_gabi_mensagem], map: "gme_org_usr_idx")
  @@index([id_conversa_gabi_mensagem], map: "gme_cnv_idx")
  @@map("gabi_mensagem")
}

// ---------------------------------------------------------------------------
// GabiLogUso — auditoria obrigatória de toda execução da Gabi
// ---------------------------------------------------------------------------

model GabiLogUso {
  id_gabi_log_uso             String  @id @default(cuid())
  id_organizacao_gabi_log_uso String
  id_produto_gabi_log_uso     String?
  id_usuario_gabi_log_uso     String?

  acao_gabi_log_uso              String
  snapshot_conversa_gabi_log_uso String  @db.Text
  tipo_ator_gabi_log_uso         String  @default("gabi")
  disparado_por_gabi_log_uso     String

  modelo_gabi_log_uso         String?
  tokens_input_gabi_log_uso   Int     @default(0)
  tokens_output_gabi_log_uso  Int     @default(0)
  custo_usd_gabi_log_uso      Float   @default(0)

  data_criacao_gabi_log_uso   DateTime @default(now())

  @@index([id_organizacao_gabi_log_uso], map: "glu_org_idx")
  @@index([id_organizacao_gabi_log_uso, id_produto_gabi_log_uso], map: "glu_org_prd_idx")
  @@index([id_organizacao_gabi_log_uso, id_usuario_gabi_log_uso], map: "glu_org_usr_idx")
  @@map("gabi_log_uso")
}

// ---------------------------------------------------------------------------
// GabiTokenConsumido — registro de cada chamada field-help (on-demand)
// ---------------------------------------------------------------------------

model GabiTokenConsumido {
  id_gabi_token_consumido             String   @id @default(cuid())
  id_organizacao_gabi_token_consumido String
  id_produto_gabi_token_consumido     String
  id_usuario_gabi_token_consumido     String

  campo_gabi_token_consumido         String
  tokens_input_gabi_token_consumido  Int
  tokens_output_gabi_token_consumido Int
  tokens_total_gabi_token_consumido  Int
  mes_ref_gabi_token_consumido       String   // "2026-04" — agrupamento mensal

  data_criacao_gabi_token_consumido  DateTime @default(now())

  @@index([id_organizacao_gabi_token_consumido], map: "gtc_org_idx")
  @@index([id_organizacao_gabi_token_consumido, id_produto_gabi_token_consumido], map: "gtc_org_prd_idx")
  @@index([id_organizacao_gabi_token_consumido, id_usuario_gabi_token_consumido], map: "gtc_org_usr_idx")
  @@index([id_organizacao_gabi_token_consumido, mes_ref_gabi_token_consumido], map: "gtc_org_mes_idx")
  @@map("gabi_token_consumido")
}

// ---------------------------------------------------------------------------
// GabiTokenOrganizacao — quota mensal por tenant
// ---------------------------------------------------------------------------

model GabiTokenOrganizacao {
  id_gabi_token_workspace             String   @id @default(cuid())
  id_organizacao_gabi_token_workspace String
  id_produto_gabi_token_workspace     String

  quota_mensal_gabi_token_workspace   Int
  mes_ref_gabi_token_workspace        String   // "2026-04"
  tokens_usados_gabi_token_workspace  Int      @default(0)

  data_atualizacao_gabi_token_workspace DateTime @updatedAt

  @@unique([id_organizacao_gabi_token_workspace, id_produto_gabi_token_workspace, mes_ref_gabi_token_workspace], map: "gtw_unq_quota")
  @@index([id_organizacao_gabi_token_workspace], map: "gtw_org_idx")
  @@index([id_organizacao_gabi_token_workspace, id_produto_gabi_token_workspace], map: "gtw_org_prd_idx")
  @@index([id_organizacao_gabi_token_workspace, mes_ref_gabi_token_workspace], map: "gtw_org_mes_idx")
  @@map("gabi_token_workspace")
}

// ---------------------------------------------------------------------------
// GabiPersonalizacaoOrganizacao — persona/comportamento Gabi por tenant
// ---------------------------------------------------------------------------

model GabiPersonalizacaoOrganizacao {
  id_gabi_personalizacao             String   @id @default(cuid())
  id_organizacao_gabi_personalizacao String   @unique
  id_produto_gabi_personalizacao     String?
  id_usuario_gabi_personalizacao     String?

  prompt_sistema_gabi_personalizacao   String?  @db.Text
  tom_voz_gabi_personalizacao          String?
  limitacoes_gabi_personalizacao       String?  @db.Text
  instrucoes_extras_gabi_personalizacao String? @db.Text
  ativa_gabi_personalizacao            Boolean  @default(true)

  data_criacao_gabi_personalizacao     DateTime @default(now())
  data_atualizacao_gabi_personalizacao DateTime @updatedAt

  @@index([id_organizacao_gabi_personalizacao], map: "gpe_org_idx")
  @@index([id_organizacao_gabi_personalizacao, id_produto_gabi_personalizacao], map: "gpe_org_prd_idx")
  @@index([id_organizacao_gabi_personalizacao, id_usuario_gabi_personalizacao], map: "gpe_org_usr_idx")
  @@map("gabi_personalizacao")
}

// ---------------------------------------------------------------------------
// GabiLimiteMonetario — limite USD por organizacao (e opcionalmente por modelo)
//
// Vive em cada schema tenant_<cuid> via composicao do organizacao-shared.
// Limites GLOBAIS (cross-org) ficam em configurador-db.GabiLimiteMonetarioGlobal.
//
// Avaliado pelo worker horario; quando excede `limite_bloqueio_usd_*` causa
// bloqueio (HTTP 429) em chamadas novas a LLM SOMENTE para esta organizacao.
// ---------------------------------------------------------------------------

model GabiLimiteMonetario {
  id_gabi_limite_monetario             String  @id @default(cuid())
  id_organizacao_gabi_limite_monetario String
  modelo_gabi_limite_monetario         String? // null = todos os modelos

  limite_aviso_usd_gabi_limite_monetario    Decimal  @db.Decimal(12, 2)
  limite_bloqueio_usd_gabi_limite_monetario Decimal  @db.Decimal(12, 2)
  destinatarios_email_gabi_limite_monetario String[]
  ativo_gabi_limite_monetario          Boolean  @default(true)

  data_criacao_gabi_limite_monetario     DateTime @default(now())
  data_atualizacao_gabi_limite_monetario DateTime @updatedAt

  // unicidade gerenciada pela migration (UNIQUE ... COALESCE(modelo,'__ALL__'))
  // — Prisma nao expressa NULLS-DISTINCT-FALSE de forma portatil.
  @@index([id_organizacao_gabi_limite_monetario], map: "glm_org_idx")
  @@index([id_organizacao_gabi_limite_monetario, modelo_gabi_limite_monetario], map: "glm_org_modelo_idx")
  @@map("gabi_limite_monetario")
}

// ---------------------------------------------------------------------------
// GabiKbChunk — chunk da base de conhecimento para RAG com pgvector
// ---------------------------------------------------------------------------

model GabiKbChunk {
  id_gabi_kb_chunk             String  @id @default(cuid())

  hash_conteudo_gabi_kb_chunk  String  @unique
  conteudo_gabi_kb_chunk       String  @db.Text
  embedding_gabi_kb_chunk      Unsupported("vector(768)")
  segmento_gabi_kb_chunk       String
  titulo_secao_gabi_kb_chunk   String
  nivel_gabi_kb_chunk          Int     @default(1)
  tokens_gabi_kb_chunk         Int
  versao_kb_gabi_kb_chunk      String
  ordem_gabi_kb_chunk          Int     @default(0)

  data_criacao_gabi_kb_chunk     DateTime @default(now())
  data_atualizacao_gabi_kb_chunk DateTime @updatedAt

  @@index([segmento_gabi_kb_chunk], map: "gkc_seg_idx")
  @@index([versao_kb_gabi_kb_chunk], map: "gkc_ver_idx")
  @@map("gabi_kb_chunk")
}

// ---------------------------------------------------------------------------
// GabiAlertaEmitido — idempotencia de e-mail por (limite, mes, nivel)
//
// Worker insere ANTES de enviar e-mail; UNIQUE constraint + ON CONFLICT
// DO NOTHING garante 1 e-mail por nivel/mes mesmo com worker em N instancias.
// ---------------------------------------------------------------------------

model GabiAlertaEmitido {
  id_gabi_alerta_emitido             String   @id @default(cuid())
  id_organizacao_gabi_alerta_emitido String
  id_limite_gabi_alerta_emitido      String
  mes_ref_gabi_alerta_emitido        String   // "YYYY-MM"
  nivel_gabi_alerta_emitido          String   // "AVISO" | "BLOQUEIO"
  gasto_usd_gabi_alerta_emitido      Decimal  @db.Decimal(12, 2)
  data_criacao_gabi_alerta_emitido   DateTime @default(now())

  @@unique([id_limite_gabi_alerta_emitido, mes_ref_gabi_alerta_emitido, nivel_gabi_alerta_emitido], map: "gae_unq_limite_mes_nivel")
  @@index([id_organizacao_gabi_alerta_emitido], map: "gae_org_idx")
  @@index([id_organizacao_gabi_alerta_emitido, mes_ref_gabi_alerta_emitido], map: "gae_org_mes_idx")
  @@map("gabi_alerta_emitido")
}
