// servicos-global/servicos-plataforma/prisma/base.prisma
// ESTRUTURA BASE COM RLS — documentação para o Coordenador
//
// Este arquivo documenta a estrutura base esperada para TODOS os models
// que serão adicionados via fragment.prisma nos serviços de organização.
//
// RLS (Row Level Security) é obrigatório em toda tabela com id_organizacao.
// As policies SQL estão em: servicos-global/servicos-plataforma/prisma/rls-policies.sql
//
// REGRAS OBRIGATÓRIAS para todo fragment.prisma (DDD Era Nova):
//
// 1. Todo model DEVE ter id_organizacao String (NOT NULL)
// 2. Todo model DEVE ter os 3 índices:
//    @@index([id_organizacao])
//    @@index([id_organizacao, criado_em])
//    @@index([id_organizacao, status])  (quando o campo status existir)
// 3. Todo model DEVE ter RLS configurado no SQL (ver rls-policies.sql)
// 4. Nenhum model pode ter foreign key cross-service via Prisma
//    (use IDs simples para links entre serviços)
//
// NOTA: 8 produtos COMEX (bid-cambio, bid-frete, lpco, nf-importacao, pedido,
// processo, simula-custo, financeiro-comex) ainda usam `tenant_id` literal
// como nome de coluna por motivos históricos — Onda DB-2 (rename de campos)
// não foi executada. A REGRA acima vale para NOVOS models e modelos já
// migrados (Onda 38: agendamento, cadastros, atividades, gabi, email, etc.).
//
// ESTRUTURA MODELO PARA FRAGMENTS:
//
// model NomeDoServico {
//   id_nome_do_servico              String   @id @default(cuid())
//
//   // Isolamento de organização — OBRIGATÓRIO
//   id_organizacao_nome_do_servico  String
//   id_produto_nome_do_servico      String?  // nullable — apenas quando faz sentido por produto
//   id_usuario_nome_do_servico      String?  // nullable — quando vinculado a usuário
//
//   // Campos específicos do modelo (sufixo _nome_do_servico em todos)
//   status_nome_do_servico          String
//   // ...
//
//   // Timestamps — sempre os dois por último
//   criado_em_nome_do_servico       DateTime @default(now())
//   atualizado_em_nome_do_servico   DateTime @updatedAt
//
//   // Índices — OBRIGATÓRIOS
//   @@index([id_organizacao_nome_do_servico])
//   @@index([id_organizacao_nome_do_servico, criado_em_nome_do_servico])
//   @@index([id_organizacao_nome_do_servico, status_nome_do_servico])  // usar quando o campo status existir
//   @@map("nome_do_servico")
// }

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("ORGANIZACAO_DATABASE_URL")
}
