# .env.example (Tenant Services)

# Server
PORT=3002
NODE_ENV=development

# Database
# URL do banco de dados Tenant (ex: postgresql://user:pass@localhost:5432/tenant)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tenant_dev

# S2S Communication
INTERNAL_SERVICE_KEY=develop-internal-key
CONFIGURADOR_API_URL=http://localhost:3001/api/internal

# AI (Gabi)
GEMINI_API_KEY=your_gemini_api_key_here

# Messaging
RESEND_API_KEY=re_...
WHATSAPP_API_TOKEN=...
