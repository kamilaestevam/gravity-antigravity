# ============================================================
# servicos-global/tenant — .env.example
# Compartilhado por TODOS os serviços de tenant:
# dashboard, relatorios, cronometro, email, whatsapp,
# notificacoes, historico-global, gabi, agendamento, conector-erp.
# Copie para .env e preencha com os valores reais.
# NUNCA commite o arquivo .env com valores reais.
# Versões: T26000001 (Staging) / P26000001 (Produção)
# ============================================================

# --- Banco de Dados (Tenant DB — compartilhado entre serviços de tenant) ---
# Staging (T26000001): obter em Railway > tenant-db-staging > Connect
# Produção (P26000001): obter em Railway > tenant-db-prod > Connect
TENANT_DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/tenant_db?sslmode=require

# --- Autenticação (Clerk) ---
# Mesmo Clerk para todos os serviços — validação via @clerk/backend
CLERK_SECRET_KEY=sk_test_...

# --- Comunicação entre Serviços (S2S) ---
# Deve ser igual ao valor do Configurador — rotacionar trimestralmente
INTERNAL_SERVICE_KEY=gravity_internal_...

# --- URLs Internas dos Serviços (Railway Private Networking) ---
# Usar endereços .railway.internal para tráfego interno (sem overhead SSL)
CONFIGURATOR_URL=http://configurador.railway.internal:3000
TENANT_SERVICES_URL=http://tenant-services.railway.internal:3001

# --- Email (Resend) ---
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=no-reply@gravity.com.br

# --- WhatsApp (Meta Cloud API) ---
META_WHATSAPP_TOKEN=...
META_WHATSAPP_PHONE_ID=...
META_WEBHOOK_VERIFY_TOKEN=...

# --- IA (OpenAI — Gabi) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# --- Ambiente ---
# Valores: development | staging | production
NODE_ENV=development
PORT=3001

# --- Observabilidade ---
SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project_id>
LOG_LEVEL=info

# --- Testes ---
# Banco isolado para testes funcionais (nunca o banco de staging)
TEST_DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/tenant_test_db?sslmode=require
