// servicos-global/tenant/atividades/prisma/fragment.prisma
// AGENTE ATIVIDADES — ONDA 3
//
// Fragment Prisma para o serviço de Atividades (CRM).
// Não editar o schema.prisma final — apenas este fragment.
// O Coordenador compõe o schema via scripts/compose-tenant-schema.ts.

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum EmpresaStatus {
  ATIVA
  INATIVA
  PROSPECTO
  CLIENTE
  CHURNED
}

enum AtividadeStatus {
  PENDENTE
  EM_ANDAMENTO
  CONCLUIDA
  CANCELADA
}

enum AtividadePrioridade {
  BAIXA
  MEDIA
  ALTA
  URGENTE
}

enum AtividadeTipo {
  TAREFA
  REUNIAO
  LIGACAO
  EMAIL
  FOLLOW_UP
  VISITA
  OUTRO
}

enum PipelineEtapa {
  PROSPECCAO
  QUALIFICACAO
  PROPOSTA
  NEGOCIACAO
  FECHAMENTO
  POS_VENDA
}

enum KanbanCardStatus {
  ABERTO
  EM_PROGRESSO
  BLOQUEADO
  CONCLUIDO
}

// ---------------------------------------------------------------------------
// Empresa — cadastro de empresas do CRM
// ---------------------------------------------------------------------------

model Empresa {
  id         String        @id @default(cuid())
  tenant_id  String
  product_id String?
  user_id    String?

  nome       String
  cnpj       String?
  email      String?
  telefone   String?
  site       String?
  segmento   String?
  status     EmpresaStatus @default(PROSPECTO)
  observacao String?

  contatos     Contato[]
  atividades   Atividade[]
  pipelines    Pipeline[]
  kanbanCards  KanbanCard[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
}

// ---------------------------------------------------------------------------
// Contato — pessoas vinculadas a empresas
// ---------------------------------------------------------------------------

model Contato {
  id         String  @id @default(cuid())
  tenant_id  String
  product_id String?
  user_id    String?

  empresa_id String?
  empresa    Empresa? @relation(fields: [empresa_id], references: [id])
  nome       String
  cargo      String?
  email      String?
  telefone   String?
  whatsapp   String?
  linkedin   String?
  observacao String?

  atividades  Atividade[]
  pipelines   Pipeline[]
  kanbanCards KanbanCard[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
}

// ---------------------------------------------------------------------------
// Atividade — tarefas e interações de CRM
// ---------------------------------------------------------------------------

model Atividade {
  id         String              @id @default(cuid())
  tenant_id  String
  product_id String?
  user_id    String?

  titulo      String
  descricao   String?
  tipo        AtividadeTipo       @default(TAREFA)
  status      AtividadeStatus     @default(PENDENTE)
  prioridade  AtividadePrioridade @default(MEDIA)
  data_inicio DateTime?
  data_fim    DateTime?
  data_venc   DateTime?

  empresa_id  String?
  empresa     Empresa?  @relation(fields: [empresa_id], references: [id])
  contato_id  String?
  contato     Contato?  @relation(fields: [contato_id], references: [id])
  pipeline_id String?
  pipeline    Pipeline? @relation(fields: [pipeline_id], references: [id])

  kanbanCards KanbanCard[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
}

// ---------------------------------------------------------------------------
// Pipeline — funil de vendas
// ---------------------------------------------------------------------------

model Pipeline {
  id         String        @id @default(cuid())
  tenant_id  String
  product_id String?
  user_id    String?

  titulo      String
  etapa       PipelineEtapa @default(PROSPECCAO)
  valor       Float?
  empresa_id  String?
  empresa     Empresa?  @relation(fields: [empresa_id], references: [id])
  contato_id  String?
  contato     Contato?  @relation(fields: [contato_id], references: [id])
  probabilidade Int?
  data_fechamento DateTime?
  observacao  String?

  atividades Atividade[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
}

// ---------------------------------------------------------------------------
// KanbanCard — cards para visão kanban de atividades
// ---------------------------------------------------------------------------

model KanbanCard {
  id         String           @id @default(cuid())
  tenant_id  String
  product_id String?
  user_id    String?

  titulo      String
  descricao   String?
  status      KanbanCardStatus @default(ABERTO)
  posicao     Int              @default(0)
  cor         String?
  etiquetas   String[]
  data_venc   DateTime?

  atividade_id String?
  atividade    Atividade? @relation(fields: [atividade_id], references: [id])
  empresa_id   String?
  empresa      Empresa?   @relation(fields: [empresa_id], references: [id])
  contato_id   String?
  contato      Contato?   @relation(fields: [contato_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
}
