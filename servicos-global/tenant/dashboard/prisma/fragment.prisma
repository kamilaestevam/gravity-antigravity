enum ModoDashboard {
  PRODUCT
  GENERAL
}

enum TipoWidget {
  CATALOG
  CUSTOM
  GABI
}

enum TipoGrafico {
  KPI_CARD
  LINE
  BAR
  BAR_HORIZONTAL
  DONUT
  HISTOGRAM
  FUNNEL
  GAUGE
  MAP
  TABLE
  AREA
}

model DashboardConfiguracao {
  id         String        @id @default(cuid())
  tenant_id  String
  product_id String?
  user_id    String
  name       String        @default("Meu Dashboard")
  mode       ModoDashboard @default(PRODUCT)
  layout     Json          @default("[]")
  filters    Json?
  is_default Boolean       @default(false)
  widgets    DashboardCriar[]
  alerts     DashboardAlertas[]
  shares     DashboardCompartilhar[]
  created_at DateTime      @default(now())
  updated_at DateTime      @updatedAt

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
  @@map("dashboard_configuracao")
}

model DashboardCriar {
  id           String          @id @default(cuid())
  tenant_id    String
  product_id   String?
  user_id      String
  dashboard_id String
  widget_key   String
  widget_type  TipoWidget      @default(CATALOG)
  chart_type   TipoGrafico       @default(KPI_CARD)
  title        String
  query_spec   Json
  position     Json            @default("{\"x\":0,\"y\":0,\"w\":2,\"h\":2}")
  config       Json?
  dashboard    DashboardConfiguracao @relation(fields: [dashboard_id], references: [id], onDelete: Cascade)
  created_at   DateTime        @default(now())
  updated_at   DateTime        @updatedAt

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
  @@map("dashboard_criar")
}

model DashboardMetricas {
  id          String   @id @default(cuid())
  tenant_id   String
  product_id  String
  user_id     String?
  metric_key  String
  dimensions  Json?
  value       Json
  period_from DateTime
  period_to   DateTime
  captured_at DateTime @default(now())

  @@unique([tenant_id, product_id, metric_key, period_from, period_to])
  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
  @@map("dashboard_metricas")
}

model DashboardAlertas {
  id             String          @id @default(cuid())
  tenant_id      String
  product_id     String?
  user_id        String
  dashboard_id   String
  widget_id      String?
  metric_key     String
  condition      String
  threshold      Json
  channels       String[]        @default([])
  is_active      Boolean         @default(true)
  last_triggered DateTime?
  dashboard      DashboardConfiguracao @relation(fields: [dashboard_id], references: [id], onDelete: Cascade)
  created_at     DateTime        @default(now())
  updated_at     DateTime        @updatedAt

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
  @@map("dashboard_alertas")
}

model DashboardCompartilhar {
  id              String          @id @default(cuid())
  tenant_id       String
  product_id      String?
  user_id         String
  dashboard_id    String
  share_token     String          @unique @default(cuid())
  channel         String
  recipient_email String?
  recipient_phone String?
  snapshot_data   Json?
  expires_at      DateTime?
  dashboard       DashboardConfiguracao @relation(fields: [dashboard_id], references: [id], onDelete: Cascade)
  created_at      DateTime        @default(now())

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([share_token])
  @@index([tenant_id, user_id])
  @@map("dashboard_compartilhar")
}
