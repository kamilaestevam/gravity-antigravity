//
// Fragment Prisma para o serviço da Gabi AI (agente autônomo).
// Não editar o schema.prisma final — apenas este fragment.
// O Coordenador compõe o schema via scripts/compose-tenant-schema.ts.

// ---------------------------------------------------------------------------
// GabiConversation — conversa principal da Gabi com o usuário no tenant
// ---------------------------------------------------------------------------

model GabiConversation {
  id         String @id @default(cuid())
  tenant_id  String
  product_id String?
  user_id    String?

  title      String?
  
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  messages   GabiMessage[]

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
}

// ---------------------------------------------------------------------------
// GabiMessage — mensagem individual da conversa
// ---------------------------------------------------------------------------

model GabiMessage {
  id              String @id @default(cuid())
  tenant_id       String
  product_id      String?
  user_id         String?

  conversation_id String
  conversation    GabiConversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  role            String   // 'user' | 'assistant' | 'system'
  content         String   @db.Text
  attachments     String?  // JSON encodado com links/detalhes de arquivos

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
  @@index([conversation_id])
}

// ---------------------------------------------------------------------------
// GabiUsageLog (SnapshotAuditoria) — auditoria obrigatória de toda execução
// Campos model_used/tokens_input/tokens_output/cost_usd adicionados para
// compatibilidade com usage.ts
// ---------------------------------------------------------------------------

model GabiUsageLog {
  id                    String @id @default(cuid())
  tenant_id             String
  product_id            String?
  user_id               String?

  action_taken          String
  conversation_snapshot String  @db.Text
  actor_type            String  @default("gabi")
  triggered_by          String

  // Campos de custo (usados por usage.ts)
  model_used            String?
  tokens_input          Int     @default(0)
  tokens_output         Int     @default(0)
  cost_usd              Float   @default(0)

  created_at            DateTime @default(now())

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
}

// ---------------------------------------------------------------------------
// GabiTokenLog — registro de cada chamada field-help (on-demand)
// ---------------------------------------------------------------------------

model GabiTokenLog {
  id             String   @id @default(cuid())
  tenant_id      String
  product_id     String
  user_id        String
  campo          String
  tokens_input   Int
  tokens_output  Int
  tokens_total   Int
  mes_ref        String   // "2026-04" — para agrupamento mensal
  created_at     DateTime @default(now())

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, mes_ref])
}

// ---------------------------------------------------------------------------
// GabiTokenQuota — quota mensal por tenant (verificada em tempo real)
// ---------------------------------------------------------------------------

model GabiTokenQuota {
  id             String   @id @default(cuid())
  tenant_id      String
  product_id     String
  quota_mensal   Int      // padrão do produto, sobrescrito por negociação
  mes_ref        String   // "2026-04"
  tokens_usados  Int      @default(0)
  updated_at     DateTime @updatedAt

  @@unique([tenant_id, product_id, mes_ref])
  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, mes_ref])
}
