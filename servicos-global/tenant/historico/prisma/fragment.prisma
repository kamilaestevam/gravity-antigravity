model LogAlteracao {
  id             String  @id @default(cuid())
  tenant_id      String
  product_id     String?

  // Ator
  actor_id       String?
  actor_type     String  @default("user") // user | gabi | system
  actor_name     String

  // Ação
  action         String
  entity         String
  entity_label   String
  entity_id      String?
  description    String

  // Diff
  diff           Json?

  // Integridade
  integrity_hash String?

  // Contexto
  ip_address     String?
  user_agent     String?
  created_at     DateTime @default(now())

  @@index([tenant_id])
  @@index([tenant_id, actor_id])
  @@index([tenant_id, action])
  @@index([tenant_id, entity])
  @@index([tenant_id, created_at])
  @@index([tenant_id, product_id])
}

model EntidadeAuditada {
  id           String   @id @default(cuid())
  tenant_id    String
  entity_name  String   @unique
  is_active    Boolean  @default(true)
  
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@index([tenant_id])
}
