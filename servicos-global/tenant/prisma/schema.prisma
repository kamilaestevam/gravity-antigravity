// --- Fragment: atividades ---
// servicos-global/tenant/atividades/prisma/fragment.prisma
// AGENTE ATIVIDADES — Minhas Atividades (Tasks Board)
//
// Fragment Prisma para o serviço de Atividades — portado do Journey tasks-board.
// Suporta Kanban (4 colunas), drag-and-drop, timer, participantes e vínculo a processo.
// Não editar o schema.prisma final — apenas este fragment.
// O Coordenador compõe o schema via scripts/compose-tenant-schema.ts.

// ---------------------------------------------------------------------------
// Atividade — tarefas e interações cross-produto do usuário logado
// ---------------------------------------------------------------------------

model Atividade {
  id        String @id @default(cuid())
  tenant_id String
  user_id   String? // criador da atividade

  // Conteúdo
  titulo    String
  descricao String?

  // Tipo de atividade (igual ao Journey)
  // Valores: "Comentário" | "Reunião" | "Chamados HD" | "Chamados CS" | "Ação necessária" | "Tarefa" | "Outros"
  tipo String @default("Tarefa")

  // Status Kanban (colunas do board)
  // Valores: "A Fazer" | "Em Andamento" | "Concluída" | "Cancelada"
  status String @default("A Fazer")

  // Prioridade
  // Valores: "baixa" | "média" | "alta" | "urgente"
  prioridade String?

  // Temporal
  data_atividade  DateTime?
  data_vencimento DateTime?

  // Tempo trabalhado (acumulado de todas as sessões)
  tempo_gasto_minutos Int @default(0)

  // Próximo passo
  proximo_passo_titulo String?
  proximo_passo_data   DateTime?

  // Lembrete
  lembrete_em       DateTime?
  lembrete_email    Boolean @default(false)
  lembrete_whatsapp Boolean @default(false)

  // Notificação ao atribuir
  notificar_ao_atribuir Boolean @default(false)

  // Vínculos opcionais
  processo_id String? // link opcional a um Processo Comex (para navegar)

  // Metadados
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relações
  participantes AtividadeParticipante[]
  sessoes_timer AtividadeSessaoTimer[]

  @@index([tenant_id])
  @@index([tenant_id, user_id])
  @@index([tenant_id, status])
  @@map("atividades")
}

// ---------------------------------------------------------------------------
// AtividadeParticipante — usuários atribuídos à atividade (M2M)
// ---------------------------------------------------------------------------

model AtividadeParticipante {
  id           String  @id @default(cuid())
  atividade_id String
  user_id      String
  user_nome    String? // cache de nome para exibição sem JOIN extra

  atividade Atividade @relation(fields: [atividade_id], references: [id], onDelete: Cascade)

  @@unique([atividade_id, user_id])
  @@index([atividade_id])
  @@map("atividade_participantes")
}

// ---------------------------------------------------------------------------
// AtividadeSessaoTimer — sessões do cronômetro registradas
// ---------------------------------------------------------------------------

model AtividadeSessaoTimer {
  id           String   @id @default(cuid())
  atividade_id String
  iniciado_em  DateTime
  duracao_min  Int
  assunto      String?

  atividade Atividade @relation(fields: [atividade_id], references: [id], onDelete: Cascade)

  @@index([atividade_id])
  @@map("atividade_sessoes_timer")
}


// --- Fragment: cronometro ---
// servicos-global/tenant/cronometro/prisma/fragment.prisma
// AGENTE CRONÔMETRO — ONDA 3 | 2/13
//
// Fragment Prisma do serviço de Cronômetro.
// Não editar schema.prisma diretamente — apenas este fragment.
// O Coordenador compõe o schema final via scripts/compose-tenant-schema.ts

// ---------------------------------------------------------------------------
// TimerSession
// Sessão de tempo registrada (concluída ou manual).
// ---------------------------------------------------------------------------

model TimerSession {
  id         String  @id @default(cuid())

  // Campos de isolamento — obrigatórios
  tenant_id  String
  product_id String?
  user_id    String

  // Relacionamento
  activity_id String

  // Dados da sessão
  started_at       DateTime
  ended_at         DateTime?
  duration_minutes Int?         // null = timer ainda ativo (em progresso)
  is_manual        Boolean  @default(false)

  // Assunto e vínculo
  subject      String?  // texto livre do assunto
  linked_type  String?  // nf | meeting | process | custom
  linked_id    String?  // ID do item vinculado
  linked_label String?  // label de exibição do item vinculado

  // Timestamps
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Índices obrigatórios — padrão do projeto
  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
  // Índice extra para queries de relatório por data
  @@index([tenant_id, user_id, started_at])
  // Índice extra para queries por atividade
  @@index([tenant_id, activity_id])
}

// ---------------------------------------------------------------------------
// TimerActive
// Estado do timer em execução (um por usuário).
// Removido quando a sessão é finalizada — o histórico fica em TimerSession.
// ---------------------------------------------------------------------------

model TimerActive {
  id         String  @id @default(cuid())

  // Campos de isolamento
  tenant_id  String
  user_id    String  @unique // um timer ativo por usuário

  // Relacionamento
  activity_id String

  // Estado do timer
  started_at          DateTime
  paused_at           DateTime?
  accumulated_seconds Int      @default(0) // segundos acumulados antes de pausas

  // Timestamps
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Índices obrigatórios
  @@index([tenant_id])
  @@index([tenant_id, user_id])
  @@index([user_id])
}

// ---------------------------------------------------------------------------
// RelatorioTempoCache
// Cache de relatórios de tempo pré-computados para performance.
// ---------------------------------------------------------------------------

model RelatorioTempoCache {
  id        String @id @default(cuid())

  tenant_id  String
  user_id    String?
  product_id String?

  periodo_inicio DateTime
  periodo_fim    DateTime
  total_minutos  Int
  payload        String  // JSON serializado com breakdown por atividade

  computed_at DateTime @default(now())
  expires_at  DateTime

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
  @@index([tenant_id, periodo_inicio, periodo_fim])
}


// --- Fragment: email ---
// servicos-global/tenant/email/prisma/fragment.prisma
// AGENTE EMAIL — ONDA 3 | 3/13
//
// Fragment Prisma para o serviço de Email (envio Resend, templates, histórico).
// Não editar o schema.prisma final — apenas este fragment.
// O Coordenador compõe o schema via scripts/compose-tenant-schema.ts.

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum EmailStatus {
  PENDENTE
  PROCESSANDO
  ENVIADO
  FALHOU
  CANCELADO
}

enum EmailDirection {
  INBOUND
  OUTBOUND
}

enum EmailThreadStatus {
  ABERTA
  ARQUIVADA
  RESOLVIDA
}

enum EmailSentimentLevel {
  MUITO_POSITIVO
  POSITIVO
  NEUTRO
  NEGATIVO
  MUITO_NEGATIVO
}

enum FilaEmailPrioridade {
  BAIXA
  NORMAL
  ALTA
  URGENTE
}

// ---------------------------------------------------------------------------
// EmailThread — thread de conversa (agrupa mensagens de ida e volta)
// ---------------------------------------------------------------------------

model EmailThread {
  id         String @id @default(uuid())
  tenant_id  String
  product_id String?
  user_id    String?

  subject        String
  status         EmailThreadStatus   @default(ABERTA)
  sentiment      Float               @default(0)           // -1 a 1
  sentiment_label EmailSentimentLevel @default(NEUTRO)
  mensagens_count Int                 @default(0)
  ultimo_contato  DateTime?
  deep_link       String?                                   // ex: /email/thread/{id}

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  mensagens EmailMessage[]

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
}

// ---------------------------------------------------------------------------
// EmailMessage — mensagem individual (inbound ou outbound)
// ---------------------------------------------------------------------------

model EmailMessage {
  id         String @id @default(uuid())
  tenant_id  String
  product_id String?
  user_id    String?

  thread_id        String
  thread           EmailThread  @relation(fields: [thread_id], references: [id])

  resend_id        String?      @unique                    // ID retornado pelo Resend
  direction        EmailDirection @default(OUTBOUND)
  from             String
  to               String
  subject          String?
  body             String       @db.Text
  body_html        String?      @db.Text
  dedup_key        String?      @unique                    // UUID para Reply-To dinâmico
  parent_message_id String?                                // UUID do email pai (threading)

  // Análise Gabi
  gabi_response    String?      @db.Text
  gabi_confidence  Float?
  gabi_action      String?                                 // auto_replied | escalated_to_human | none

  sent_at          DateTime     @default(now())
  created_at       DateTime     @default(now())
  updated_at       DateTime     @updatedAt

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
  @@index([thread_id])
  @@index([dedup_key])
}

// ---------------------------------------------------------------------------
// EmailEnviado — log de todos os envios realizados (auditoria completa)
// ---------------------------------------------------------------------------

model EmailEnviado {
  id         String @id @default(cuid())
  tenant_id  String
  product_id String?
  user_id    String?

  to            String
  from          String
  reply_to      String?
  subject       String
  template_id   String?
  status        EmailStatus  @default(PENDENTE)
  resend_id     String?      @unique
  dedup_key     String       @unique                       // UUID do Reply-To dinâmico

  tentativas    Int          @default(0)
  max_tentativas Int         @default(5)
  next_retry_at DateTime?
  error_message String?      @db.Text
  enviado_at    DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
  @@index([status])
  @@index([dedup_key])
}

// ---------------------------------------------------------------------------
// Template — templates de email editáveis por tenant
// ---------------------------------------------------------------------------

model Template {
  id         String @id @default(cuid())
  tenant_id  String
  product_id String?
  user_id    String?

  nome        String
  slug        String                                        // ex: boas-vindas, recuperacao-senha
  assunto     String
  corpo_html  String    @db.Text
  corpo_texto String?   @db.Text
  variaveis   String[]                                      // ex: ["nome", "plano", "url"]
  ativo       Boolean   @default(true)
  descricao   String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([tenant_id, slug])
  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
}

// ---------------------------------------------------------------------------
// FilaEmail — fila de envio com controle de retry e backoff exponencial
// ---------------------------------------------------------------------------

model FilaEmail {
  id         String @id @default(cuid())
  tenant_id  String
  product_id String?
  user_id    String?

  status        EmailStatus         @default(PENDENTE)
  prioridade    FilaEmailPrioridade @default(NORMAL)
  payload       String              @db.Text                // JSON: { to, subject, body, ... }
  template_id   String?
  email_enviado_id String?

  tentativas     Int       @default(0)
  max_tentativas Int       @default(5)
  next_retry_at  DateTime?
  processado_at  DateTime?
  erro           String?   @db.Text

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
  @@index([status, next_retry_at])
  @@index([tenant_id, status])
}


