  @@index([tenant_id, created_at])
  @@index([tenant_id, module, created_at])
  @@index([actor_id, created_at])
  @@map("historico_log")
}

model AlertRule {
  id                       String     @id @default(cuid())
  tenant_id                String?

  name                     String
  description              String?
  enabled                  Boolean    @default(true)

  // Filtro da regra (null = qualquer valor)
  actor_type               AcaoExecutadaPor?
  action                   String?
  module                   String?
  status_filter            EventoStatus?

  // Threshold
  threshold_count          Int?
  threshold_window_seconds Int?

  // Canais ativos por regra
  channel_inapp            Boolean    @default(true)
  channel_email            Boolean    @default(false)
  channel_whatsapp         Boolean    @default(false)

  // Destinatários por canal
  recipients_email         String[]
  recipients_whatsapp      String[]
  recipients_user_ids      String[]

  created_at               DateTime   @default(now())
  updated_at               DateTime   @updatedAt

  alerts                   AlertEvent[]

  @@index([tenant_id, enabled])
  @@map("alerta_regra")
}

model AlertEvent {
  id             String      @id @default(cuid())
  tenant_id      String
  rule_id        String
  rule           AlertRule   @relation(fields: [rule_id], references: [id])

  actor_type     AcaoExecutadaPor
  actor_id       String
  actor_name     String
  module         String
  action         String
  event_count    Int
  window_seconds Int
  audit_log_ids  String[]

  status         AlertaStatus @default(PENDENTE)
  reviewed_by    String?
  reviewed_at    DateTime?
  notes          String?

  created_at     DateTime    @default(now())

  notifications  AlertNotificationLog[]

  @@index([tenant_id, status])
  @@index([tenant_id, created_at])
  @@map("alerta_data")
}

model AlertNotificationLog {
  id             String     @id @default(cuid())
  alert_event_id String
  alert_event    AlertEvent @relation(fields: [alert_event_id], references: [id])

  channel        String
  recipient      String
  status         String     @default("pending")
  attempts       Int        @default(1)
  error_message  String?
  sent_at        DateTime?

  created_at     DateTime   @default(now())

  @@index([alert_event_id])
  @@map("alerta_registro")
}

enum AcaoExecutadaPor {
  USUARIO
  API
  IA
  JOB
  INTEGRACAO
}

enum EventoStatus {
  SUCESSO
  FALHA
  PARCIAL
}

enum AlertaStatus {
  PENDENTE
  REVISADO
  ESCALADO
}

/// Resultado de exportação em background (acima de 10k registros).
/// Persiste no banco para sobreviver a restarts do Railway (alternativa ao /tmp).
model ExportarResultado {
  id           String   @id @default(cuid())
  tenant_id    String
  format       String   // 'csv' | 'json'
  content      String   @db.Text
  status       String   @default("processing") // 'processing' | 'ready' | 'failed'
  record_count Int      @default(0)
  filters      Json?
  error        String?
  created_at   DateTime @default(now())
  expires_at   DateTime // cleanup job remove após 24h

  @@index([tenant_id, status])
  @@index([expires_at])
  @@map("exportar_resultado")
}


