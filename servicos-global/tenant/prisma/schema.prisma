  id         String  @id @default(cuid())

  // Identificação — obrigatórios
  // user_id = Clerk user ID (ex: user_2abc...)
  user_id    String  @unique
  tenant_id  String

  // ── Preferências de UI ──────────────────────────────────────────────────
  // Visibilidade global das tooltips/dicas
  tooltips_disabled Boolean @default(false)

  // Tema preferido ('dark' | 'light')
  theme             String  @default("dark")

  // Sidebar aberta ou fechada
  sidebar_open      Boolean @default(true)

  // Timestamps
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([user_id])
  @@index([tenant_id])
  @@index([tenant_id, user_id])
  @@map("preferencia_workspace")
}


// --- Fragment: ncm-sync ---
// servicos-global/tenant/ncm-sync/prisma/fragment.prisma
// NcmItem  — tabela NCM cacheada do Portal Único Siscomex (atualizada diariamente)
// NcmSyncLog — histórico de cada sincronização com o Portal Único

model NcmItem {
  id          String   @id @default(cuid())
  tenant_id   String
  product_id  String?
  user_id     String?

  codigo      String   // 8 dígitos — ex: "84713019"
  descricao   String
  ativo       Boolean  @default(true)

  // Metadados do Portal Único
  data_inicio DateTime?
  data_fim    DateTime?
  sync_id     String   // referência ao NcmSyncLog que inseriu/atualizou

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@unique([tenant_id, codigo])
  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
  @@index([tenant_id, ativo])
  @@index([tenant_id, codigo])
  @@map("ncm_item")
}

model NcmSyncLog {
  id           String    @id @default(cuid())
  tenant_id    String
  product_id   String?
  user_id      String?

  iniciado_em  DateTime  @default(now())
  concluido_em DateTime?

  status       NCMStatusSincronizacao @default(EXECUTANDO)

  // Totais do diff
  total        Int @default(0)
  adicionados  Int @default(0)
  alterados    Int @default(0)
  removidos    Int @default(0)

  // Origem do trigger
  origem       NCMOrigemSincronizacao @default(JOB)  // 'JOB' | 'MANUAL'
  disparado_por String?  // user_id se MANUAL

  erro_msg     String?

  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
  @@index([tenant_id, status])
  @@index([tenant_id, iniciado_em])
  @@map("ncm_log")
}

enum NCMStatusSincronizacao {
  EXECUTANDO
  SUCESSO
  ERRO
}

enum NCMOrigemSincronizacao {
  JOB
  MANUAL
}

// ── NcmScheduleConfig — configuração singleton do job de sincronização NCM ───
// id = 'default' — registro único (singleton global do sistema)
// tenant_id = '__system__' — satisfaz padrão de índices obrigatórios

model NcmScheduleConfig {
  id             String   @id @default("default")
  tenant_id      String   @default("__system__")
  product_id     String?
  user_id        String?

  ativo          Boolean  @default(false)
  cron_expressao String   @default("0 2 * * *")   // 2am diário (America/Sao_Paulo)
  notificadores  Json     @default("[]")            // NcmNotificador[]

  criado_em      DateTime @default(now())
  atualizado_em  DateTime @updatedAt

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
  @@map("ncm_agendamento")
}


// --- Fragment: notificacoes ---
model NotificacoesTituloCorpo {
  id          String   @id @default(cuid())
  tenant_id   String
  product_id  String?
  user_id     String   // Clerk ID or direct email
  type        String   // mentioned | task-assigned | reminder | next-step | etc.
  title       String?
  message     String
  read        Boolean  @default(false)

  // ── Context link (Pilar 2) ─────────────────────────────────────────────────
  // Nunca salvar URL strings. Salvar entidade + ID e construir URL no frontend.
  target_entity  String?  // "PEDIDO" | "ITEM" | "SIMULACUSTO" | "PROCESSO" | etc.
  target_id      String?  // ID da entidade no banco

  // ── Delivery tracking (Pilar 3) ────────────────────────────────────────────
  // delivery_status: ciclo de vida do envio de email/whatsapp
  // pending → sent → delivered | bounced | failed
  delivery_status  String   @default("pending")  // pending | sent | delivered | bounced | failed
  external_id      String?  // ID da mensagem no Resend (para reconciliar webhooks)

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
  @@index([tenant_id, user_id, read])
  @@index([tenant_id, created_at])
  @@index([tenant_id, delivery_status])
  @@index([external_id])
  @@map("notificacoes_titulo_corpo")
}

// ─── Contatos externos (email / WhatsApp) ─────────────────────────────────
// Agenda de contatos por tenant. Usada pelo sininho para enviar notificações a
// pessoas que não são usuários do sistema (e-mail ou WhatsApp).
// whatsapp_opt_in_at: consentimento explícito exigido pela LGPD (Art. 8).
model ExternalContact {
  id                 String    @id @default(cuid())
  tenant_id          String
  created_by         String    // Clerk user_id
  name               String    @db.VarChar(200)
  email              String?   @db.VarChar(255)
  whatsapp_phone     String?   @db.VarChar(20)  // E.164: +5511999999999
  whatsapp_opt_in_at DateTime? // LGPD Art. 8 — consentimento explícito
  notes              String?   @db.VarChar(500)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([tenant_id])
  @@index([tenant_id, created_by])
  @@index([tenant_id, email])
  @@index([tenant_id, whatsapp_phone])
  @@map("contato_externo")
}

// ─── Configuração de canais por tenant ────────────────────────────────────
// Controlado exclusivamente pelo usuário com role MASTER.
// email_enabled default true (backward compat). whatsapp_enabled default false.
model TenantChannelConfig {
  id               String  @id @default(cuid())
  tenant_id        String  @unique
  email_enabled    Boolean @default(true)
  whatsapp_enabled Boolean @default(false)
  updated_by       String? // Clerk user_id do master que alterou

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([tenant_id])
  @@map("configuracao_canal_tenant")
}
