// Coordenador compõe via scripts/ativamente/compose-tenant-schema.ts

enum DashboardModo {
  PRODUTO
  GERAL
}

enum DashboardTipo {
  CATALOGO
  CUSTOMIZADO
  GABI
}

enum GraficoTipo {
  KPI_CARD
  LINHA
  BARRA
  BARRA_HORIZONTAL
  ROSCA
  HISTOGRAMA
  FUNIL
  MEDIDOR
  MAPA
  TABELA
  AREA
}

model DashboardConfiguracao {
  id         String        @id @default(cuid())
  tenant_id  String
  product_id String?
  user_id    String
  name       String        @default("Meu Dashboard")
  mode       DashboardModo @default(PRODUTO)
  layout     Json          @default("[]")
  filters    Json?
  is_default Boolean       @default(false)
  widgets    DashboardCriar[]
  alerts     DashboardAlertas[]
  shares     DashboardCompartilhar[]
  created_at DateTime      @default(now())
  updated_at DateTime      @updatedAt

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
  @@map("dashboard_configuracao")
}

model DashboardCriar {
  id           String          @id @default(cuid())
  tenant_id    String
  product_id   String?
  user_id      String
  dashboard_id String
  widget_key   String
  widget_type  DashboardTipo      @default(CATALOGO)
  chart_type   GraficoTipo       @default(KPI_CARD)
  title        String
  query_spec   Json
  position     Json            @default("{\"x\":0,\"y\":0,\"w\":2,\"h\":2}")
  config       Json?
  dashboard    DashboardConfiguracao @relation(fields: [dashboard_id], references: [id], onDelete: Cascade)
  created_at   DateTime        @default(now())
  updated_at   DateTime        @updatedAt

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
  @@map("dashboard_criar")
}

model DashboardMetricas {
  id          String   @id @default(cuid())
  tenant_id   String
  product_id  String
  user_id     String?
  metric_key  String
  dimensions  Json?
  value       Json
  period_from DateTime
  period_to   DateTime
  captured_at DateTime @default(now())

  @@unique([tenant_id, product_id, metric_key, period_from, period_to])
  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
  @@map("dashboard_metricas")
}

model DashboardAlertas {
  id             String          @id @default(cuid())
  tenant_id      String
  product_id     String?
  user_id        String
  dashboard_id   String
  widget_id      String?
  metric_key     String
  condition      String
  threshold      Json
  channels       String[]        @default([])
  is_active      Boolean         @default(true)
  last_triggered DateTime?
  dashboard      DashboardConfiguracao @relation(fields: [dashboard_id], references: [id], onDelete: Cascade)
  created_at     DateTime        @default(now())
  updated_at     DateTime        @updatedAt

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
  @@map("dashboard_alertas")
}

model DashboardCompartilhar {
  id              String          @id @default(cuid())
  tenant_id       String
  product_id      String?
  user_id         String
  dashboard_id    String
  share_token     String          @unique @default(cuid())
  channel         String
