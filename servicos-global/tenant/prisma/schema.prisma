// --- Fragment: historico-global ---
model HistoryLog {
  id         String    @id @default(uuid())
  tenant_id  String
  actor_id   String
  actor_type ActorType
  action     String

  product_id String?
  user_id    String?

  // Multiaxial details
  metadata Json?

  created_at DateTime @default(now())

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
  @@index([tenant_id, created_at])
}

enum ActorType {
  USER
  SYSTEM
  GABI_IA
  ADMIN
}


// --- Fragment: agendamento ---
model Agenda {
  id          String   @id @default(uuid())
  tenant_id   String
  nome        String
  descricao   String?
  tipo        String   // e.g., reuniao, consulta
  criadoEm    DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  slots       Slot[]
  config      DisponibilidadeConfig?

  @@index([tenant_id])
}

model Slot {
  id          String   @id @default(uuid())
  tenant_id   String
  agenda_id   String
  inicio      DateTime
  fim         DateTime
  capacidade  Int      @default(1)
  criadoEm    DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  agenda      Agenda   @relation(fields: [agenda_id], references: [id], onDelete: Cascade)
  reservas    Reserva[]

  @@index([tenant_id])
  @@index([agenda_id])
}

model Reserva {
  id          String   @id @default(uuid())
  tenant_id   String
  slot_id     String
  usuario_id  String   // ID do usuário ou contato
  nome        String?  // Nome se não tiver usuário cadastrado no sistema
  email       String?  // Email para notificação
  status      String   @default("confirmado") // confirmado, cancelado, pendente
  criadoEm    DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  slot        Slot     @relation(fields: [slot_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([slot_id])
  @@index([usuario_id])
}

model DisponibilidadeConfig {
  id             String   @id @default(uuid())
  tenant_id      String
  agenda_id      String   @unique
  horarioInicio  String   // Formato "HH:mm" (e.g., "09:00")
  horarioFim     String   // Formato "HH:mm" (e.g., "18:00")
  duracaoSlot    Int      // em minutos
  intervalo      Int      @default(0) // tempo entre slots em minutos
  diasSemana     Int[]    // [1,2,3,4,5] (1=Segunda, 5=Sexta)
  criadoEm       DateTime @default(now())
  atualizadoEm   DateTime @updatedAt

  agenda         Agenda   @relation(fields: [agenda_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
}


// --- Fragment: gabi ---
// servicos-global/tenant/gabi/prisma/fragment.prisma
// AGENTE GABI — ONDA 3 | 10/13
//
// Fragment Prisma para o serviço da Gabi AI (agente autônomo).
// Não editar o schema.prisma final — apenas este fragment.
// O Coordenador compõe o schema via scripts/compose-tenant-schema.ts.

// ---------------------------------------------------------------------------
// GabiConversation — conversa principal da Gabi com o usuário no tenant
// ---------------------------------------------------------------------------

model GabiConversation {
  id         String @id @default(cuid())
  tenant_id  String
  product_id String?
  user_id    String?

  title      String?
  
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  messages   GabiMessage[]

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
}

// ---------------------------------------------------------------------------
// GabiMessage — mensagem individual da conversa
// ---------------------------------------------------------------------------

model GabiMessage {
  id              String @id @default(cuid())
  tenant_id       String
  product_id      String?
  user_id         String?

  conversation_id String
  conversation    GabiConversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  role            String   // 'user' | 'assistant' | 'system'
  content         String   @db.Text
  attachments     String?  // JSON encodado com links/detalhes de arquivos

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
  @@index([conversation_id])
}

// ---------------------------------------------------------------------------
// GabiUsageLog (SnapshotAuditoria) — auditoria obrigatória de toda execução
// ---------------------------------------------------------------------------

model GabiUsageLog {
  id                    String @id @default(cuid())
  tenant_id             String
  product_id            String?
  user_id               String?

  action_taken          String
  conversation_snapshot String  @db.Text // JSON com contexto da conversa obrigatório
  actor_type            String  @default("gabi") // sempre 'gabi'
  triggered_by          String  // ID do usuário original

  created_at            DateTime @default(now())
  
  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
}
