// --- Fragment: historico-global ---
model HistoricoLog {
  id             String      @id @default(cuid())
  tenant_id      String

  // Ator
  actor_type     AcaoExecutadaPor
  actor_id       String
  actor_name     String
  actor_ip       String?
  actor_metadata Json?

  // Recurso
  module         String
  resource_type  String
  resource_id    String?

  // Ação
  action         String
  action_detail  String

  // Estado antes/depois
  before         Json?
  after          Json?

  // Resultado
  status         EventoStatus @default(SUCESSO)
  error_message  String?

  // Integridade
  integrity_hash String

  // Referências para queries e visibilidade por role
  product_id     String?
  user_id        String?

  created_at     DateTime    @default(now()) @db.Timestamptz

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
  @@index([tenant_id, created_at])
  @@index([tenant_id, module, created_at])
  @@index([actor_id, created_at])
  @@map("historico_log")
}

model AlertRule {
  id                       String     @id @default(cuid())
  tenant_id                String?

  name                     String
  description              String?
  enabled                  Boolean    @default(true)

  // Filtro da regra (null = qualquer valor)
  actor_type               AcaoExecutadaPor?
  action                   String?
  module                   String?
  status_filter            EventoStatus?

  // Threshold
  threshold_count          Int?
  threshold_window_seconds Int?

  // Canais ativos por regra
  channel_inapp            Boolean    @default(true)
  channel_email            Boolean    @default(false)
  channel_whatsapp         Boolean    @default(false)

  // Destinatários por canal
  recipients_email         String[]
  recipients_whatsapp      String[]
  recipients_user_ids      String[]

  created_at               DateTime   @default(now())
  updated_at               DateTime   @updatedAt

  alerts                   AlertEvent[]

  @@index([tenant_id, enabled])
  @@map("alerta_regra")
}

model AlertEvent {
  id             String      @id @default(cuid())
  tenant_id      String
  rule_id        String
  rule           AlertRule   @relation(fields: [rule_id], references: [id])

  actor_type     AcaoExecutadaPor
  actor_id       String
  actor_name     String
  module         String
  action         String
  event_count    Int
  window_seconds Int
  audit_log_ids  String[]

  status         AlertaStatus @default(PENDENTE)
  reviewed_by    String?
  reviewed_at    DateTime?
  notes          String?

  created_at     DateTime    @default(now())

  notifications  AlertNotificationLog[]

  @@index([tenant_id, status])
  @@index([tenant_id, created_at])
  @@map("alerta_data")
}

model AlertNotificationLog {
  id             String     @id @default(cuid())
  alert_event_id String
  alert_event    AlertEvent @relation(fields: [alert_event_id], references: [id])

  channel        String
  recipient      String
  status         String     @default("pending")
  attempts       Int        @default(1)
  error_message  String?
  sent_at        DateTime?

  created_at     DateTime   @default(now())

  @@index([alert_event_id])
  @@map("alerta_registro")
}

enum AcaoExecutadaPor {
  USUARIO
  API
  IA
  JOB
  INTEGRACAO
}

enum EventoStatus {
  SUCESSO
  FALHA
  PARCIAL
}

enum AlertaStatus {
  PENDENTE
  REVISADO
  ESCALADO
}

/// Resultado de exportação em background (acima de 10k registros).
/// Persiste no banco para sobreviver a restarts do Railway (alternativa ao /tmp).
model ExportarResultado {
  id           String   @id @default(cuid())
  tenant_id    String
  format       String   // 'csv' | 'json'
  content      String   @db.Text
  status       String   @default("processing") // 'processing' | 'ready' | 'failed'
  record_count Int      @default(0)
  filters      Json?
  error        String?
  created_at   DateTime @default(now())
  expires_at   DateTime // cleanup job remove após 24h

  @@index([tenant_id, status])
  @@index([expires_at])
  @@map("exportar_resultado")
}


// --- Fragment: agendamento ---
model Agenda {
  id          String   @id @default(cuid())
  tenant_id   String
  nome        String
  descricao   String?
  tipo        String   // e.g., reuniao, consulta
  criadoEm    DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  slots       Slot[]
  config      DisponibilidadeConfig?

  @@index([tenant_id])
  @@map("agenda_usuario")
}

model Slot {
  id          String   @id @default(cuid())
  tenant_id   String
  agenda_id   String
  inicio      DateTime
  fim         DateTime
  capacidade  Int      @default(1)
  criadoEm    DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  agenda      Agenda   @relation(fields: [agenda_id], references: [id], onDelete: Cascade)
  reservas    Reserva[]

  @@index([tenant_id])
  @@index([agenda_id])
  @@map("horario_disponivel")
}

model Reserva {
  id          String   @id @default(cuid())
  tenant_id   String
  slot_id     String
  usuario_id  String   // ID do usuário ou contato
  nome        String?  // Nome se não tiver usuário cadastrado no sistema
  email       String?  // Email para notificação
  status      String   @default("confirmado") // confirmado, cancelado, pendente
  criadoEm    DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  slot        Slot     @relation(fields: [slot_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([slot_id])
  @@index([usuario_id])
  @@map("reserva_agenda")
}

model DisponibilidadeConfig {
  id             String   @id @default(cuid())
  tenant_id      String
  agenda_id      String   @unique
  horarioInicio  String   // Formato "HH:mm" (e.g., "09:00")
  horarioFim     String   // Formato "HH:mm" (e.g., "18:00")
  duracaoSlot    Int      // em minutos
  intervalo      Int      @default(0) // tempo entre slots em minutos
  diasSemana     Int[]    // [1,2,3,4,5] (1=Segunda, 5=Sexta)
  criadoEm       DateTime @default(now())
  atualizadoEm   DateTime @updatedAt

  agenda         Agenda   @relation(fields: [agenda_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@map("config_disponibilidade_agenda")
}


// --- Fragment: gabi ---
// servicos-global/tenant/gabi/prisma/fragment.prisma
// AGENTE GABI — ONDA 3 | 10/13
//
// Fragment Prisma para o serviço da Gabi AI (agente autônomo).
// Não editar o schema.prisma final — apenas este fragment.
// O Coordenador compõe o schema via scripts/ativamente/compose-tenant-schema.ts.

// ---------------------------------------------------------------------------
// ConversaCompletaGabi — conversa principal da Gabi com o usuário no tenant
// ---------------------------------------------------------------------------

model ConversaCompletaGabi {
  id         String @id @default(cuid())
  tenant_id  String
  product_id String?
  user_id    String?

  title      String?
  
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  messages   MensagemIndividualGabiai[]

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
  @@map("conversa_completa_gabi")
}

// ---------------------------------------------------------------------------
// MensagemIndividualGabiai — mensagem individual da conversa
// ---------------------------------------------------------------------------

model MensagemIndividualGabiai {
  id              String @id @default(cuid())
  tenant_id       String
  product_id      String?
  user_id         String?

  conversation_id String
  conversation    ConversaCompletaGabi @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  role            String   // 'user' | 'assistant' | 'system'
  content         String   @db.Text
  attachments     String?  // JSON encodado com links/detalhes de arquivos

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
  @@index([conversation_id])
  @@map("mensagem_individual_gabiai")
}

// ---------------------------------------------------------------------------
// GabiaLogUso (SnapshotAuditoria) — auditoria obrigatória de toda execução
// Campos model_used/tokens_input/tokens_output/cost_usd adicionados para
// compatibilidade com usage.ts
// ---------------------------------------------------------------------------

model GabiaLogUso {
  id                    String @id @default(cuid())
  tenant_id             String
  product_id            String?
  user_id               String?

  action_taken          String
  conversation_snapshot String  @db.Text
  actor_type            String  @default("gabi")
  triggered_by          String

  // Campos de custo (usados por usage.ts)
  model_used            String?
  tokens_input          Int     @default(0)
  tokens_output         Int     @default(0)
  cost_usd              Float   @default(0)

  created_at            DateTime @default(now())

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
  @@map("gabiai_log_uso")
}

// ---------------------------------------------------------------------------
// GabiaTokenConsumidos — registro de cada chamada field-help (on-demand)
// ---------------------------------------------------------------------------

model GabiaTokenConsumidos {
  id             String   @id @default(cuid())
  tenant_id      String
  product_id     String
  user_id        String
  campo          String
  tokens_input   Int
  tokens_output  Int
  tokens_total   Int
  mes_ref        String   // "2026-04" — para agrupamento mensal
  created_at     DateTime @default(now())

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, mes_ref])
  @@map("gabiai_token_consumidos")
}

// ---------------------------------------------------------------------------
// GabiaTokenWorkspace — quota mensal por tenant (verificada em tempo real)
// ---------------------------------------------------------------------------

model GabiaTokenWorkspace {
  id             String   @id @default(cuid())
  tenant_id      String
  product_id     String
  quota_mensal   Int      // padrão do produto, sobrescrito por negociação
  mes_ref        String   // "2026-04"
  tokens_usados  Int      @default(0)
  updated_at     DateTime @updatedAt

  @@unique([tenant_id, product_id, mes_ref])
  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, mes_ref])
  @@map("gabiai_token_workspace")
}

// ---------------------------------------------------------------------------
// PersonalizacaoOrganizacaoGabiai — persona/comportamento Gabi por tenant
// ---------------------------------------------------------------------------

model PersonalizacaoOrganizacaoGabiai {
  id                String   @id @default(cuid())
  tenant_id         String   @unique
  product_id        String?
  system_prompt     String?  @db.Text
  tom_voz           String?
  limitacoes        String?  @db.Text
  instrucoes_extras String?  @db.Text
  ativo             Boolean  @default(true)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  @@index([tenant_id])
  @@map("personalizacao_organizacao_gabiai")
}


// --- Fragment: preferencias-usuario ---
// servicos-global/tenant/preferencias-usuario/prisma/fragment.prisma
// SERVIÇO PREFERÊNCIAS DO USUÁRIO
//
// Fragment Prisma para persistência cross-device de preferências de UI.
// IDs de usuário vêm do Clerk (user.id).
// Não editar o schema.prisma final — apenas este fragment.
// O Coordenador compõe o schema via scripts/ativamente/compose-tenant-schema.ts.

// ---------------------------------------------------------------------------
// UserPreferences — preferências de UI persitidas por usuário (cross-device)
// ---------------------------------------------------------------------------

model UserPreferences {
  id         String  @id @default(cuid())

  // Identificação — obrigatórios
  // user_id = Clerk user ID (ex: user_2abc...)
  user_id    String  @unique
  tenant_id  String

  // ── Preferências de UI ──────────────────────────────────────────────────
  // Visibilidade global das tooltips/dicas
  tooltips_disabled Boolean @default(false)

  // Tema preferido ('dark' | 'light')
  theme             String  @default("dark")

  // Sidebar aberta ou fechada
  sidebar_open      Boolean @default(true)

  // Timestamps
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([user_id])
  @@index([tenant_id])
  @@index([tenant_id, user_id])
  @@map("preferencia_workspace")
}


// --- Fragment: ncm-sync ---
// servicos-global/tenant/ncm-sync/prisma/fragment.prisma
// NcmItem  — tabela NCM cacheada do Portal Único Siscomex (atualizada diariamente)
// NcmSyncLog — histórico de cada sincronização com o Portal Único

model NcmItem {
  id          String   @id @default(cuid())
  tenant_id   String
  product_id  String?
  user_id     String?

  codigo      String   // 8 dígitos — ex: "84713019"
  descricao   String
  ativo       Boolean  @default(true)

  // Metadados do Portal Único
  data_inicio DateTime?
  data_fim    DateTime?
  sync_id     String   // referência ao NcmSyncLog que inseriu/atualizou

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@unique([tenant_id, codigo])
  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
  @@index([tenant_id, ativo])
  @@index([tenant_id, codigo])
  @@map("ncm_item")
}

model NcmSyncLog {
  id           String    @id @default(cuid())
  tenant_id    String
  product_id   String?
  user_id      String?

  iniciado_em  DateTime  @default(now())
  concluido_em DateTime?

  status       NCMStatusSincronizacao @default(EXECUTANDO)

  // Totais do diff
  total        Int @default(0)
  adicionados  Int @default(0)
  alterados    Int @default(0)
  removidos    Int @default(0)

  // Origem do trigger
  origem       NCMOrigemSincronizacao @default(JOB)  // 'JOB' | 'MANUAL'
  disparado_por String?  // user_id se MANUAL

  erro_msg     String?

  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
  @@index([tenant_id, status])
  @@index([tenant_id, iniciado_em])
  @@map("ncm_log")
}

enum NCMStatusSincronizacao {
  EXECUTANDO
  SUCESSO
  ERRO
}

enum NCMOrigemSincronizacao {
  JOB
  MANUAL
}

// ── NcmScheduleConfig — configuração singleton do job de sincronização NCM ───
// id = 'default' — registro único (singleton global do sistema)
// tenant_id = '__system__' — satisfaz padrão de índices obrigatórios

model NcmScheduleConfig {
  id             String   @id @default("default")
  tenant_id      String   @default("__system__")
  product_id     String?
  user_id        String?

  ativo          Boolean  @default(false)
  cron_expressao String   @default("0 2 * * *")   // 2am diário (America/Sao_Paulo)
  notificadores  Json     @default("[]")            // NcmNotificador[]

  criado_em      DateTime @default(now())
  atualizado_em  DateTime @updatedAt

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
  @@map("ncm_agendamento")
}


// --- Fragment: notificacoes ---
model NotificacoesTituloCorpo {
  id          String   @id @default(cuid())
  tenant_id   String
  product_id  String?
  user_id     String   // Clerk ID or direct email
  type        String   // mentioned | task-assigned | reminder | next-step | etc.
  title       String?
  message     String
  read        Boolean  @default(false)

  // ── Context link (Pilar 2) ─────────────────────────────────────────────────
  // Nunca salvar URL strings. Salvar entidade + ID e construir URL no frontend.
  target_entity  String?  // "PEDIDO" | "ITEM" | "SIMULACUSTO" | "PROCESSO" | etc.
  target_id      String?  // ID da entidade no banco

  // ── Delivery tracking (Pilar 3) ────────────────────────────────────────────
  // delivery_status: ciclo de vida do envio de email/whatsapp
  // pending → sent → delivered | bounced | failed
  delivery_status  String   @default("pending")  // pending | sent | delivered | bounced | failed
  external_id      String?  // ID da mensagem no Resend (para reconciliar webhooks)

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
  @@index([tenant_id, user_id, read])
  @@index([tenant_id, created_at])
  @@index([tenant_id, delivery_status])
  @@index([external_id])
  @@map("notificacoes_titulo_corpo")
}

// ─── Contatos externos (email / WhatsApp) ─────────────────────────────────
// Agenda de contatos por tenant. Usada pelo sininho para enviar notificações a
// pessoas que não são usuários do sistema (e-mail ou WhatsApp).
// whatsapp_opt_in_at: consentimento explícito exigido pela LGPD (Art. 8).
model ExternalContact {
  id                 String    @id @default(cuid())
  tenant_id          String
  created_by         String    // Clerk user_id
  name               String    @db.VarChar(200)
  email              String?   @db.VarChar(255)
  whatsapp_phone     String?   @db.VarChar(20)  // E.164: +5511999999999
  whatsapp_opt_in_at DateTime? // LGPD Art. 8 — consentimento explícito
  notes              String?   @db.VarChar(500)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([tenant_id])
  @@index([tenant_id, created_by])
  @@index([tenant_id, email])
  @@index([tenant_id, whatsapp_phone])
  @@map("contato_externo")
}

// ─── Configuração de canais por tenant ────────────────────────────────────
// Controlado exclusivamente pelo usuário com role MASTER.
// email_enabled default true (backward compat). whatsapp_enabled default false.
model TenantChannelConfig {
  id               String  @id @default(cuid())
  tenant_id        String  @unique
  email_enabled    Boolean @default(true)
  whatsapp_enabled Boolean @default(false)
  updated_by       String? // Clerk user_id do master que alterou

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([tenant_id])
  @@map("configuracao_canal_tenant")
}
