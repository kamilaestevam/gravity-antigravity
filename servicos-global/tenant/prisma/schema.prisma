  actor_id       String
  actor_name     String
  actor_ip       String?
  actor_metadata Json?

  // Recurso
  module         String
  resource_type  String
  resource_id    String?

  // Ação
  action         String
  action_detail  String

  // Estado antes/depois
  before         Json?
  after          Json?

  // Resultado
  status         EventoStatus @default(SUCESSO)
  error_message  String?

