// --- Fragment: processos-core ---
// fragment.prisma — Processos, Gestão de Pedidos e Rastreador
// COMPONENT: servicos-global/tenant/processos-core
// MÓDULOS: Pedido de Compra/Venda, Tarefas Logísticas, Containers, Faturas.

// ============================================
// 1. GERENCIADOR DE PEDIDOS
// ============================================
model Pedido {
  id         String @id // (O Chassi / Robôs) Chave Primária PK. Ex: pedi_id_0000001/26
  tenant_id  String // (O Workspace/Filial) Importador ou Exportador
  company_id String // (A Organização Matriz) Dona da Assinatura do Software

  tipo_operacao String // importacao (PO - Purchase Order) | exportacao (SO - Sales Order)
  numero_pedido String // (A Placa / Humanos) Referência Comercial. Ex: PO-8912, N° Pedido Totvs
  status        String @default("aberto") // aberto, transferencia, consolidado, cancelado
  status_id     String? // FK to PedidoStatus (null = built-in status)

  // Parceiros Negociais Internacionais
  importacao_exportador_id String? // Se importacao: A Fábrica/Fornecedor (Exterior)
  exportacao_importador_id String? // Se exportacao: O Cliente Final (Exterior)
  fabricante_id            String? // Fabricante do produto (pode diferir do exportador)

  // DADOS COMERCIAIS GLOBAIS (Capa do Pedido)
  incoterm                          String?
  moeda_pedido                      String  @default("USD") // Lista de moedas padrão do sistema gravity
  valor_total_pedido                Decimal? @db.Decimal(18,6) // O somatório de todos os valores totais dos itens do pedido
  casas_decimais_valor_pedido       Int     @default(2) // Precisão (Ex: 3)
  quantidade_total_inicial_pedido   Decimal? @db.Decimal(18,6) // O somatório de todas as quantidades comercializadas dos itens do pedido
  casas_decimais_quantidade_pedido  Int     @default(2) // Precisão (Ex: 3)
  unidade_comercializada_pedido     String? // Ex: TON, UN Lista de unidades padrão do sistema gravity

  // DADOS FÍSICOS TOTAIS (sum(peso_*_unitario × quantidade_inicial) dos itens)
  peso_liquido_total_pedido     Decimal? @db.Decimal(18,6)
  peso_bruto_total_pedido       Decimal? @db.Decimal(18,6)
  cubagem_total_pedido          Decimal? @db.Decimal(18,6)
  casas_decimais_peso_pedido    Int      @default(3)
  casas_decimais_cubagem_pedido Int      @default(3)

  // DADOS FINANCEIROS & FECHAMENTO DE CÂMBIO (FX)
  condicao_pagamento_pedido String? // Ex: 30% Antecipado, 70% Contra-Documento

  // Referências Documentais
  numero_proforma         String? // Número da Proforma Invoice
  numero_invoice          String? // Número da Commercial Invoice
  referencia_importador   String? // Referência interna do importador
  referencia_exportador   String? // Referência interna do exportador
  referencia_fabricante   String? // Referência do fabricante

  valor_total_cambio_pedido   Decimal? @db.Decimal(18,6) // O montante do boleto cambial real fechado
  moeda_cambio_pedido         String? // Padrão cruzado: Ex: BRL (Saindo) -> USD (Comprando)
  taxa_cambio_estimada_pedido Decimal? @db.Decimal(18,6) // A PTAX alvo/estimada na hora do fechamento da PO
  contrato_cambio_id_pedido   String? // [FOREIGN KEY] Aponta para a tabela 'ContratoCambio'

  data_emissao_pedido DateTime @default(now()) // Nome corrigido sem barra/hifen

  cnpj_importador String? // CNPJ do importador (quando tipo_operacao = exportacao)

  // --- METADADOS POLIMÓRFICOS (AGILITY TIER 1) ---
  detalhes_operacionais Json? // Absorve atributos customizados de Exportador/Fabricante
  campos_custom         Json? // custom columns storage (JSONB + GIN index in SQL)

  // Consolidação (preenchido quando este pedido é resultado de merge)
  pedidos_origem_id        Json?     // IDs dos pedidos originais consolidados
  data_consolidacao_pedido DateTime? // Momento da consolidação

  // Soft delete (preenchido quando o pedido é consolidado em outro)
  deleted_at DateTime? // null = ativo; data = soft-deleted (consolidado em outro pedido)

  // Lista Fatiável de Itens (A ORDEM 1:N SALVA!)
  itens          PedidoItem[]

  pedido_criado_em    DateTime @default(now())
  pedido_atualizado_em DateTime @updatedAt

  @@index([tenant_id])
  @@index([tenant_id, company_id])
  @@index([tenant_id, status])
  @@index([tenant_id, status_id])
  @@index([tenant_id, tipo_operacao])
  @@index([tenant_id, data_emissao_pedido])
  @@index([tenant_id, deleted_at])
  @@map("pedidos_comerciais")
}

// O Gestor completo de Pedidos
model PedidoItem {
  id         String @id // (O Chassi / Robôs) PK da Linha do Pedido. Ex: pite_id_00001/26
  tenant_id  String
  company_id String
  pedido_id  String // (Fio Invisível/Máquina) Aponta silenciosamente para o 'id' do Pedido Pai

  // Identidade do Produto (Padrão Ouro de Comércio Exterior)
  sequencia_item              Int?    // Sequencial da Linha no Documento/Processo (Ex: 1, 2, 3)
  part_number                 String  // Chave do cadastro interno (SKU Interno Estável)
  ncm                         String  // Classificação Fiscal
  descricao_item              String
  unidade_comercializada_item String? // Ex: TON, UN Lista de unidades padrão do sistema gravity

  // Controle de Quantidades
  quantidade_inicial_item_pedido      Decimal @db.Decimal(18,6)
  saldo_item_pedido                   Decimal @db.Decimal(18,6)
  quantidade_pronta_total_item_pedido Decimal @default(0) @db.Decimal(18,6)
  quantidade_transferida_item_pedido  Decimal @default(0) @db.Decimal(18,6)
  quantidade_cancelada_item_pedido    Decimal @default(0) @db.Decimal(18,6)
  casas_decimais_quantidade_item      Int     @default(2)

  // Valores da Linha
  moeda_item              String   @default("USD")
  valor_total_itens       Decimal? @db.Decimal(18,6) // somatório desta linha (unitário × quantidade)
  valor_unitario_item     Decimal? @db.Decimal(18,6)
  casas_decimais_valor_item Int    @default(2)
  cobertura_cambial         String @default("com_cobertura") // com_cobertura | sem_cobertura

  // Dados Físicos Unitários (usados para calcular totais do pedido)
  peso_liquido_unitario_item  Decimal? @db.Decimal(18,6)
  peso_bruto_unitario_item    Decimal? @db.Decimal(18,6)
  cubagem_unitaria_item       Decimal? @db.Decimal(18,6)
  casas_decimais_peso_item    Int      @default(3)
  casas_decimais_cubagem_item Int      @default(3)

  // Descrições multilíngues
  descricao_completa_item_pt String?
  descricao_completa_item_en String?
  descricao_completa_item_es String?
  descricao_completa_item_nf String?

  // Classificação interna
  grupo_item        String?
  subgrupo_item     String?
  campo_especial_item String?

  campos_custom Json? // custom columns storage

  pedido             Pedido         @relation(fields: [pedido_id], references: [id], onDelete: Cascade)
  embarques_efetivos ProcessoItem[]

  item_criado_em    DateTime @default(now())
  item_atualizado_em DateTime @updatedAt

  @@index([tenant_id])
  @@index([tenant_id, company_id])
  @@index([pedido_id])
  @@map("pedido_itens")
}

// ============================================
// 2. LOGÍSTICA INTERNACIONAL (O PROCESSO)
// ============================================
model Processo {
  id         String @id // (O Chassi / Robôs) Chave Primária PK. Ex: proc_id_0000001/26
  tenant_id  String
  company_id String

  // ALONGAMENTO STANDALONE (Os Módulos Casam Aqui!)
  estimativa_custo_id String? // Trás o SimulaCusto que originou a operação
  cotacao_frete_id    String? // A Proposta Antiga do BID Fretes

  // DADOS ESTRUTURAIS DO EMBARQUE
  status_embarque     String  @default("aberto")
  tipo_operacao       String // importacao | exportacao (Muda a visão de Due x Duimp)
  referencia_processo String? // Padrão Sequencial: 000000001/26
  numero_processo     String? // (A Placa / Humanos) Número Público Customizável. Ex: IMP-24-001

  responsavel_processo String?
  responsavel_rotina   String?
  setor_responsavel    String?
  vendedor_responsavel String?
  canal_parametrizacao String? // Verde, Amarelo, Vermelho, Cinza

  // ENTIDADES DO CARGUEIRO (Parceiros Externos do seu Comex)
  importacao_exportador_id            String?
  exportacao_importador_id            String?
  agente_carga_id                     String?
  armador_id                          String?
  cia_aerea_id                        String?
  transportador_rodo_internacional_id String?
  transportador_rodo_nacional_id      String?
  transportador_ferroviario_id        String?
  despachante_id                      String?
  armazem_alfandegado_id              String?
  securadora_internacional_id         String?
  banco_id                            String?
  corretora_cambio_id                 String?

  moeda_pedido                String  @default("USD")
  valor_total_pedido          Float?
  incoterm                    String?
  premio_seguro_internacional Decimal? @db.Decimal(18,6)

  // LOGÍSTICA DE FRETE
  modal_frete_internacional                     String? // Maritimo LCL, Maritimo FCL, Aereo, Rodoviario, Ferroviario
  porto_origem                                  String?
  porto_transbordo                              String? // Corrigido typo (transporto -> transbordo)
  porto_destino                                 String?
  aeroporto_origem                              String?
  aeroporto_escala                              String?
  aeroporto_destino                             String?
  transit_time_previsto_frete_internacional     Int?
  moeda_frete_internacional                     String? @default("USD")
  tipo_frete_internacional                      String? // collect / prepaid
  proposta_frete_internacional                  String?
  valor_frete_internacional_estimado            Decimal? @db.Decimal(18,6)
  valor_total_frete_internacional               Decimal? @db.Decimal(18,6)
  valor_total_taxas_origem_frete_internacional  Decimal? @db.Decimal(18,6)
  valor_total_taxas_destino_frete_internacional Decimal? @db.Decimal(18,6)

  // DADOS DA CARGA FÍSICA GLOBAL
  tipo_volume              String? // caixa, container, pallet, etc. Lista padrão de volumes do gravity
  quantidade_total_volumes Int?    @default(0)
  peso_bruto_total         Decimal? @default(0) @db.Decimal(18,6)
  peso_liquido_total       Decimal? @default(0) @db.Decimal(18,6)

  // A LINHA DO TEMPO (TRACKING ABSOLUTO - MASTER COMEX)
  data_pedido                            DateTime?
  data_pedido_aberto                     DateTime? @default(now())
  data_previsao_pedido                   DateTime?
  data_pedido_pronto                     DateTime?
  data_pedido_consolidado                DateTime?
  data_previsao_coleta_pedido_origem     DateTime?
  data_coleta_pedido_origem              DateTime?
  data_previsao_entrega_pedido_origem    DateTime?
  data_entrega_pedido_origem             DateTime?
  data_previsao_carregamento_container   DateTime?
  data_carregamento_container            DateTime?
  data_previsao_coleta_embarque_origem   DateTime?
  data_coleta_embarque_origem            DateTime?
  data_previsao_entrega_embarque_origem  DateTime?
  data_entrega_embarque_origem           DateTime?
  data_previsao_coleta_container_origem  DateTime?
  data_coleta_container_origem           DateTime?
  data_previsao_entrega_container_origem DateTime?
  data_entrega_container_origem          DateTime?
  data_previsao_embarque_origem_etd      DateTime?
  data_embarque_origem                   DateTime?
  data_previsao_transbordo_embarque      DateTime?
  data_transbordo_embarque               DateTime?
  data_previsao_chegada_destino_eta      DateTime?
  data_chegada_destino_eta               DateTime?
  data_previsao_presenca_carga_destino   DateTime?
  data_presenca_carga_destino            DateTime?
  data_previsao_registro_duimp           DateTime?
  data_registro_duimp                    DateTime?
  data_previsao_liberacao_duimp          DateTime?
  data_liberacao_duimp                   DateTime?
  data_consulta_liberacao_duimp          DateTime?
  data_previsao_registro_lpco            DateTime?
  data_registro_lpco                     DateTime?
  data_deferimento_lpco                  DateTime?
  data_indeferimento_lpco                DateTime?
  data_pendencia_lpco                    DateTime?
  data_consulta_liberacao_lpco           DateTime?

  // DOCUMENTAÇÃO LOGÍSTICA & ALFANDEGÁRIA
  numero_certificado_origem     String?
  numero_bl                     String?
  numero_mbl                    String?
  numero_hbl                    String?
  numero_awb                    String?
  numero_mawb                   String?
  numero_hawb                   String?
  numero_crt                    String?
  numero_cim                    String?
  numero_ce_mercante            String?
  numero_presenca_carga_destino String?
  numero_duimp                  String?
  numero_nfe                    String?
  chave_acesso_nfe              String?
  // NOTA: Invoices foram para ProcessoFatura e Containers para ProcessoContainer

  // Tributos Acumulados
  total_imposto_ii     Decimal? @default(0) @db.Decimal(18,6)
  total_imposto_ipi    Decimal? @default(0) @db.Decimal(18,6)
  total_imposto_pis    Decimal? @default(0) @db.Decimal(18,6)
  total_imposto_cofins Decimal? @default(0) @db.Decimal(18,6)
  total_imposto_icms   Decimal? @default(0) @db.Decimal(18,6)

  // --- METADADOS POLIMÓRFICOS (AGILITY TIER 1) ---
  detalhes_fiscais     Json?  // (Absorve os 300 campos da DUIMP, NF, MAPA...)
  detalhes_logisticos  Json?  // (Absorve os 100 campos do Frete, VGM e Seguros...)
  detalhes_financeiros Json?  // (Absorve ROF, Parcelas Câmbio e Impostos detalhados...)

  // Camadas de Execução (Restauradas para suportar 1:N)
  faturas        ProcessoFatura[]
  containers     ProcessoContainer[]
  itens_processo ProcessoItem[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([tenant_id])
  @@index([company_id])
  @@index([tenant_id, company_id])
  @@map("processos_logisticos")
}

model ProcessoFatura {
  id          String @id // Formato padrão: fatu_id_00001/26
  tenant_id   String
  company_id  String
  processo_id String

  tipo_fatura   String // proforma | commercial_invoice | freight_invoice | tax_invoice
  numero_fatura String // (Acomoda os 'numero_commercial_invoice', etc)
  moeda_fatura  String @default("USD")
  valor_total   Decimal @db.Decimal(18,6)
  valor_pago    Decimal @default(0) @db.Decimal(18,6)

  data_vencimento  DateTime?
  status_pagamento String    @default("pendente") // pendente, pago, parcial

  processo Processo @relation(fields: [processo_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, company_id])
  @@index([tenant_id, processo_id])
  @@map("processo_faturas")
}

model ProcessoItem {
  id          String @id // Formato padrão: prit_id_00001/26 (ProcessoItem)
  tenant_id   String
  company_id  String
  processo_id String

  pedido_item_id String? // O Elo Dourado com o Comercial

  sequencia_item Int?
  part_number    String
  ncm            String
  descricao_po   String
  descricao_en   String?

  quantidade                  Decimal @db.Decimal(18,6)
  unidade_comercializada_item String?
  valor_unitario              Decimal @db.Decimal(18,6)
  valor_total                 Decimal @db.Decimal(18,6)

  peso_liquido_unitario Decimal? @db.Decimal(18,6)
  peso_bruto_unitario   Decimal? @db.Decimal(18,6)

  // --- METADADOS POLIMÓRFICOS (AGILITY TIER 1) ---
  detalhes_do_produto Json? // Absorve Especificações, Lotes e Campos Extensos da NCM

  processo    Processo    @relation(fields: [processo_id], references: [id], onDelete: Cascade)
  pedido_item PedidoItem? @relation(fields: [pedido_item_id], references: [id])

  @@index([tenant_id, company_id])
  @@index([processo_id])
  @@index([pedido_item_id])
  @@map("processo_itens")
}

model ProcessoContainer {
  id          String @id // Formato padrão: cont_id_00001/26
  tenant_id   String
  company_id  String
  processo_id String

  numero_container String
  numero_lacre     String?
  tipo_container   String // 20Dry, 40HQ, 40Nor, LCL
  tara             Decimal? @db.Decimal(18,6)
  peso_bruto       Decimal? @db.Decimal(18,6)

  data_devolucao_prevista DateTime?
  data_devolucao_real     DateTime?
  local_devolucao         String?

  processo Processo @relation(fields: [processo_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, company_id])
  @@index([processo_id])
  @@map("processo_containers")
}

// ============================================
// 5. CONFIGURAÇÃO DA TABELA DE PEDIDOS
// ============================================

// Status customizável por tenant (as "abas" da tabela)
model PedidoStatus {
  id         String   @id @default(cuid())
  tenant_id  String
  company_id String?

  nome       String   // slug/valor: "aguardando_embarque"
  rotulo     String   // label exibido: "Aguardando Embarque"
  cor        String   // hex: "#6366F1"
  icone      String?  // nome do ícone Phosphor
  ordem      Int      @default(0)
  is_padrao  Boolean  @default(false) // status aplicado em novos pedidos
  is_sistema Boolean  @default(false) // status built-in que não pode ser deletado

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([tenant_id, nome])
  @@index([tenant_id])
  @@index([tenant_id, company_id])
  @@map("pedido_status")
}

// Colunas customizadas criadas pelo tenant (até 30 por tenant)
model PedidoColuna {
  id         String   @id @default(cuid())
  tenant_id  String
  company_id String?

  nome           String   // slug interno (nunca usado em SQL direto, só como key no JSONB)
  rotulo         String   // label exibido ao usuário
  tipo           String   // 'texto' | 'numero' | 'data' | 'select' | 'booleano'
  casas_decimais Int      @default(2)  // para tipo 'numero'
  opcoes         Json?    // para tipo 'select': [{valor, rotulo}]
  ordem          Int      @default(0)
  filtravel      Boolean  @default(true)
  exibida_padrao Boolean  @default(false)
  index_criado   Boolean  @default(false) // true quando expression index foi criado no PG

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([tenant_id, nome])
  @@index([tenant_id])
  @@index([tenant_id, company_id])
  @@map("pedido_colunas")
}

// Preferência de colunas por usuário (persistência cross-device)
model PedidoPreferenciaUsuario {
  id         String   @id @default(cuid())
  tenant_id  String
  company_id String?
  user_id    String   // clerk_id do usuário

  colunas_visiveis String[]  // keys das colunas visíveis, na ordem
  colunas_largura  Json?     // {key: larguraEmPx}

  updated_at DateTime @updatedAt

  @@unique([tenant_id, user_id])
  @@index([tenant_id])
  @@index([tenant_id, user_id])
  @@map("pedido_preferencias_usuario")
}

// Preferência padrão de colunas por workspace (fallback quando usuário não tem preferência)
model PedidoPreferenciaPadrao {
  id         String   @id @default(cuid())
  tenant_id  String
  company_id String?

  colunas_visiveis String[]
  colunas_largura  Json?

  updated_at DateTime @updatedAt

  @@unique([tenant_id])
  @@index([tenant_id])
  @@map("pedido_preferencias_padrao")
}

// Regras de negócio configuráveis por tenant (duplicar, excluir, transferir, consolidar)
model ConfiguracaoPedido {
  id         String   @id @default(cuid())
  tenant_id  String
  company_id String?

  // Duplicar
  duplicar_numero_auto      Boolean  @default(false)
  duplicar_copiar_datas     Boolean  @default(false)
  duplicar_status_inicial   String   @default("copiar") // "copiar" | "rascunho" | "aberto" | ...

  // Excluir
  excluir_status_permitidos    String[] @default(["rascunho", "aberto", "em_andamento", "aprovado", "transferencia", "consolidado", "cancelado"])
  excluir_pedido_sem_item_permitido Boolean @default(true)
  excluir_confirmar_com_preview     Boolean @default(true)

  // Alertas
  alerta_numero_duplicado             Boolean @default(true)  // número de pedido repetido
  alerta_valor_total_divergente       Boolean @default(true)  // valor_total_pedido ≠ sum(valor_total_item)
  alerta_quantidade_total_divergente  Boolean @default(true)  // quantidade_total_inicial ≠ sum(quantidade_inicial_item)
  alerta_quantidade_pronta_divergente Boolean @default(true)  // quantidade_pronta_total ≠ sum(quantidade_pronta_item)
  alerta_peso_liquido_divergente      Boolean @default(true)  // peso_liquido_total ≠ sum(peso_liquido_unitario × qty)
  alerta_peso_bruto_divergente        Boolean @default(true)  // peso_bruto_total ≠ sum(peso_bruto_unitario × qty)
  alerta_cubagem_divergente           Boolean @default(true)  // cubagem_total ≠ sum(cubagem_unitaria × qty)

  updated_at DateTime @updatedAt

  @@unique([tenant_id])
  @@index([tenant_id])
  @@index([tenant_id, company_id])
  @@map("configuracao_pedido")
}

// Mapeamento de colunas de importacao salvo por tenant (Smart Import — Memoria)
// Associa hash dos cabecalhos de um arquivo ao mapeamento confirmado pelo usuario.
// Nas proximas importacoes com o mesmo arquivo, o mapeamento e aplicado automaticamente.
model MapeamentoImport {
  id           String   @id @default(cuid())
  tenant_id    String
  product_id   String?
  user_id      String?  // null = mapeamento compartilhado no workspace; preenchido = mapeamento pessoal

  hash_colunas String               // SHA256 (ou hash simples) dos cabecalhos ordenados
  mapeamento   String               // JSON serializado de ColunaMapeada[]
  uso_count    Int      @default(1) // quantas vezes o mapeamento foi utilizado

  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@unique([tenant_id, hash_colunas])
  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
  @@map("mapeamento_import")
}


// --- Fragment: ncm-sync ---
// servicos-global/tenant/ncm-sync/prisma/fragment.prisma
// NcmItem  — tabela NCM cacheada do Portal Único Siscomex (atualizada diariamente)
// NcmSyncLog — histórico de cada sincronização com o Portal Único

model NcmItem {
  id          String   @id @default(cuid())
  tenant_id   String
  product_id  String?
  user_id     String?

  codigo      String   // 8 dígitos — ex: "84713019"
  descricao   String
  ativo       Boolean  @default(true)

  // Metadados do Portal Único
  data_inicio DateTime?
  data_fim    DateTime?
  sync_id     String   // referência ao NcmSyncLog que inseriu/atualizou

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@unique([tenant_id, codigo])
  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
  @@index([tenant_id, ativo])
  @@index([tenant_id, codigo])
}

model NcmSyncLog {
  id           String    @id @default(cuid())
  tenant_id    String
  product_id   String?
  user_id      String?

  iniciado_em  DateTime  @default(now())
  concluido_em DateTime?

  status       NcmSyncStatus @default(RUNNING)

  // Totais do diff
  total        Int @default(0)
  adicionados  Int @default(0)
  alterados    Int @default(0)
  removidos    Int @default(0)

  // Origem do trigger
  origem       NcmSyncOrigem @default(JOB)  // 'JOB' | 'MANUAL'
  disparado_por String?  // user_id se MANUAL

  erro_msg     String?

  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
  @@index([tenant_id, status])
  @@index([tenant_id, iniciado_em])
}

enum NcmSyncStatus {
  RUNNING
  SUCCESS
  ERROR
}

enum NcmSyncOrigem {
  JOB
  MANUAL
}

// ── NcmScheduleConfig — configuração singleton do job de sincronização NCM ───
// id = 'default' — registro único (singleton global do sistema)
// tenant_id = '__system__' — satisfaz padrão de índices obrigatórios

model NcmScheduleConfig {
  id             String   @id @default("default")
  tenant_id      String   @default("__system__")
  product_id     String?
  user_id        String?

  ativo          Boolean  @default(false)
  cron_expressao String   @default("0 2 * * *")   // 2am diário (America/Sao_Paulo)
  notificadores  Json     @default("[]")            // NcmNotificador[]

  criado_em      DateTime @default(now())
  atualizado_em  DateTime @updatedAt

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
}


// --- Fragment: notificacoes ---
model Notification {
  id          String   @id @default(cuid())
  tenant_id   String
  product_id  String?  // nullable — applicable when related to a product
  user_id     String   // Clerk ID or direct email
  type        String   // mentioned | task-assigned | reminder | next-step | etc.
  title       String?
  message     String
  read        Boolean  @default(false)
  activity_id String?  // for direct navigation

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
  @@index([tenant_id, user_id, read])
  @@index([tenant_id, created_at])
}

// ─── Contatos externos (email / WhatsApp) ─────────────────────────────────
// Agenda de contatos por tenant. Usada pelo sininho para enviar notificações a
// pessoas que não são usuários do sistema (e-mail ou WhatsApp).
// whatsapp_opt_in_at: consentimento explícito exigido pela LGPD (Art. 8).
model ExternalContact {
  id                 String    @id @default(cuid())
  tenant_id          String
  created_by         String    // Clerk user_id
  name               String    @db.VarChar(200)
  email              String?   @db.VarChar(255)
  whatsapp_phone     String?   @db.VarChar(20)  // E.164: +5511999999999
  whatsapp_opt_in_at DateTime? // LGPD Art. 8 — consentimento explícito
  notes              String?   @db.VarChar(500)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([tenant_id])
  @@index([tenant_id, created_by])
  @@index([tenant_id, email])
  @@index([tenant_id, whatsapp_phone])
}

// ─── Configuração de canais por tenant ────────────────────────────────────
// Controlado exclusivamente pelo usuário com role MASTER.
// email_enabled default true (backward compat). whatsapp_enabled default false.
model TenantChannelConfig {
  id               String  @id @default(cuid())
  tenant_id        String  @unique
  email_enabled    Boolean @default(true)
  whatsapp_enabled Boolean @default(false)
  updated_by       String? // Clerk user_id do master que alterou

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([tenant_id])
}

model NotificationPreferences {
  id            String  @id @default(cuid())
  tenant_id     String
  product_id    String? // nullable — preferências podem ser globais por tenant ou específicas de produto
  user_id       String  // Clerk ID
  email_enabled Boolean @default(true)
  push_enabled  Boolean @default(true)
  wa_enabled    Boolean @default(true)

  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  // Uniqueness composta: dois tenants podem ter o mesmo Clerk user_id.
  // Antes era `user_id @unique` global — colisão entre tenants. Detetive de Tela
  // identificou na Onda 1 (item A9 / #13).
  @@unique([tenant_id, user_id, product_id])
  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
}
