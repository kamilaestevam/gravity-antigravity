// servicos-global/tenant/relatorios/prisma/fragment.prisma

model Relatorio {
  id         String   @id @default(cuid())
  tenant_id  String
  product_id String?
  user_id    String?

  nome       String
  tabelas    Json     @default("[]") // [{"productId":"simulador-comex", "tableId":"simulacoes"}]
  colunas    Json     @default("[]") // Colunas visíveis
  filtros    Json     @default("{}") // Filtros salvos
  join_type  String   @default("left")
  is_shared  Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
}

model ConfigRelatorio {
  id              String   @id @default(cuid())
  tenant_id       String
  product_id      String?
  user_id         String?

  relatorio_id    String
  frequencia      String   // once | daily | weekly | monthly
  canais          Json     // { email:[], whatsapp:[] }
  formato         String   @default("csv") // csv | excel | pdf
  ativo           Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
}

model ExportJob {
  id           String   @id @default(cuid())
  tenant_id    String
  product_id   String?
  user_id      String?

  relatorio_id String
  status       String   @default("PENDING") // PENDING, PROCESSING, DONE, FAILED
  formato      String   @default("csv")
  url_arquivo  String?
  erro         String?
  started_at   DateTime?
  completed_at DateTime?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])
}
