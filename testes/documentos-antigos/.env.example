# ============================================================
# Gravity — Variáveis de Ambiente (Raiz do Monorepo)
# ============================================================
# Copie este arquivo para .env e preencha com os valores reais.
# NUNCA faça commit do arquivo .env — ele está no .gitignore.
# ============================================================

# ── Ambiente ─────────────────────────────────────────────────
NODE_ENV=development
# LOG_LEVEL aceita: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ── Chave interna entre serviços (obrigatória em toda chamada s2s)
# Gere com: openssl rand -hex 32
INTERNAL_API_KEY=

# ─────────────────────────────────────────────────────────────
# CONFIGURADOR (porta 8001)
# ─────────────────────────────────────────────────────────────
PORT_CONFIGURADOR=8001

# Clerk — painel: https://dashboard.clerk.com
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# Stripe — painel: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Banco de dados do Configurador (PostgreSQL)
CONFIGURADOR_DATABASE_URL=postgresql://user:password@host:5432/gravity_configurador

# ─────────────────────────────────────────────────────────────
# SERVIÇOS TENANT (compartilham o mesmo banco por tenant)
# ─────────────────────────────────────────────────────────────
TENANT_DATABASE_URL=postgresql://user:password@host:5432/gravity_tenant

# Portas dos serviços tenant
PORT_DASHBOARD=8010
PORT_RELATORIOS=8011
PORT_CRONOMETRO=8012
PORT_NOTIFICACOES=8013
PORT_HISTORICO=8014
PORT_GABI=8015
PORT_API_COCKPIT=8016
PORT_CONECTOR_ERP=8017
PORT_AGENDAMENTO=8018
PORT_WHATSAPP=8019

# URL base do servidor de serviços tenant (para service-to-service)
TENANT_SERVICES_URL=http://localhost:3001

# ─────────────────────────────────────────────────────────────
# SIMULA-CUSTO — produto (porta 8020)
# ─────────────────────────────────────────────────────────────
PORT_SIMULA_CUSTO=8020
SIMULACUSTO_DATABASE_URL=postgresql://user:password@host:5432/gravity_simulacusto

# ─────────────────────────────────────────────────────────────
# MARKETPLACE — shell pública (porta 3000)
# ─────────────────────────────────────────────────────────────
PORT_MARKETPLACE=3000
# URL pública do configurador acessada pelo marketplace
NEXT_PUBLIC_CONFIGURADOR_URL=http://localhost:8001

# ─────────────────────────────────────────────────────────────
# INTEGRAÇÕES EXTERNAS
# ─────────────────────────────────────────────────────────────

# Resend — e-mail transacional: https://resend.com/api-keys
RESEND_API_KEY=re_...

# Meta / WhatsApp Cloud API: https://developers.facebook.com/apps
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# OpenAI (Gabi IA): https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ─────────────────────────────────────────────────────────────
# OBSERVABILIDADE
# ─────────────────────────────────────────────────────────────

# Sentry — monitoramento de erros: https://sentry.io
# Formato: https://<key>@o<org>.ingest.sentry.io/<project_id>
SENTRY_DSN=
# Token para upload de source maps no CI
SENTRY_AUTH_TOKEN=

# ─────────────────────────────────────────────────────────────
# SEGURANÇA / CRIPTOGRAFIA
# ─────────────────────────────────────────────────────────────

# Chave AES-256 para criptografia de credenciais ERP/API Cockpit
# Gere com: openssl rand -hex 32
ENCRYPTION_KEY=

# JWT Secret (se utilizado em algum serviço custom)
JWT_SECRET=
